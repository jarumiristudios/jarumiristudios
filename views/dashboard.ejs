<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; min-height: 40px; border-radius: 6px;
      font-size: 13.5px; color: #6b7280; font-weight: 500;
      text-decoration: none; transition: all 0.15s;
    }
    .sidebar-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.active { color: #fff; background: rgba(255,255,255,0.07); }
    .sidebar-link.new-link { color: #f59e0b; }
    .sidebar-link.new-link:hover { color: #fbbf24; background: rgba(245,158,11,0.08); }
    .sidebar-link.danger:hover { color: #f87171; background: rgba(239,68,68,0.06); }

    .status-pill {
      display: inline-flex; align-items: center;
      padding: 3px 10px; border-radius: 9999px;
      font-size: 10.5px; font-weight: 600;
      letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap;
    }
    .status-pending     { background: rgba(245,158,11,0.1);  color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
    .status-in-review   { background: rgba(99,102,241,0.1);  color: #818cf8; border: 1px solid rgba(99,102,241,0.2); }
    .status-accepted    { background: rgba(34,197,94,0.1);   color: #4ade80; border: 1px solid rgba(34,197,94,0.2); }
    .status-declined    { background: rgba(239,68,68,0.1);   color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
    .status-in-progress { background: rgba(59,130,246,0.1);  color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }
    .status-completed   { background: rgba(16,185,129,0.1);  color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
    .status-archived    { background: rgba(107,114,128,0.1); color: #9ca3af; border: 1px solid rgba(107,114,128,0.2); }
    .status-paused       { background: rgba(167,139,250,0.1); color: #a78bfa; border: 1px solid rgba(167,139,250,0.2); }

    .stat-card {
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px; padding: 24px 28px;
    }

    /* Projects table */
    .projects-table { width: 100%; border-collapse: collapse; }

    .projects-table thead th {
      padding: 10px 14px;
      text-align: left;
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #9ca3af;
      border-bottom: 1px solid rgba(255,255,255,0.10);
      white-space: nowrap;
    }

    .projects-table tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.07);
      transition: background 0.15s;
    }
    .projects-table tbody tr:hover { background: rgba(255,255,255,0.03); }

    .projects-table tbody td {
      padding: 12px 14px;
      font-size: 13px;
      color: #d1d5db;
      vertical-align: middle;
    }

    .project-code-link {
      font-family: 'Courier New', monospace;
      font-size: 12px;
      color: #e5e7eb;
      text-decoration: none;
      font-weight: 600;
      letter-spacing: 0.03em;
    }
    .project-code-link:hover { color: #f59e0b; }

    .thumb-cell { width: 72px; }
    .thumb-wrap {
      width: 64px; height: 42px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 4px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .thumb-wrap video {
      width: 100%; height: 100%; object-fit: cover;
    }
    .thumb-placeholder {
      color: #6b7280;
    }

    .brief-cell {
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      color: #9ca3af;
      font-size: 12.5px;
    }

    .amount-cell {
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .amount-zero { color: #6b7280; }
    .amount-est  { color: #9ca3af; }
    .amount-pos  { color: #d1d5db; }
    .amount-due  { color: #f87171; }

    .cta-btn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 6px;
      background: transparent; border: none; cursor: pointer;
      color: #ffffff; transition: all 0.15s;
    }
    .cta-btn:hover { background: rgba(255,255,255,0.06); }
    .cta-btn.danger:hover { background: rgba(239,68,68,0.15); color: #fca5a5; }
    .cta-btn.warn:hover   { background: rgba(245,158,11,0.15); color: #fcd34d; }
    .cta-btn.info:hover   { background: rgba(99,102,241,0.15); color: #a5b4fc; }
    .cta-btn.pay:hover    { background: rgba(34,197,94,0.15); color: #86efac; }
    .cta-btn.download:hover { background: rgba(245,158,11,0.15); color: #fcd34d; }

    .projects-table tbody tr.selected { background: rgba(255,255,255,0.04); }
    .row-cb { width: 36px; padding: 0 0 0 16px; }
    .cb-icon { color: #4b5563; cursor: pointer; transition: color 0.15s; display: block; }
    .cb-icon:hover { color: #9ca3af; }
    .cb-icon.checked { color: #f59e0b; }
    #client-bulk-bar {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      display: none; align-items: center; gap: 12px;
      background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; padding: 10px 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 50; white-space: nowrap;
    }
    #client-bulk-bar.visible { display: flex; }
    .bulk-action-btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 600; padding: 6px 12px; border-radius: 8px;
      border: none; cursor: pointer; background: transparent; transition: all 0.15s;
    }
    .bulk-action-btn.danger { color: #f87171; }
    .bulk-action-btn.danger:hover { background: rgba(239,68,68,0.12); color: #fca5a5; }
    .bulk-action-btn.warn   { color: #f59e0b; }
    .bulk-action-btn.warn:hover   { background: rgba(245,158,11,0.12); color: #fcd34d; }
    .bulk-action-btn.info   { color: #818cf8; }
    .bulk-action-btn.info:hover   { background: rgba(99,102,241,0.12); color: #a5b4fc; }
    .bulk-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.08); }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <%
    const total       = user.bookings ? user.bookings.length : 0;
    const active      = user.bookings ? user.bookings.filter(b => !b.archived && ['accepted','in-progress'].includes(b.status)).length : 0;
    const completed   = user.bookings ? user.bookings.filter(b => b.status === 'completed').length : 0;
    const pendingRevs = user.bookings ? user.bookings.filter(b => b.revisions && b.revisions.some(r => r.status === 'pending')).length : 0;
  %>

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[#0d0d0d] border-b border-white/5 flex items-center justify-between px-4">
    <span class="brand text-[15px] font-bold text-white">Jarumiri<span class="text-amber-400">.</span></span>
    <button onclick="toggleSidebar()" class="text-gray-500 hover:text-white transition-colors p-1.5">
      <iconify-icon icon="material-symbols-light:menu" width="22" height="22"></iconify-icon>
    </button>
  </header>

  <div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-30 hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-screen w-55 bg-[#0d0d0d] border-r border-white/5 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="h-16.25 flex items-center px-5 border-b border-white/5 shrink-0">
      <span class="brand text-[15px] font-bold text-white">Jarumiri Studios<span class="text-amber-400">.</span></span>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/dashboard" class="sidebar-link active">
        <iconify-icon icon="material-symbols-light:grid-view" width="20" height="20"></iconify-icon>
        Overview
      </a>
      <a href="/dashboard/gallery" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:photo-library" width="20" height="20"></iconify-icon>
        Gallery
      </a>
      <a href="/dashboard/messages" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:chat" width="20" height="20"></iconify-icon>
        <span class="flex-1">Messages</span>
        <% if (locals.unreadMessageCount > 0) { %>
        <span style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;"><%= unreadMessageCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/notifications" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:notifications" width="20" height="20"></iconify-icon>
        <span class="flex-1">Notifications</span>
        <% if (locals.unreadCount > 0) { %>
        <span style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/invoices" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:receipt-long-outline" width="20" height="20"></iconify-icon>
        Invoices
      </a>
      <a href="/dashboard/account" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:person" width="20" height="20"></iconify-icon>
        Account
      </a>
    </nav>

    <div class="px-3 pb-4 border-t border-white/5 shrink-0 space-y-1">
      <a href="/dashboard/new"
        class="flex items-center gap-2.5 w-full px-3 min-h-10 rounded-md bg-amber-400 text-black text-[13.5px] font-bold hover:bg-amber-300 transition-colors">
        <iconify-icon icon="material-symbols-light:add" width="20" height="20"></iconify-icon>
        New project
      </a>
      <a href="https://t.me/jarumiri" target="_blank" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:forum" width="20" height="20"></iconify-icon>
        Support
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="lg:ml-55 min-h-screen">
    <div class="lg:hidden h-14"></div>

    <main style="padding: 24px 50px 50px;">


      <!-- Projects section -->
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-sm font-semibold text-white">Projects</h2>
        <% if (total > 0) { %>
        <div class="flex items-center gap-4 text-[11px] font-semibold uppercase tracking-widest">
          <span class="text-gray-400"><%= total %> total</span>
          <span class="<%= active > 0 ? 'text-amber-400' : 'text-gray-400' %>"><%= active %> active</span>
          <span class="<%= completed > 0 ? 'text-green-400' : 'text-gray-400' %>"><%= completed %> completed</span>
          <span class="<%= pendingRevs > 0 ? 'text-amber-400' : 'text-gray-400' %>"><%= pendingRevs %> revisions</span>
        </div>
        <% } %>
      </div>

      <!-- Bulk action bar -->
      <div id="client-bulk-bar">
        <span id="client-bulk-count" class="text-sm text-gray-400"></span>
        <div class="bulk-divider"></div>
        <button class="bulk-action-btn danger" onclick="bulkDelete()">
          <iconify-icon icon="material-symbols-light:delete" width="20" height="20"></iconify-icon>
          Delete
        </button>
        <button class="bulk-action-btn warn" onclick="bulkPause()">
          <iconify-icon icon="material-symbols-light:pause-circle" width="20" height="20"></iconify-icon>
          Pause
        </button>
        <button class="bulk-action-btn info" onclick="bulkNudge()">
          <iconify-icon icon="material-symbols-light:notifications-active" width="20" height="20"></iconify-icon>
          Nudge
        </button>
        <div class="bulk-divider"></div>
        <button class="bulk-action-btn" style="color:#6b7280;" onclick="clientClearSelection()" title="Clear selection">
          <iconify-icon icon="material-symbols-light:close" width="20" height="20"></iconify-icon>
        </button>
      </div>

      <% if (!user.bookings || user.bookings.length === 0) { %>
      <div class="text-center py-20 border border-white/5 rounded-lg bg-white/1">
        <div class="w-11 h-11 rounded-md bg-white/3 border border-white/8 flex items-center justify-center mx-auto mb-4">
          <iconify-icon icon="material-symbols-light:description" width="22" height="22" class="text-gray-700"></iconify-icon>
        </div>
        <p class="text-gray-600 text-sm mb-3">No projects yet.</p>
        <a href="/dashboard/new" class="text-amber-400 text-sm hover:text-amber-300 transition-colors font-medium">Submit your first project →</a>
      </div>

      <% } else { %>
      <div style="overflow-x: auto; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px;">
        <table class="projects-table">
          <thead>
            <tr>
              <th class="row-cb">
                <iconify-icon id="client-select-all" icon="material-symbols-light:check-box-outline-blank" width="20" height="20" class="cb-icon" onclick="clientToggleSelectAll()"></iconify-icon>
              </th>
              <th class="thumb-cell"></th>
              <th>Code</th>
              <th>Service</th>
              <th>Package</th>
              <th>Date</th>
              <th>Brief</th>
              <th>Est. Cost</th>
              <th>Paid</th>
              <th>Due</th>
              <th>Status</th>
              <th style="text-align:right; padding-right:16px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% user.bookings.forEach(b => {
              const dateStr = new Date(b.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
              const videoFile = b.uploadedFiles && b.uploadedFiles.find(f => f.mimetype && f.mimetype.startsWith('video/'));
              const thumbSrc = videoFile ? `/dashboard/uploads/${videoFile.storedName}` : null;
              const price = b.agreedPrice || null;
              const estimatedTotal = (TIER_PRICES[b.pricingTier] || 0) + (b.addOns || []).reduce((s, a) => s + (ADDON_PRICES[a] || 0), 0) - (b.discountAmount || 0);
              const displayCost = price || (estimatedTotal > 0 ? estimatedTotal : null);
              const isEstimate  = !price && displayCost != null;
              const depositPaid = b.depositStatus === 'paid';
              const finalPaid   = b.finalPaymentStatus === 'paid';
              const amountPaid  = price ? (depositPaid ? price * 0.30 : 0) + (finalPaid ? price * 0.70 : 0) : 0;
              const remaining   = price ? price - amountPaid : null;
              const fmtMoney = (v) => v != null ? '$' + v.toFixed(2) : '—';
              const canManage = !b.archived && b.status !== 'declined' && b.status !== 'completed';
              const pendingInvoiceUrl = b.depositStatus === 'pending' ? b.depositInvoiceUrl : (b.finalPaymentStatus === 'pending' ? b.finalInvoiceUrl : null);
            %>
            <tr data-id="<%= b._id %>" data-crcode="<%= b.crCode %>" data-manageable="<%= canManage %>" data-status="<%= b.status %>" onclick="window.location='/dashboard/booking/<%= b._id %>'" style="cursor:pointer;">
              <!-- Checkbox -->
              <td class="row-cb">
                <iconify-icon icon="material-symbols-light:check-box-outline-blank" width="20" height="20" class="cb-icon" onclick="event.stopPropagation(); clientToggleRow(this, '<%= b._id %>')"></iconify-icon>
              </td>

              <!-- Thumbnail -->
              <td class="thumb-cell">
                <div class="thumb-wrap">
                  <% if (thumbSrc) { %>
                  <video src="<%= thumbSrc %>" muted preload="auto" class="project-thumb"></video>
                  <% } else { %>
                  <iconify-icon icon="material-symbols-light:movie" width="18" height="18" class="thumb-placeholder"></iconify-icon>
                  <% } %>
                </div>
              </td>

              <!-- CR Code -->
              <td>
                <a href="/dashboard/booking/<%= b._id %>" class="project-code-link"><%= b.crCode %></a>
              </td>

              <!-- Service -->
              <td style="white-space:nowrap; color:#d1d5db; font-size:13px;"><%= b.serviceType.join(', ') %></td>

              <!-- Package -->
              <td style="white-space:nowrap;">
                <span style="font-size:12px; font-weight:500; color:#9ca3af; letter-spacing:0.02em;"><%= b.pricingTier %></span>
              </td>

              <!-- Date -->
              <td style="white-space:nowrap; color:#9ca3af; font-size:12.5px;"><%= dateStr %></td>

              <!-- Brief -->
              <td class="brief-cell" title="<%= b.projectBrief %>"><%= b.projectBrief %></td>

              <!-- Est. Cost -->
              <td class="amount-cell <%= price ? 'amount-pos' : (isEstimate ? 'amount-est' : 'amount-zero') %>">
                <% if (price) { %><%= fmtMoney(price) %>
                <% } else if (isEstimate) { %>~<%= fmtMoney(displayCost) %>
                <% } else { %>—<% } %>
              </td>

              <!-- Paid -->
              <td class="amount-cell <%= amountPaid > 0 ? 'amount-pos' : 'amount-zero' %>"><%= price ? fmtMoney(amountPaid) : '—' %></td>

              <!-- Remaining / Due -->
              <td class="amount-cell <%= remaining && remaining > 0 ? 'amount-due' : 'amount-zero' %>"><%= remaining != null ? (remaining > 0 ? fmtMoney(remaining) : '—') : '—' %></td>

              <!-- Status -->
              <td>
                <span class="status-pill status-<%= b.archived ? 'archived' : b.status %>"><%= b.archived ? 'Archived' : b.status.replace('-', '‑') %></span>
              </td>

              <!-- CTAs -->
              <td style="text-align:right; padding-right:16px;">
                <div style="display:inline-flex; align-items:center; gap:2px;">
                  <% if (pendingInvoiceUrl) { %>
                  <a class="cta-btn pay" title="Pay now" href="<%= pendingInvoiceUrl %>" target="_blank" rel="noopener" onclick="event.stopPropagation()">
                    <iconify-icon icon="material-symbols-light:send-money" width="20" height="20"></iconify-icon>
                  </a>
                  <% } %>
                  <% if (b.deliverablesUnlocked && b.deliverableFiles && b.deliverableFiles.length > 0) { %>
                  <a class="cta-btn download" title="Download final files" href="/dashboard/booking/<%= b._id %>" onclick="event.stopPropagation()">
                    <iconify-icon icon="material-symbols-light:download-for-offline" width="20" height="20"></iconify-icon>
                  </a>
                  <% } %>
                  <button class="cta-btn danger" title="Delete project" onclick="event.stopPropagation(); deleteProject('<%= b._id %>', '<%= b.crCode %>')">
                    <iconify-icon icon="material-symbols-light:delete" width="20" height="20"></iconify-icon>
                  </button>
                  <% if (canManage && b.status !== 'paused') { %>
                  <button class="cta-btn warn" title="Pause project" onclick="event.stopPropagation(); pauseProject('<%= b._id %>', '<%= b.crCode %>')">
                    <iconify-icon icon="material-symbols-light:pause-circle" width="20" height="20"></iconify-icon>
                  </button>
                  <% } %>
                  <% if (canManage) { %>
                  <button class="cta-btn info" title="Nudge admin" onclick="event.stopPropagation(); nudgeAdmin('<%= b._id %>', '<%= b.crCode %>')">
                    <iconify-icon icon="material-symbols-light:notifications-active" width="20" height="20"></iconify-icon>
                  </button>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

    </main>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }

    // Seek video thumbnails to first frame
    document.querySelectorAll('video.project-thumb').forEach(v => {
      const seek = () => { if (v.currentTime === 0) v.currentTime = 0.1; };
      if (v.readyState >= 2) seek();
      else v.addEventListener('loadeddata', seek, { once: true });
    });

    // ── Bulk selection ──
    const clientChecked = new Set();

    function clientUpdateBulkBar() {
      const bar = document.getElementById('client-bulk-bar');
      const countEl = document.getElementById('client-bulk-count');
      const n = clientChecked.size;
      bar.classList.toggle('visible', n > 0);
      countEl.textContent = n + ' selected';
      const allRows = [...document.querySelectorAll('.projects-table tbody tr[data-id]')];
      const allChecked = allRows.length > 0 && allRows.every(r => clientChecked.has(r.dataset.id));
      const saIcon = document.getElementById('client-select-all');
      if (saIcon) {
        saIcon.setAttribute('icon', allChecked
          ? 'material-symbols-light:check-box'
          : 'material-symbols-light:check-box-outline-blank');
        saIcon.classList.toggle('checked', allChecked);
      }
    }

    function clientToggleRow(icon, id) {
      const row = icon.closest('tr');
      if (clientChecked.has(id)) {
        clientChecked.delete(id);
        icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank');
        icon.classList.remove('checked');
        row.classList.remove('selected');
      } else {
        clientChecked.add(id);
        icon.setAttribute('icon', 'material-symbols-light:check-box');
        icon.classList.add('checked');
        row.classList.add('selected');
      }
      clientUpdateBulkBar();
    }

    function clientToggleSelectAll() {
      const allRows = [...document.querySelectorAll('.projects-table tbody tr[data-id]')];
      const allChecked = allRows.every(r => clientChecked.has(r.dataset.id));
      allRows.forEach(row => {
        const icon = row.querySelector('.cb-icon');
        const id = row.dataset.id;
        if (allChecked) {
          clientChecked.delete(id);
          icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank');
          icon.classList.remove('checked');
          row.classList.remove('selected');
        } else {
          clientChecked.add(id);
          icon.setAttribute('icon', 'material-symbols-light:check-box');
          icon.classList.add('checked');
          row.classList.add('selected');
        }
      });
      clientUpdateBulkBar();
    }

    function clientClearSelection() {
      [...clientChecked].forEach(id => {
        const row = document.querySelector(`.projects-table tbody tr[data-id="${id}"]`);
        if (row) {
          row.classList.remove('selected');
          const icon = row.querySelector('.cb-icon');
          if (icon) { icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank'); icon.classList.remove('checked'); }
        }
      });
      clientChecked.clear();
      clientUpdateBulkBar();
    }

    // ── Single-row actions ──
    async function deleteProject(id, code) {
      const ok = await showConfirm({
        title: `Delete project ${code}?`,
        message: 'Uploaded files will be permanently removed.',
        detail: 'This cannot be undone.',
        confirmLabel: 'Delete',
        tone: 'danger',
      });
      if (!ok) return;
      fetch(`/dashboard/booking/${id}/delete`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(r => r.ok ? location.reload() : alert('Could not delete project.'))
        .catch(() => alert('Could not delete project.'));
    }

    function pauseProject(id, code) {
      fetch(`/dashboard/booking/${id}/pause`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(r => r.ok ? location.reload() : alert('Could not pause project.'))
        .catch(() => alert('Could not pause project.'));
    }

    function nudgeAdmin(id, code) {
      fetch(`/dashboard/booking/${id}/nudge`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(async r => {
          if (r.ok) return showToast('Nudge sent!', `Admin has been notified about project ${code}.`);
          if (r.status === 429) return alert((await r.json()).error);
          alert('Could not send nudge.');
        })
        .catch(() => alert('Could not send nudge.'));
    }

    // ── Bulk actions ──
    async function bulkDelete() {
      const ids = [...clientChecked];
      if (!ids.length) return;
      const rows = ids.map(id => document.querySelector(`tr[data-id="${id}"]`));
      const codes = rows.map(r => r ? r.dataset.crcode : id).join(', ');
      const ok = await showConfirm({
        title: `Delete ${ids.length} project(s)?`,
        message: 'Uploaded files will be permanently removed.',
        detail: codes + '\n\nThis cannot be undone.',
        confirmLabel: 'Delete',
        tone: 'danger',
      });
      if (!ok) return;
      Promise.all(ids.map(id =>
        fetch(`/dashboard/booking/${id}/delete`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      )).then(() => location.reload());
    }

    function manageableIds(ids) {
      return ids.filter(id => document.querySelector(`tr[data-id="${id}"]`)?.dataset.manageable === 'true');
    }

    function bulkPause() {
      const ids = manageableIds([...clientChecked]).filter(id =>
        document.querySelector(`tr[data-id="${id}"]`)?.dataset.status !== 'paused'
      );
      if (!ids.length) return;
      Promise.all(ids.map(id =>
        fetch(`/dashboard/booking/${id}/pause`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      )).then(() => location.reload());
    }

    function bulkNudge() {
      const ids = manageableIds([...clientChecked]);
      if (!ids.length) return;
      Promise.all(ids.map(id =>
        fetch(`/dashboard/booking/${id}/nudge`, { method: 'POST', headers: { 'Content-Type': 'application/json' } }).then(r => r.ok)
      )).then(results => {
        const sent = results.filter(Boolean).length;
        if (sent === ids.length) {
          showToast('Nudges sent!', `Admin notified about ${sent} project(s).`);
        } else if (sent > 0) {
          showToast('Some nudges sent', `${sent} of ${ids.length} sent — the rest hit the 3-per-hour limit.`);
        } else {
          alert('Could not send nudges — these projects may have hit the 3-per-hour limit.');
        }
      });
    }
  </script>

  <%- include('_toast') %>
  <%- include('_confirm-modal') %>
  <%- include('_notif-poll') %>
  <% if (locals.submitted) { %>
  <script>showToast('Project submitted!', 'Request <code style="font-family:monospace;background:rgba(255,255,255,0.08);padding:1px 5px;border-radius:4px;font-size:12px;color:#e5e7eb"><%= submitted %></code> received — we\'ll be in touch soon.');</script>
  <% } %>
</body>
</html>
