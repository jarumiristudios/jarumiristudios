<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= booking.crCode %> | Jarumiri Admin</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, .brand { font-family: 'Syne', sans-serif; }
    button, a { cursor: pointer; }
    button:disabled { cursor: not-allowed; }
    .status-badge {
      display: inline-flex; align-items: center;
      font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 999px;
    }
    .status-pending   { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }
    .status-in-review { background: rgba(99,102,241,0.12);  color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
    .status-accepted  { background: rgba(34,197,94,0.12);   color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .status-declined  { background: rgba(239,68,68,0.12);   color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .detail-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #6b7280; margin-bottom: 4px; }
    .detail-value { font-size: 14px; color: #e5e7eb; }
    .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; padding: 16px; }
    .status-btn {
      font-size: 12px; font-weight: 600; padding: 8px 16px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.1);
      color: #9ca3af; background: transparent;
      transition: all 0.15s ease;
    }
    .status-btn:hover  { border-color: rgba(255,255,255,0.3); color: #fff; }
    .status-btn.active { border-color: transparent; }
    .status-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .status-btn:disabled:hover { border-color: rgba(255,255,255,0.1); color: #9ca3af; }
    .status-btn.active.s-pending     { background: rgba(245,158,11,0.15); color: #f59e0b; border-color: rgba(245,158,11,0.3); }
    .status-btn.active.s-in-review  { background: rgba(99,102,241,0.15);  color: #818cf8; border-color: rgba(99,102,241,0.3); }
    .status-btn.active.s-accepted   { background: rgba(34,197,94,0.15);   color: #4ade80; border-color: rgba(34,197,94,0.3); }
    .status-btn.active.s-declined   { background: rgba(239,68,68,0.15);   color: #f87171; border-color: rgba(239,68,68,0.3); }
    .status-btn.active.s-in-progress { background: rgba(59,130,246,0.15); color: #60a5fa; border-color: rgba(59,130,246,0.3); }
    .status-btn.active.s-completed  { background: rgba(16,185,129,0.15);  color: #34d399; border-color: rgba(16,185,129,0.3); }
    .status-btn.active.s-paused     { background: rgba(167,139,250,0.15); color: #a78bfa; border-color: rgba(167,139,250,0.3); }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased min-h-screen">

  <%- include('_sidebar', { active: 'dashboard' }) %>

  <div class="lg:ml-55 min-h-screen">
  <div class="lg:hidden h-14"></div>

  <main class="max-w-5xl mx-auto px-6 py-10 space-y-6">

    <div class="flex items-center gap-4 mb-2">
      <a href="/admin" class="text-gray-500 hover:text-white transition-colors text-sm inline-flex items-center gap-1"><iconify-icon icon="material-symbols-light:arrow-left-alt" width="16" height="16"></iconify-icon> All requests</a>
      <span class="text-white/10">|</span>
      <span class="font-mono text-amber-400 text-sm font-semibold"><%= booking.crCode %></span>
      <% if (booking.archived) { %>
      <span class="status-badge" style="background:rgba(255,255,255,0.06);color:#9ca3af;border:1px solid rgba(255,255,255,0.12);">Archived</span>
      <% } %>
      <% if (booking.filesDeleted) { %>
      <span class="status-badge" style="background:rgba(239,68,68,0.1);color:#f87171;border:1px solid rgba(239,68,68,0.2);">Files deleted by client</span>
      <% } %>
      <% if (booking.pricingTier === 'Free') { %>
      <span class="status-badge" style="background:rgba(245,158,11,0.12);color:#f59e0b;border:1px solid rgba(245,158,11,0.25);" title="Burn in the watermark before uploading deliverables — no automated watermarking pipeline.">Clip tier — watermark required</span>
      <% } %>
      <% if (booking.galleryRightsGranted) { %>
      <span class="status-badge" style="background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);">Distribution rights granted</span>
      <% } %>
    </div>

    <!-- Top row: status -->
    <div class="flex flex-col sm:flex-row sm:items-start gap-6">
      <!-- Status picker -->
      <div class="card p-4! flex flex-col gap-3 w-full">
        <p class="detail-label">Status</p>
        <% if (locals.statusError) { %>
        <div class="px-3 py-2 rounded-md bg-red-500/10 border border-red-500/25 text-red-400 text-xs">
          <%= statusError %>
        </div>
        <% } %>
        <div class="flex flex-wrap gap-2">
          <% ['pending','in-review','accepted','declined','in-progress','paused','completed'].forEach(s => {
               const isCurrent = booking.status === s;
               const isAllowed = isCurrent || (locals.statusGate ? statusGate[s] : true);
               const hint = isCurrent ? '' : (isAllowed ? '' : (locals.statusGateHints?.[s] || statusGateTerminalHint));
          %>
          <form action="/admin/booking/<%= booking._id %>/status" method="POST" style="display:inline;">
            <input type="hidden" name="status" value="<%= s %>" />
            <button type="submit"
              class="status-btn s-<%= s %> <%= isCurrent ? 'active' : '' %>"
              <%= isAllowed ? '' : 'disabled' %>
              <%= hint ? `title="${hint}"` : '' %>>
              <%= s %>
            </button>
          </form>
          <% }) %>
        </div>
        <p class="text-xs text-gray-600">
          Updated <%= new Date(booking.updatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Project details -->
      <div class="md:col-span-2 space-y-6">
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-5">Project details</h2>
          <div class="grid grid-cols-2 gap-5 mb-5">
            <div>
              <p class="detail-label">Services</p>
              <p class="detail-value"><%= booking.serviceType.join(', ') %></p>
            </div>
            <div>
              <p class="detail-label">Package</p>
              <p class="detail-value">
                <%= booking.pricingTier === 'Free' ? 'Clip' : booking.pricingTier %>
                <% if (booking.pricingTier === 'Custom' && booking.budget) { %>
                <span class="text-amber-400 ml-1">(<%= booking.budget %>)</span>
                <% } %>
              </p>
            </div>
            <% if (booking.addOns && booking.addOns.length > 0) { %>
            <div class="col-span-2">
              <p class="detail-label">Add-ons</p>
              <p class="detail-value"><%= booking.addOns.join(' · ') %></p>
            </div>
            <% } %>
            <div>
              <p class="detail-label">Submitted</p>
              <p class="detail-value"><%= new Date(booking.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'long', year:'numeric' }) %></p>
            </div>
            <div>
              <p class="detail-label">BR Code</p>
              <p class="detail-value font-mono text-amber-400"><%= booking.crCode %></p>
            </div>
          </div>
          <% const TIER_PRICES = { Clip: 79, Scene: 189, Feature: 399 };
             const ADDON_PRICES = { 'Rush delivery': 50, 'Platform cut': 30, 'Captions': 35, 'Censored preview': 45, 'Intro/outro bumper': 75, 'Extra revision': 30 };
             const FREE_TIER_EXCLUDED_ADDONS = ['Captions', 'Intro/outro bumper', 'Extra revision'];
             const TIER_ADDON_MULTIPLIERS = { Scene: 1.5, Feature: 2.5 };
             const isAddonAllowedForTier = (tier, addon) => !(tier === 'Free' && FREE_TIER_EXCLUDED_ADDONS.includes(addon));
             const addonPriceForTier = (tier, addon) => ADDON_PRICES[addon] === undefined ? undefined : Math.round(ADDON_PRICES[addon] * (TIER_ADDON_MULTIPLIERS[tier] || 1) * 100) / 100;
             if (booking.pricingTier !== 'Custom') {
               const tierBase = TIER_PRICES[booking.pricingTier] || 0;
               const addonTotal = (booking.addOns || []).reduce((s, a) => s + (isAddonAllowedForTier(booking.pricingTier, a) ? (addonPriceForTier(booking.pricingTier, a) || 0) : 0), 0);
               const tierLabel = booking.pricingTier === 'Free' ? 'Clip' : booking.pricingTier;
               const baseLabel = (booking.pricingTier === 'Free' && tierBase === 0) ? 'Free' : `$${tierBase}`;
          %>
          <div class="border-t border-white/5 pt-5 mb-5">
            <p class="detail-label mb-3">Client estimate</p>
            <div class="space-y-1.5">
              <div class="flex justify-between text-sm"><span class="text-gray-400"><%= tierLabel %> package</span><span class="text-gray-200"><%= baseLabel %></span></div>
              <% (booking.addOns || []).forEach(a => { if (isAddonAllowedForTier(booking.pricingTier, a) && addonPriceForTier(booking.pricingTier, a)) { %>
              <div class="flex justify-between text-sm"><span class="text-gray-500"><%= a %></span><span class="text-amber-400">+$<%= addonPriceForTier(booking.pricingTier, a) %></span></div>
              <% } }) %>
              <% (booking.couponCodes || []).forEach(c => { %>
              <div class="flex justify-between text-sm"><span class="text-green-400"><%= c.code === 'WELCOME' ? 'Welcome discount' : `Coupon (${c.code})` %></span><span class="text-green-400">−$<%= c.amount.toFixed(2) %></span></div>
              <% }) %>
              <div class="flex justify-between text-sm pt-2 border-t border-white/5 mt-2"><span class="text-gray-400 font-medium">Total</span><span class="text-white font-semibold">$<%= (tierBase + addonTotal - (booking.discountAmount || 0)).toFixed(2) %></span></div>
            </div>
          </div>
          <% } %>
          <div>
            <p class="detail-label mb-2">Project brief</p>
            <p class="detail-value leading-relaxed whitespace-pre-wrap text-gray-300"><%= booking.projectBrief %></p>
          </div>
        </div>

        <!-- Files -->
        <% if (booking.filesDeleted) { %>
        <div class="card">
          <p class="text-sm text-red-400">Uploaded files were permanently deleted by the client. The project brief and final deliverables remain on record.</p>
        </div>
        <% } %>
        <% if (booking.uploadedFiles && booking.uploadedFiles.length > 0) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">Uploaded files <span class="text-gray-600 font-normal text-sm"><%= booking.uploadedFiles.length %></span></h2>
          <div class="space-y-4">
            <% booking.uploadedFiles.forEach(f => {
              const url = '/admin/uploads/' + f.storedName;
              const isImage = /^image\//i.test(f.mimetype);
              const isVideo = /^video\//i.test(f.mimetype);
              const isAudio = /^audio\//i.test(f.mimetype);
              const sizeLabel = f.size < 1024*1024 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1024/1024).toFixed(1)+' MB';
            %>
            <div class="border border-white/5 rounded-md overflow-hidden">

              <% if (isImage) { %>
              <a href="<%= url %>" target="_blank">
                <img src="<%= url %>" alt="<%= f.originalName %>"
                  class="w-full max-h-72 object-contain bg-black/40" />
              </a>
              <% } else if (isVideo) { %>
              <video controls preload="metadata"
                class="w-full max-h-72 bg-black">
                <source src="<%= url %>" type="<%= f.mimetype %>">
              </video>
              <% } else if (isAudio) { %>
              <div class="px-3 pt-3">
                <audio controls class="w-full">
                  <source src="<%= url %>" type="<%= f.mimetype %>">
                </audio>
              </div>
              <% } %>

              <div class="flex items-center justify-between px-3 py-2.5 gap-3">
                <div class="flex items-center gap-2.5 min-w-0">
                  <% if (isVideo) { %>
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M4 6h8a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>
                  <% } else if (isImage) { %>
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <% } else if (isAudio) { %>
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
                  <% } else { %>
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <% } %>
                  <span class="text-gray-300 text-sm truncate"><%= f.originalName %></span>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-gray-600 text-xs"><%= sizeLabel %></span>
                  <a href="<%= url %>" download="<%= f.originalName %>"
                    class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1 rounded-full border border-amber-400/30 hover:border-amber-400/60 whitespace-nowrap">
                    Download
                  </a>
                </div>
              </div>

            </div>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Final deliverables -->
        <% if (!booking.filesDeleted) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-1">Final deliverables <span class="text-gray-600 font-normal text-sm"><%= (booking.deliverableFiles || []).length %></span></h2>
          <% if (booking.pricingTier === 'Free') { %>
          <p class="text-xs text-amber-400 mb-2">Clip tier — burn in the watermark in your NLE before uploading. There's no automated watermarking in this app.</p>
          <% } %>
          <p class="text-xs text-gray-600 mb-4">
            <% if (booking.deliverablesUnlocked) { %>
            Visible to the client on <span class="text-gray-400">/track</span> and their dashboard now that the project is marked Completed.
            <% } else { %>
            Only downloadable by the client once this project's status is set to <span class="text-gray-400">Completed</span>.
            <% } %>
          </p>
          <% if (booking.deliverableFiles && booking.deliverableFiles.length > 0) { %>
          <div class="space-y-4 mb-4">
            <% booking.deliverableFiles.forEach(f => {
              const url = '/admin/uploads/' + f.storedName;
              const isImage = /^image\//i.test(f.mimetype);
              const isVideo = /^video\//i.test(f.mimetype);
              const isAudio = /^audio\//i.test(f.mimetype);
              const sizeLabel = f.size < 1024*1024 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1024/1024).toFixed(1)+' MB';
            %>
            <div class="border border-white/5 rounded-md overflow-hidden">

              <% if (isImage) { %>
              <a href="<%= url %>" target="_blank">
                <img src="<%= url %>" alt="<%= f.originalName %>"
                  class="w-full max-h-72 object-contain bg-black/40" />
              </a>
              <% } else if (isVideo) { %>
              <video controls preload="metadata"
                class="w-full max-h-72 bg-black">
                <source src="<%= url %>" type="<%= f.mimetype %>">
              </video>
              <% } else if (isAudio) { %>
              <div class="px-3 pt-3">
                <audio controls class="w-full">
                  <source src="<%= url %>" type="<%= f.mimetype %>">
                </audio>
              </div>
              <% } %>

              <div class="flex items-center justify-between px-3 py-2.5 gap-3">
                <div class="flex items-center gap-2.5 min-w-0">
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="text-gray-300 text-sm truncate"><%= f.originalName %></span>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-gray-600 text-xs"><%= sizeLabel %></span>
                  <a href="<%= url %>" download="<%= f.originalName %>"
                    class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1 rounded-full border border-amber-400/30 hover:border-amber-400/60 whitespace-nowrap">
                    Download
                  </a>
                  <form action="/admin/booking/<%= booking._id %>/deliverables/<%= f._id %>/delete" method="POST"
                    onsubmit="return confirm('Remove this deliverable file?');">
                    <button type="submit" class="text-xs text-gray-600 hover:text-red-400 transition-colors">Remove</button>
                  </form>
                </div>
              </div>

            </div>
            <% }) %>
          </div>
          <% } %>
          <% if (booking.archived) { %>
          <p class="text-xs text-gray-600">Restore this booking to upload more final files.</p>
          <% } else { %>
          <form id="deliverables-form" action="/admin/booking/<%= booking._id %>/deliverables" method="POST" enctype="multipart/form-data">
            <label id="deliverables-label" for="deliverables-input"
              class="w-full flex items-center justify-center px-4 py-2.5 rounded-full border border-white/10 text-sm text-gray-300 hover:text-white hover:border-white/25 transition-colors cursor-pointer">
              Upload final files
            </label>
            <input id="deliverables-input" type="file" name="files" multiple class="sr-only" />
          </form>
          <script>
            (function () {
              var input = document.getElementById('deliverables-input');
              var label = document.getElementById('deliverables-label');
              var form = document.getElementById('deliverables-form');
              input.addEventListener('change', function () {
                if (!input.files.length) return;
                label.textContent = 'Uploading ' + input.files.length + ' file' + (input.files.length === 1 ? '' : 's') + '…';
                label.classList.add('pointer-events-none', 'opacity-60');
                form.submit();
              });
            }());
          </script>
          <% } %>
        </div>
        <% } %>

        <!-- Media links -->
        <% if (booking.mediaLinks && booking.mediaLinks.length > 0) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">Media links</h2>
          <div class="space-y-2">
            <% booking.mediaLinks.forEach(link => { %>
            <a href="<%= link %>" target="_blank" rel="noopener"
              class="flex items-center gap-3 text-sm text-amber-400 hover:text-amber-300 transition-colors group">
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              <span class="truncate group-hover:underline"><%= link.replace(/^https?:\/\//, '') %></span>
            </a>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- External links -->
        <% if (booking.platforms && booking.platforms.length > 0) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">External links</h2>
          <div class="space-y-2">
            <% const PLATFORM_BASES = { Instagram: 'https://instagram.com/', Twitter: 'https://x.com/', TikTok: 'https://tiktok.com/', OnlyFans: 'https://onlyfans.com/', Fansly: 'https://fansly.com/', Pornhub: 'https://pornhub.com/', MannyVids: 'https://manyvids.com/' }; %>
            <% const shorten = (s) => s.length > 16 ? s.slice(0, 8) + '…' + s.slice(-8) : s; %>
            <% booking.platforms.forEach(p => { %>
            <% const isUrl = /^https?:\/\//i.test(p.handle); %>
            <% const bare = p.handle.replace(/^@/, ''); %>
            <% const handlePath = p.platform === 'TikTok' ? `@${bare}` : bare; %>
            <% const href = isUrl ? p.handle : (PLATFORM_BASES[p.platform] ? PLATFORM_BASES[p.platform] + handlePath : null); %>
            <div class="flex items-center gap-2 text-sm">
              <% if (href) { %>
              <a href="<%= href %>" target="_blank" rel="noopener"
                class="flex items-center gap-2 min-w-0 text-amber-400 hover:text-amber-300 transition-colors group">
                <span class="shrink-0 px-2 py-0.5 rounded-md bg-amber-400/10 border border-amber-400/20 text-[11px] font-semibold"><%= p.platform %></span>
                <span class="truncate group-hover:underline"><%= shorten(p.handle) %></span>
              </a>
              <% } else { %>
              <span class="flex items-center gap-2 min-w-0 text-gray-300">
                <span class="shrink-0 px-2 py-0.5 rounded-md bg-amber-400/10 border border-amber-400/20 text-[11px] font-semibold"><%= p.platform %></span>
                <span class="truncate"><%= shorten(p.handle) %></span>
              </span>
              <% } %>
              <button type="button" data-copy="<%= href || p.handle %>" onclick="copyLinkToClipboard(this);"
                class="ml-auto shrink-0 p-1 rounded-md text-gray-500 hover:text-amber-300 hover:bg-white/5 transition-colors">
                <iconify-icon icon="material-symbols-light:content-copy-outline" width="15" height="15"></iconify-icon>
              </button>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
        <!-- Revision requests -->
        <% if (booking.revisions && booking.revisions.length > 0) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">
            Revision requests
            <% const pendingRevs = booking.revisions.filter(r => r.status === 'pending'); %>
            <% if (pendingRevs.length > 0) { %>
            <span class="ml-2 text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-400/15 text-amber-400 border border-amber-400/25"><%= pendingRevs.length %> pending</span>
            <% } %>
          </h2>
          <div class="space-y-3">
            <% booking.revisions.forEach(r => { %>
            <div class="border border-white/5 rounded-md px-3 py-2.5 <%= r.status === 'pending' ? 'border-amber-400/15 bg-amber-400/5' : '' %>">
              <p class="text-gray-300 text-sm whitespace-pre-wrap mb-2"><%= r.message %></p>
              <div class="flex items-center justify-between gap-3">
                <p class="text-gray-600 text-xs"><%= new Date(r.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></p>
                <% if (r.status === 'pending') { %>
                <form action="/admin/booking/<%= booking._id %>/revision/<%= r._id %>/reviewed" method="POST">
                  <button type="submit" class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1 rounded-full border border-amber-400/30 hover:border-amber-400/60">
                    Mark reviewed
                  </button>
                </form>
                <% } else { %>
                <span class="text-xs text-green-400 font-medium">Reviewed</span>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>

      </div>

      <!-- Sidebar: contact -->
      <div class="space-y-6">
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-3">Notes</h2>
          <% if (booking.adminNotes && booking.adminNotes.length > 0) { %>
          <div class="space-y-2.5 mb-3 max-h-64 overflow-y-auto">
            <% [...booking.adminNotes].reverse().forEach(n => { %>
            <div class="border border-white/5 rounded-md px-3 py-2" id="note-view-<%= n._id %>">
              <p class="text-gray-300 text-sm whitespace-pre-wrap"><%= n.text %></p>
              <div class="flex items-center justify-between mt-1">
                <p class="text-gray-600 text-xs"><%= new Date(n.createdAt).toLocaleString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></p>
                <div class="flex items-center gap-3">
                  <button type="button" onclick="document.getElementById('note-view-<%= n._id %>').classList.add('hidden'); document.getElementById('note-edit-<%= n._id %>').classList.remove('hidden');"
                    class="text-xs text-gray-600 hover:text-white transition-colors">Edit</button>
                  <form action="/admin/booking/<%= booking._id %>/notes/<%= n._id %>/delete" method="POST">
                    <button type="submit" class="text-xs text-gray-600 hover:text-red-400 transition-colors">Delete</button>
                  </form>
                </div>
              </div>
            </div>
            <form action="/admin/booking/<%= booking._id %>/notes/<%= n._id %>/edit" method="POST" class="hidden space-y-2" id="note-edit-<%= n._id %>">
              <textarea name="text" class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm resize-none h-12 focus:outline-none focus:border-amber-400/50"><%= n.text %></textarea>
              <div class="flex gap-2">
                <button type="submit" class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1 rounded-full border border-amber-400/30 hover:border-amber-400/60">Save</button>
                <button type="button" onclick="document.getElementById('note-edit-<%= n._id %>').classList.add('hidden'); document.getElementById('note-view-<%= n._id %>').classList.remove('hidden');"
                  class="text-xs text-gray-500 hover:text-white transition-colors px-3 py-1 rounded-full border border-white/10 hover:border-white/25">Cancel</button>
              </div>
            </form>
            <% }) %>
          </div>
          <% } %>
          <form action="/admin/booking/<%= booking._id %>/notes" method="POST" class="space-y-3">
            <textarea name="note" placeholder="Add a note…" <% if (booking.archived) { %>disabled<% } %>
              class="w-full h-12 bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-amber-400/50 resize-none disabled:opacity-40 disabled:cursor-not-allowed"></textarea>
            <button type="submit" <% if (booking.archived) { %>disabled<% } %>
              class="w-full px-4 py-2.5 rounded-full border border-white/10 text-sm text-gray-300 hover:text-white hover:border-white/25 transition-colors disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:text-gray-300 disabled:hover:border-white/10">
              Add note
            </button>
          </form>
        </div>

        <div class="card">
          <h2 class="text-base font-semibold text-white mb-5">Contact</h2>
          <div class="space-y-4">
            <div>
              <p class="detail-label">Name</p>
              <p class="detail-value"><%= booking.name %></p>
            </div>
            <div>
              <p class="detail-label">Email</p>
              <a href="mailto:<%= booking.email %>" class="detail-value text-amber-400 hover:text-amber-300 transition-colors"><%= booking.email %></a>
            </div>
            <div>
              <p class="detail-label">Location</p>
              <p class="detail-value"><%= booking.location %></p>
            </div>
            <% if (booking.clientType) { %>
            <div>
              <p class="detail-label">Client type</p>
              <p class="detail-value"><%= booking.clientType %></p>
            </div>
            <% } %>
          </div>
        </div>

        <!-- Assigned editor -->
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-3">Assigned editor</h2>
          <form action="/admin/booking/<%= booking._id %>/assign" method="POST" class="flex items-center gap-2">
            <select name="associateId"
              class="flex-1 bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50">
              <option value="">Unassigned</option>
              <% associates.forEach(a => { %>
              <option value="<%= a._id %>" <%= booking.assignedTo && booking.assignedTo.toString() === a._id.toString() ? 'selected' : '' %>><%= a.name %></option>
              <% }) %>
            </select>
            <button type="submit"
              class="px-3 py-2 rounded-md border border-white/10 text-xs text-gray-400 hover:text-white hover:border-white/25 transition-colors shrink-0">
              Save
            </button>
          </form>
        </div>

        <!-- Payment -->
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">Payment</h2>
          <% if (stripeError) { %>
          <div class="mb-4 px-3 py-2.5 rounded-md bg-red-500/10 border border-red-500/25 text-red-400 text-xs">
            Stripe error: <%= stripeError %>
          </div>
          <% } %>
          <% if (booking.agreedPrice) { %>
          <p class="detail-label mb-1">Agreed price</p>
          <p class="text-white font-semibold text-lg mb-4">$<%= booking.agreedPrice.toLocaleString('en-US', { minimumFractionDigits: 2 }) %></p>
          <% } %>

          <% if (booking.depositStatus === 'none') { %>
          <%
            const hasVideoUpload = (booking.uploadedFiles || []).some(f => f.mimetype && /^video\//i.test(f.mimetype));
            const canSendDeposit = !booking.archived && (booking.status === 'in-review' || booking.status === 'accepted' || booking.status === 'in-progress') && hasVideoUpload;
          %>
          <form action="/admin/booking/<%= booking._id %>/send-deposit" method="POST" class="space-y-3">
            <div>
              <label class="detail-label block mb-1">Agreed price (USD)</label>
              <%
                const _estimatedTotal = ((TIER_PRICES[booking.pricingTier] || 0) + (booking.addOns || []).reduce((s, a) => s + (isAddonAllowedForTier(booking.pricingTier, a) ? (addonPriceForTier(booking.pricingTier, a) || 0) : 0), 0) - (booking.discountAmount || 0));
              %>
              <input id="deposit-price-input" type="number" name="agreedPrice" min="1" step="0.01" required
                placeholder="e.g. 250.00"
                <% if (_estimatedTotal > 0) { %>value="<%= _estimatedTotal.toFixed(2) %>"<% } %>
                <% if (!canSendDeposit) { %>disabled<% } %>
                class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-amber-400/50 disabled:opacity-40 disabled:cursor-not-allowed" />
            </div>
            <div class="rounded-md border border-white/8 bg-white/3 px-3 py-2.5 space-y-1.5">
              <div class="flex justify-between text-xs">
                <span class="text-gray-400">Deposit (30%)</span>
                <span id="deposit-amount" class="text-white font-medium">$0.00</span>
              </div>
              <div class="flex justify-between text-xs">
                <span class="text-gray-400">Final (70%)</span>
                <span id="final-amount" class="text-white font-medium">$0.00</span>
              </div>
            </div>
            <div>
              <label class="detail-label block mb-1">Deposit due date</label>
              <%
                const _defaultDueDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
                const _minDueDate = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
              %>
              <input type="date" name="dueDate" required value="<%= _defaultDueDate %>" min="<%= _minDueDate %>"
                <% if (!canSendDeposit) { %>disabled<% } %>
                class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50 disabled:opacity-40 disabled:cursor-not-allowed" />
              <p class="text-xs text-gray-600 mt-1">Unpaid deposit past this date auto-declines the project. Must be at least 3 days out.</p>
            </div>
            <button id="deposit-submit-btn" type="submit" disabled
              class="w-full px-4 py-2.5 rounded-full bg-amber-400 text-black text-sm font-semibold transition-colors disabled:opacity-40 disabled:cursor-not-allowed hover:bg-amber-300 disabled:hover:bg-amber-400">
              Send Deposit Invoice (30%)
            </button>
          </form>
          <% if (!canSendDeposit && booking.archived) { %>
          <p class="text-xs text-gray-600 mt-2">Restore this booking to enable invoicing.</p>
          <% } else if (!canSendDeposit && !hasVideoUpload) { %>
          <p class="text-xs text-gray-600 mt-2">Waiting on the client to upload at least one video before invoicing.</p>
          <% } else if (!canSendDeposit) { %>
          <p class="text-xs text-gray-600 mt-2">Set status to <span class="text-gray-400">In Review</span> or higher to enable invoicing.</p>
          <% } %>

          <% } else if (booking.depositStatus === 'pending') { %>
          <div class="flex items-start gap-2.5 mb-4">
            <div class="w-2 h-2 rounded-full bg-amber-400 mt-1.5 shrink-0"></div>
            <div>
              <p class="text-sm text-white font-medium">Deposit invoice sent</p>
              <p class="text-xs text-gray-500 mt-0.5">Awaiting client payment ($<%= (booking.agreedPrice * 0.30).toFixed(2) %>)</p>
              <% if (booking.depositDueDate) { %>
              <p class="text-xs text-amber-400 mt-0.5">Due by <%= new Date(booking.depositDueDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %> — auto-declines if unpaid</p>
              <% } %>
            </div>
          </div>
          <form action="/admin/booking/<%= booking._id %>/deposit-due-date" method="POST" class="flex items-center gap-2">
            <% const _minDepositEditDate = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10); %>
            <input type="date" name="dueDate" min="<%= _minDepositEditDate %>"
              <% if (booking.depositDueDate) { %>value="<%= new Date(booking.depositDueDate).toISOString().slice(0, 10) %>" data-initial="<%= new Date(booking.depositDueDate).toISOString().slice(0, 10) %>"<% } %>
              oninput="document.getElementById('deposit-due-btn').disabled = !this.value || this.value === this.dataset.initial"
              class="flex-1 bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
            <button type="submit" id="deposit-due-btn" disabled
              class="px-3 py-2 rounded-md border border-white/10 text-xs text-gray-400 hover:text-white hover:border-white/25 transition-colors shrink-0 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:text-gray-400 disabled:hover:border-white/10">
              Update
            </button>
          </form>

          <% } else if (booking.depositStatus === 'paid' && booking.finalPaymentStatus === 'none') { %>
          <div class="flex items-start gap-2.5 mb-4">
            <div class="w-2 h-2 rounded-full bg-green-400 mt-1.5 shrink-0"></div>
            <div>
              <p class="text-sm text-white font-medium">Deposit received</p>
              <p class="text-xs text-gray-500 mt-0.5">$<%= (booking.agreedPrice * 0.30).toFixed(2) %> paid</p>
            </div>
          </div>
          <form action="/admin/booking/<%= booking._id %>/send-final" method="POST" class="space-y-3">
            <div>
              <label class="detail-label block mb-1">Final due date</label>
              <%
                const _defaultFinalDueDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
                const _minFinalDueDate = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
              %>
              <input type="date" name="dueDate" required value="<%= _defaultFinalDueDate %>" min="<%= _minFinalDueDate %>"
                class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
              <p class="text-xs text-gray-600 mt-1">Unpaid final invoice past this date is voided automatically. Must be at least 3 days out.</p>
            </div>
            <button type="submit"
              class="w-full px-4 py-2.5 rounded-full bg-green-500 hover:bg-green-400 text-black text-sm font-semibold transition-colors">
              Send Final Invoice (70%)
            </button>
          </form>

          <% } else if (booking.finalPaymentStatus === 'pending') { %>
          <div class="space-y-2.5 mb-4">
            <div class="flex items-start gap-2.5">
              <div class="w-2 h-2 rounded-full bg-green-400 mt-1.5 shrink-0"></div>
              <div>
                <p class="text-sm text-white font-medium">Deposit received</p>
                <p class="text-xs text-gray-500 mt-0.5">$<%= (booking.agreedPrice * 0.30).toFixed(2) %> paid</p>
              </div>
            </div>
            <div class="flex items-start gap-2.5">
              <div class="w-2 h-2 rounded-full bg-amber-400 mt-1.5 shrink-0"></div>
              <div>
                <p class="text-sm text-white font-medium">Final invoice sent</p>
                <p class="text-xs text-gray-500 mt-0.5">Awaiting client payment ($<%= (booking.agreedPrice * 0.70).toFixed(2) %>)</p>
                <% if (booking.finalDueDate) { %>
                <p class="text-xs text-amber-400 mt-0.5">Due by <%= new Date(booking.finalDueDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %> — voided if unpaid</p>
                <% } %>
              </div>
            </div>
          </div>
          <form action="/admin/booking/<%= booking._id %>/final-due-date" method="POST" class="flex items-center gap-2">
            <% const _minFinalEditDate = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10); %>
            <input type="date" name="dueDate" min="<%= _minFinalEditDate %>"
              <% if (booking.finalDueDate) { %>value="<%= new Date(booking.finalDueDate).toISOString().slice(0, 10) %>" data-initial="<%= new Date(booking.finalDueDate).toISOString().slice(0, 10) %>"<% } %>
              oninput="document.getElementById('final-due-btn').disabled = !this.value || this.value === this.dataset.initial"
              class="flex-1 bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
            <button type="submit" id="final-due-btn" disabled
              class="px-3 py-2 rounded-md border border-white/10 text-xs text-gray-400 hover:text-white hover:border-white/25 transition-colors shrink-0 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:text-gray-400 disabled:hover:border-white/10">
              Update
            </button>
          </form>

          <% } else if (booking.finalPaymentStatus === 'paid') { %>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <div class="w-2 h-2 rounded-full bg-green-400 mt-1.5 shrink-0"></div>
              <p class="text-sm text-white font-medium">Deposit received — $<%= (booking.agreedPrice * 0.30).toFixed(2) %></p>
            </div>
            <div class="flex items-start gap-2.5">
              <div class="w-2 h-2 rounded-full bg-green-400 mt-1.5 shrink-0"></div>
              <p class="text-sm text-white font-medium">Final payment received — $<%= (booking.agreedPrice * 0.70).toFixed(2) %></p>
            </div>
            <p class="text-xs text-green-400 font-semibold pt-1">All payments received</p>
          </div>
          <% } %>
        </div>

        <% if (booking.stripeCustomerId && !booking.archived) { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-1">Revision invoices</h2>
          <p class="text-xs text-gray-600 mb-4">Bill the client for extra revision work outside what's included.</p>

          <% if (booking.revisionInvoices && booking.revisionInvoices.length > 0) { %>
          <div class="space-y-2 mb-4">
            <% [...booking.revisionInvoices].reverse().forEach(ri => { %>
            <div class="flex items-center justify-between gap-3 border border-white/5 rounded-md px-3 py-2.5">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full shrink-0 <%= ri.status === 'paid' ? 'bg-green-400' : ri.status === 'void' ? 'bg-gray-600' : 'bg-amber-400' %>"></div>
                <div>
                  <p class="text-sm text-white font-medium">$<%= ri.amount.toFixed(2) %></p>
                  <p class="text-xs text-gray-500">
                    <%= new Date(ri.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    · <%= ri.status === 'paid' ? 'Paid' : ri.status === 'void' ? 'Void' : 'Awaiting payment' %>
                  </p>
                  <% if (ri.status === 'pending' && ri.dueDate) { %>
                  <p class="text-xs text-amber-400 mt-0.5">Due by <%= new Date(ri.dueDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
                  <% } %>
                </div>
              </div>
              <% if (ri.invoiceUrl) { %>
              <a href="<%= ri.invoiceUrl %>" target="_blank" rel="noopener"
                class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1 rounded-full border border-amber-400/30 hover:border-amber-400/60 whitespace-nowrap shrink-0">
                View
              </a>
              <% } %>
            </div>
            <% }) %>
          </div>
          <% } %>

          <form action="/admin/booking/<%= booking._id %>/send-revision-invoice" method="POST" class="space-y-3">
            <div>
              <label class="detail-label block mb-1">Amount (USD)</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm pointer-events-none">$</span>
                <input type="number" name="amount" min="1" step="0.01" value="<%= ADDON_PRICES['Extra revision'] %>" required
                  class="w-full bg-white/5 border border-white/10 rounded-md pl-6 pr-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
              </div>
            </div>
            <div>
              <label class="detail-label block mb-1">Due date</label>
              <%
                const _revDefaultDue = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
                const _revMinDue = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
              %>
              <input type="date" name="dueDate" required value="<%= _revDefaultDue %>" min="<%= _revMinDue %>"
                class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
            </div>
            <button type="submit"
              class="w-full px-4 py-2.5 rounded-full bg-amber-400/15 hover:bg-amber-400/25 text-amber-300 text-sm font-semibold border border-amber-400/30 transition-colors">
              Send revision invoice
            </button>
          </form>
        </div>
        <% } %>

        <% if (booking.depositStatus === 'paid') { %>
        <div class="card">
          <h2 class="text-base font-semibold text-white mb-4">Delivery date</h2>
          <% if (booking.deliveryDate) { %>
          <p class="text-white font-semibold text-sm mb-3">
            <%= new Date(booking.deliveryDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
          </p>
          <% } else { %>
          <p class="text-xs text-gray-600 mb-3">Not set yet — the client won't see a delivery estimate on /track until you set one.</p>
          <% } %>
          <form action="/admin/booking/<%= booking._id %>/delivery-date" method="POST" class="flex items-center gap-2">
            <input type="date" name="deliveryDate"
              <% if (booking.deliveryDate) { %>value="<%= new Date(booking.deliveryDate).toISOString().slice(0, 10) %>"<% } %>
              class="flex-1 bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
            <button type="submit"
              class="px-3 py-2 rounded-md border border-white/10 text-xs text-gray-400 hover:text-white hover:border-white/25 transition-colors shrink-0">
              Save
            </button>
          </form>
        </div>
        <% } %>

        <div class="card">
          <h2 class="text-base font-semibold text-white mb-3">Quick actions</h2>
          <div class="space-y-2">
            <% if (booking.clientId && booking.chatUnlocked) { %>
            <a href="/admin/messages/<%= booking._id %>"
              class="flex items-center gap-2.5 text-sm text-gray-400 hover:text-white transition-colors py-1">
              <iconify-icon icon="material-symbols-light:chat-outline" width="16" height="16"></iconify-icon>
              Messages
            </a>
            <% } else if (booking.clientId) { %>
            <span title="Chat opens once this project is accepted."
              class="flex items-center gap-2.5 text-sm text-gray-400 opacity-40 cursor-not-allowed py-1">
              <iconify-icon icon="material-symbols-light:chat-outline" width="16" height="16"></iconify-icon>
              Messages
            </span>
            <% } %>
            <a href="mailto:<%= booking.email %>?subject=Re: <%= booking.crCode %> — Your Jarumiri Studios Request"
              class="flex items-center gap-2.5 text-sm text-gray-400 hover:text-white transition-colors py-1">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Email client
            </a>
            <div class="pt-2 mt-2 border-t border-white/5">
              <% if (booking.archived && booking.filesDeleted) { %>
              <span class="flex items-center gap-2.5 text-sm text-red-400 py-1" title="Client permanently deleted this project — it cannot be restored">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
                Deleted by client
              </span>
              <% } else if (booking.archived) { %>
              <form action="/admin/booking/<%= booking._id %>/restore" method="POST">
                <button type="submit"
                  class="flex items-center gap-2.5 text-sm text-amber-400 hover:text-amber-300 transition-colors py-1 w-full">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"/></svg>
                  Restore project
                </button>
              </form>
              <% } else { %>
              <button type="button" onclick="document.getElementById('delete-modal').classList.remove('hidden')"
                class="flex items-center gap-2.5 text-sm text-red-500 hover:text-red-400 transition-colors py-1 w-full">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
                Archive request
              </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>

    </div>

  </main>

  </div>

  <!-- Accept + invoice modal (shown when clicking accepted with no invoice yet) -->
  <% if (booking.depositStatus === 'none') { %>
  <%
    const _modalEstimate = ((TIER_PRICES[booking.pricingTier] || 0) + (booking.addOns || []).reduce((s, a) => s + (isAddonAllowedForTier(booking.pricingTier, a) ? (addonPriceForTier(booking.pricingTier, a) || 0) : 0), 0) - (booking.discountAmount || 0));
    const _defaultDueDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
    const _minDueDate = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
  %>
  <div id="accept-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('accept-modal').classList.add('hidden')"></div>
    <div class="relative bg-[#111] border border-white/10 rounded-md p-6 max-w-sm w-full shadow-2xl">
      <div class="w-12 h-12 rounded-full bg-amber-400/10 border border-amber-400/20 flex items-center justify-center mb-5 mx-auto">
        <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h2 class="text-white font-bold text-lg text-center mb-1">Accept & send deposit invoice</h2>
      <p class="text-gray-500 text-sm text-center mb-6"><span class="font-mono text-amber-400"><%= booking.crCode %></span> — <%= booking.name %></p>
      <form action="/admin/booking/<%= booking._id %>/send-deposit" method="POST" class="space-y-4" id="accept-invoice-form">
        <div>
          <label class="text-xs text-gray-500 uppercase tracking-wider block mb-1.5">Agreed price (USD)</label>
          <input id="accept-modal-price" type="number" name="agreedPrice" min="1" step="0.01" required
            <% if (_modalEstimate > 0) { %>value="<%= _modalEstimate.toFixed(2) %>"<% } %>
            placeholder="e.g. 250.00"
            class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-amber-400/50" />
        </div>
        <div>
          <label class="text-xs text-gray-500 uppercase tracking-wider block mb-1.5">Deposit due date</label>
          <input type="date" name="dueDate" required value="<%= _defaultDueDate %>"
            class="w-full bg-white/5 border border-white/10 rounded-md px-3 py-2 text-white text-sm focus:outline-none focus:border-amber-400/50" />
          <p class="text-xs text-gray-600 mt-1">Unpaid deposit past this date auto-declines the project.</p>
        </div>
        <div class="flex gap-3 pt-1">
          <button type="button" onclick="document.getElementById('accept-modal').classList.add('hidden')"
            class="flex-1 px-4 py-2.5 rounded-full border border-white/10 text-sm text-gray-400 hover:text-white hover:border-white/25 transition-colors">
            Cancel
          </button>
          <button id="accept-modal-confirm" type="submit"
            class="flex-1 px-4 py-2.5 rounded-full bg-amber-400 hover:bg-amber-300 text-black text-sm font-semibold transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
            Accept & invoice
          </button>
        </div>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Archive confirmation modal -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="document.getElementById('delete-modal').classList.add('hidden')"></div>
    <div class="relative bg-[#111] border border-white/10 rounded-md p-6 max-w-sm w-full shadow-2xl">
      <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-5 mx-auto">
        <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
      </div>
      <h2 class="text-white font-bold text-lg text-center mb-2">Archive this request?</h2>
      <p class="text-gray-500 text-sm text-center mb-6">
        <span class="font-mono text-amber-400"><%= booking.crCode %></span> — <%= booking.name %><br>
        Files stay stored — you can restore this project anytime.
      </p>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('delete-modal').classList.add('hidden')"
          class="flex-1 px-4 py-2.5 rounded-full border border-white/10 text-sm text-gray-400 hover:text-white hover:border-white/25 transition-colors">
          Cancel
        </button>
        <form action="/admin/booking/<%= booking._id %>/archive" method="POST" class="flex-1">
          <button type="submit"
            class="w-full px-4 py-2.5 rounded-full bg-red-500/90 hover:bg-red-500 text-white text-sm font-semibold transition-colors">
            Archive
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Intercept "accepted" status button when no invoice has been sent yet
    <% if (booking.depositStatus === 'none') { %>
    (function () {
      var acceptBtn = document.querySelector('.s-accepted');
      if (!acceptBtn) return;
      var hasVideoUpload = <%- (booking.uploadedFiles || []).some(f => f.mimetype && /^video\//i.test(f.mimetype)) ? 'true' : 'false' %>;
      acceptBtn.closest('form').addEventListener('submit', function (e) {
        e.preventDefault();
        if (!hasVideoUpload) {
          showToast('Video required', "The client hasn't uploaded a video yet — wait for at least one before sending the deposit invoice.", 'error');
          return;
        }
        document.getElementById('accept-modal').classList.remove('hidden');
        document.getElementById('accept-modal-price').focus();
      });

      var modalPrice   = document.getElementById('accept-modal-price');
      var modalConfirm = document.getElementById('accept-modal-confirm');
      var modalForm    = document.getElementById('accept-invoice-form');

      function validateModal() {
        modalConfirm.disabled = !modalPrice.value || parseFloat(modalPrice.value) <= 0;
      }
      modalPrice.addEventListener('input', validateModal);
      validateModal();

      modalForm.addEventListener('submit', function () {
        modalConfirm.disabled = true;
        modalConfirm.innerHTML = '<svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';
      });
    }());
    <% } %>

    const priceInput   = document.getElementById('deposit-price-input');
    const submitBtn    = document.getElementById('deposit-submit-btn');
    const depositAmtEl = document.getElementById('deposit-amount');
    const finalAmtEl   = document.getElementById('final-amount');
    if (priceInput && submitBtn) {
      const check = () => {
        submitBtn.disabled = priceInput.disabled || !priceInput.value || parseFloat(priceInput.value) <= 0;
        const price = parseFloat(priceInput.value) || 0;
        if (depositAmtEl) depositAmtEl.textContent = '$' + (price * 0.30).toFixed(2);
        if (finalAmtEl)   finalAmtEl.textContent   = '$' + (price * 0.70).toFixed(2);
      };
      priceInput.addEventListener('input', check);
      check();

      submitBtn.closest('form').addEventListener('submit', function () {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';
      });
    }

    function copyLinkToClipboard(btn) {
      navigator.clipboard.writeText(btn.dataset.copy)
        .then(() => showToast('Copied', 'Link copied to clipboard.'))
        .catch(() => showToast('Copy failed', 'Could not copy link.', 'error'));
    }
  </script>

  <%- include('../_toast') %>
  <%- include('_notif-poll') %>
  <% if (locals.delivered) { %>
  <script>showToast('Files uploaded', '<%= delivered %> file<%= delivered === 1 ? "" : "s" %> uploaded.');</script>
  <% } %>
  <% if (locals.deliverError) { %>
  <script>showToast('Upload failed', <%- JSON.stringify(deliverError) %>, 'error');</script>
  <% } %>
</body>
</html>
