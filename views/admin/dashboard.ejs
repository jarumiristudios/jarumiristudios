<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Jarumiri Admin</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, .brand { font-family: 'Syne', sans-serif; }
    button, a { cursor: pointer; }
    .status-badge {
      display: inline-flex; align-items: center;
      font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
      padding: 3px 10px; border-radius: 999px;
    }
    .status-pending   { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }
    .status-in-review { background: rgba(99,102,241,0.12);  color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
    .status-accepted  { background: rgba(34,197,94,0.12);   color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .status-declined  { background: rgba(239,68,68,0.12);   color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .status-paused    { background: rgba(167,139,250,0.12); color: #a78bfa; border: 1px solid rgba(167,139,250,0.25); }
    .row-link { transition: background 0.15s ease; }
    .row-link:hover { background: rgba(255,255,255,0.03); }
    .row-link.selected { background: rgba(255,255,255,0.04); }
    .row-cb { width: 40px; padding: 0 0 0 16px; }
    .cb-icon { color: #4b5563; cursor: pointer; transition: color 0.15s; flex-shrink: 0; }
    .cb-icon:hover { color: #9ca3af; }
    .cb-icon.checked { color: #f59e0b; }
    #bulk-bar {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      display: none; align-items: center; gap: 12px;
      background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; padding: 10px 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 50; white-space: nowrap;
    }
    #bulk-bar.visible { display: flex; }
    .thumb-cell { width: 108px; padding: 8px 8px 8px 16px; }
    .thumb-wrap {
      width: 96px; height: 54px; border-radius: 6px; overflow: hidden;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .project-thumb { width: 100%; height: 100%; object-fit: cover; display: block; }
    .thumb-placeholder { color: #374151; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased min-h-screen">

  <!-- Header -->
  <header class="border-b border-white/5 bg-[#080808]/90 backdrop-blur-md sticky top-0 z-40">
    <div class="max-w-350 mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="brand text-lg font-bold tracking-tight">
        <span class="text-white">Jarumiri</span> Studios<span class="text-amber-400">.</span>
        <span class="text-gray-600 font-normal text-sm ml-2">/ admin</span>
      </a>
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <span><%= pending %> pending</span>
        </div>
        <a href="/admin/analytics" class="text-sm text-gray-500 hover:text-white transition-colors">Analytics</a>
        <a href="/admin/coupons" class="text-sm text-gray-500 hover:text-white transition-colors">Coupons</a>
        <a href="/admin/notifications" id="admin-notif-bell" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-white transition-colors">
          Notifications
          <% if (locals.adminUnreadCount > 0) { %>
          <span id="admin-notif-count" style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:11px;font-weight:700;"><%= adminUnreadCount %></span>
          <% } %>
        </a>
        <a href="/admin/logout" class="text-sm text-gray-500 hover:text-white transition-colors">Sign out</a>
      </div>
    </div>
  </header>

  <main class="max-w-350 mx-auto px-6 py-10">

    <!-- Title + filters -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4" id="filter-summary-region">
      <%- include('_filter-summary') %>
    </div>

    <!-- Active / Archived tabs -->
    <div class="flex gap-1 mb-6 border-b border-white/8">
      <a href="/admin"
        class="px-4 py-2.5 text-sm font-semibold border-b-2 -mb-px transition-colors <%= !archivedView ? 'text-white border-amber-400' : 'text-gray-500 border-transparent hover:text-gray-300' %>">
        Active
      </a>
      <a href="/admin?view=archived"
        class="px-4 py-2.5 text-sm font-semibold border-b-2 -mb-px transition-colors <%= archivedView ? 'text-white border-amber-400' : 'text-gray-500 border-transparent hover:text-gray-300' %>">
        Archived
      </a>
    </div>

    <!-- Search bar -->
    <div class="flex gap-2 mb-8">
      <!-- Custom field dropdown -->
      <div class="relative flex-shrink-0" id="field-dropdown">
        <button type="button" id="field-btn" onclick="toggleDropdown()"
          class="flex items-center gap-2 bg-white/[0.04] border border-white/10 rounded-md px-4 py-2.5 text-sm text-gray-300 hover:border-white/20 hover:text-white transition-colors whitespace-nowrap">
          <% const fieldOptions = [
            { value: 'all',     label: 'All fields'  },
            { value: 'crCode',  label: 'BR Code'     },
            { value: 'name',    label: 'Client name' },
            { value: 'email',   label: 'Email'       },
            { value: 'location',label: 'Location'    },
            { value: 'services',label: 'Services'    },
            { value: 'package', label: 'Package'     },
            { value: 'status',  label: 'Status'      },
          ]; %>
          <span id="field-label"><%= (fieldOptions.find(o => o.value === field) || fieldOptions[0]).label %></span>
          <svg id="field-chevron" class="w-3.5 h-3.5 text-gray-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="field-menu"
          class="hidden absolute left-0 top-full mt-1.5 z-50 min-w-[160px] bg-[#111] border border-white/10 rounded-md overflow-hidden shadow-xl">
          <% fieldOptions.forEach(opt => { %>
          <button type="button"
            class="field-option w-full text-left px-4 py-2.5 text-sm <%= opt.value === field ? 'text-white' : 'text-gray-400' %> hover:bg-white/[0.05] hover:text-white transition-colors"
            data-value="<%= opt.value %>" data-label="<%= opt.label %>"
            onclick="selectField(this)">
            <%= opt.label %>
          </button>
          <% }) %>
        </div>
        <input type="hidden" id="search-field" value="<%= field %>" />
      </div>

      <div class="relative flex-1">
        <svg class="pointer-events-none absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 111 11a6 6 0 0116 0z"/></svg>
        <input id="search-input" type="text" placeholder="Search requests…" value="<%= q %>"
          oninput="onSearchInput()"
          class="w-full bg-white/[0.04] border border-white/10 rounded-md pl-10 pr-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-amber-400/50 transition-colors" />
      </div>

      <!-- Date range filter -->
      <div class="flex items-center gap-1.5 flex-shrink-0 bg-white/[0.04] border border-white/10 rounded-md px-3 py-2.5">
        <input id="date-from" type="date" value="<%= dateFrom %>" max="<%= dateTo || '' %>"
          onchange="navigateSearch()"
          class="bg-transparent text-sm text-gray-300 focus:outline-none w-[130px]" />
        <span class="text-gray-600 text-sm">–</span>
        <input id="date-to" type="date" value="<%= dateTo %>" min="<%= dateFrom || '' %>"
          onchange="navigateSearch()"
          class="bg-transparent text-sm text-gray-300 focus:outline-none w-[130px]" />
        <% if (dateFrom || dateTo) { %>
        <button type="button" onclick="clearDateRange()" title="Clear date range"
          class="text-gray-600 hover:text-white transition-colors ml-1">
          <iconify-icon icon="material-symbols-light:close" width="16" height="16"></iconify-icon>
        </button>
        <% } %>
      </div>
    </div>

    <div id="results-table-region">
      <%- include('_results-table') %>
    </div>

  </main>

  <script>
    // ── Search (live, fetched in place — no page reload) ──
    function buildFilterUrl() {
      const params = new URLSearchParams(window.location.search);
      const q = document.getElementById('search-input').value.trim();
      const field = document.getElementById('search-field').value;
      const dateFrom = document.getElementById('date-from').value;
      const dateTo = document.getElementById('date-to').value;
      if (q) params.set('q', q); else params.delete('q');
      if (field && field !== 'all') params.set('field', field); else params.delete('field');
      if (dateFrom) params.set('dateFrom', dateFrom); else params.delete('dateFrom');
      if (dateTo) params.set('dateTo', dateTo); else params.delete('dateTo');
      params.delete('page');
      const qs = params.toString();
      return '/admin' + (qs ? '?' + qs : '');
    }

    function navigateSearch() {
      fetchAndRender(buildFilterUrl());
    }

    let searchDebounce;
    function onSearchInput() {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(navigateSearch, 400);
    }

    function clearDateRange() {
      document.getElementById('date-from').value = '';
      document.getElementById('date-to').value = '';
      navigateSearch();
    }

    // Swaps the summary + table regions in place by re-fetching the same
    // /admin route as JSON, instead of a full page navigation.
    async function fetchAndRender(url, pushState = true) {
      let res;
      try {
        res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      } catch {
        window.location = url;
        return;
      }
      if (!res.ok) { window.location = url; return; }
      const data = await res.json();
      document.getElementById('filter-summary-region').innerHTML = data.summaryHtml;
      document.getElementById('results-table-region').innerHTML = data.tableHtml;
      if (pushState) history.pushState({}, '', url);
      checkedIds.clear();
      initVideoThumbs();
    }

    function initVideoThumbs() {
      document.querySelectorAll('video.project-thumb').forEach(v => {
        v.addEventListener('loadedmetadata', () => { v.currentTime = 0.001; });
      });
    }
    initVideoThumbs();

    window.addEventListener('popstate', () => fetchAndRender(location.href, false));

    // Status filter pills and pagination links are re-rendered inside the
    // fetched regions, so intercept clicks via delegation on document.
    document.addEventListener('click', e => {
      const link = e.target.closest('.filter-btn, .page-link');
      if (link) {
        e.preventDefault();
        fetchAndRender(link.getAttribute('href'));
      }
    });

    // ── Bulk selection ──
    const checkedIds = new Set();

    function updateBulkBar() {
      const bar = document.getElementById('bulk-bar');
      const countEl = document.getElementById('bulk-count');
      const hiddenIds = document.getElementById('hidden-ids');
      const n = checkedIds.size;
      bar.classList.toggle('visible', n > 0);
      countEl.textContent = n + ' selected';
      hiddenIds.innerHTML = [...checkedIds].map(id =>
        `<input type="hidden" name="ids" value="${id}">`
      ).join('');
      // sync select-all icon
      const allVisible = [...document.querySelectorAll('tbody tr[data-id]')];
      const allChecked = allVisible.length > 0 && allVisible.every(r => checkedIds.has(r.dataset.id));
      const saIcon = document.getElementById('select-all-cb');
      if (saIcon) {
        saIcon.setAttribute('icon', allChecked
          ? 'material-symbols-light:check-box'
          : 'material-symbols-light:check-box-outline-blank');
        saIcon.classList.toggle('checked', allChecked);
      }
    }

    function toggleRow(icon, id) {
      const row = icon.closest('tr');
      if (checkedIds.has(id)) {
        checkedIds.delete(id);
        icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank');
        icon.classList.remove('checked');
        row.classList.remove('selected');
      } else {
        checkedIds.add(id);
        icon.setAttribute('icon', 'material-symbols-light:check-box');
        icon.classList.add('checked');
        row.classList.add('selected');
      }
      updateBulkBar();
    }

    function toggleSelectAll() {
      const allVisible = [...document.querySelectorAll('tbody tr[data-id]')];
      const allChecked = allVisible.every(r => checkedIds.has(r.dataset.id));
      allVisible.forEach(row => {
        const icon = row.querySelector('.cb-icon');
        const id = row.dataset.id;
        if (allChecked) {
          checkedIds.delete(id);
          icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank');
          icon.classList.remove('checked');
          row.classList.remove('selected');
        } else {
          checkedIds.add(id);
          icon.setAttribute('icon', 'material-symbols-light:check-box');
          icon.classList.add('checked');
          row.classList.add('selected');
        }
      });
      updateBulkBar();
    }

    function rowClick(e, id, url) {
      // if click originated from the checkbox cell, ignore navigation
      if (e.target.closest('.row-cb')) return;
      window.location = url;
    }

    function confirmBulkArchive() {
      document.getElementById('bulk-form').action = '/admin/bookings/bulk-archive';
      return confirm(`Archive ${checkedIds.size} project(s)? Files stay stored — you can restore them anytime.`);
    }

    function toggleBulkStatusDropdown() {
      const menu = document.getElementById('bulk-status-menu');
      const chevron = document.getElementById('bulk-status-chevron');
      const open = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', open);
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    }

    function selectBulkStatus(btn) {
      document.getElementById('bulk-status-value').value = btn.dataset.value;
      document.getElementById('bulk-status-label').textContent = btn.dataset.label;
      document.querySelectorAll('.bulk-status-option').forEach(b => {
        b.classList.toggle('text-white', b === btn);
        b.classList.toggle('text-gray-400', b !== btn);
      });
      document.getElementById('bulk-status-menu').classList.add('hidden');
      document.getElementById('bulk-status-chevron').style.transform = '';
    }

    function submitBulkStatus() {
      const status = document.getElementById('bulk-status-value').value;
      if (!status) return;
      const label = document.getElementById('bulk-status-label').textContent;
      if (!confirm(`Set ${checkedIds.size} project(s) to "${label}"?`)) return;

      const form = document.getElementById('bulk-form');
      form.action = '/admin/bookings/bulk-status';
      let statusInput = document.getElementById('bulk-status-input');
      if (!statusInput) {
        statusInput = document.createElement('input');
        statusInput.type = 'hidden';
        statusInput.id = 'bulk-status-input';
        statusInput.name = 'status';
        form.appendChild(statusInput);
      }
      statusInput.value = status;
      form.submit();
    }

    function adminClearSelection() {
      [...checkedIds].forEach(id => {
        const row = document.querySelector(`tbody tr[data-id="${id}"]`);
        if (row) {
          row.classList.remove('selected');
          const icon = row.querySelector('.cb-icon');
          if (icon) { icon.setAttribute('icon', 'material-symbols-light:check-box-outline-blank'); icon.classList.remove('checked'); }
        }
      });
      checkedIds.clear();
      updateBulkBar();
    }

    function toggleDropdown() {
      const menu = document.getElementById('field-menu');
      const chevron = document.getElementById('field-chevron');
      const open = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', open);
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    }

    function selectField(btn) {
      document.getElementById('search-field').value = btn.dataset.value;
      document.getElementById('field-label').textContent = btn.dataset.label;
      document.querySelectorAll('.field-option').forEach(b => {
        b.classList.toggle('text-white', b === btn);
        b.classList.toggle('text-gray-400', b !== btn);
      });
      document.getElementById('field-menu').classList.add('hidden');
      document.getElementById('field-chevron').style.transform = '';
      navigateSearch();
    }

    document.addEventListener('click', e => {
      if (!document.getElementById('field-dropdown').contains(e.target)) {
        document.getElementById('field-menu').classList.add('hidden');
        document.getElementById('field-chevron').style.transform = '';
      }
      if (!document.getElementById('bulk-status-dropdown').contains(e.target)) {
        document.getElementById('bulk-status-menu').classList.add('hidden');
        document.getElementById('bulk-status-chevron').style.transform = '';
      }
    });
  </script>

  <%- include('../_toast') %>
  <%- include('_notif-poll') %>
</body>
</html>
