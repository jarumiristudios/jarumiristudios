<div id="toast-container" class="fixed bottom-5 right-5 z-[9999] flex flex-col gap-2 items-end pointer-events-none"></div>

<script>
(function () {
  const TYPES = {
    success: {
      wrap:  'bg-green-500/[0.07] border-green-500/20',
      icon:  'bg-green-500/15 border-green-500/25 text-green-400',
      title: 'text-green-400',
      svg:   'material-symbols-light:check-circle',
    },
    error: {
      wrap:  'bg-red-500/10 border-red-500/20',
      icon:  'bg-red-500/15 border-red-500/25 text-red-400',
      title: 'text-red-400',
      svg:   'material-symbols-light:cancel',
    },
    info: {
      wrap:  'bg-blue-500/10 border-blue-500/20',
      icon:  'bg-blue-500/15 border-blue-500/25 text-blue-400',
      title: 'text-blue-400',
      svg:   'material-symbols-light:info',
    },
  };

  window.showToast = function (title, body, type) {
    const c = TYPES[type] || TYPES.success;
    const el = document.createElement('div');
    el.className = 'pointer-events-auto w-[360px] max-w-[calc(100vw-2.5rem)] flex items-start gap-3 p-4 rounded-md border shadow-xl ' + c.wrap;
    Object.assign(el.style, { transform: 'translateX(110%)', opacity: '0', transition: 'transform 0.3s ease, opacity 0.3s ease' });
    el.innerHTML =
      '<div class="w-7 h-7 rounded-full border flex items-center justify-center shrink-0 mt-0.5 ' + c.icon + '">' +
        '<iconify-icon icon="' + c.svg + '" width="14" height="14"></iconify-icon>' +
      '</div>' +
      '<div class="flex-1 min-w-0">' +
        '<p class="text-sm font-semibold ' + c.title + '">' + title + '</p>' +
        (body ? '<p class="text-sm text-gray-300 mt-0.5">' + body + '</p>' : '') +
      '</div>' +
      '<button class="text-gray-600 hover:text-gray-400 transition-colors shrink-0 mt-0.5 cursor-pointer">' +
        '<iconify-icon icon="material-symbols-light:close" width="14" height="14"></iconify-icon>' +
      '</button>';
    el.querySelector('button').addEventListener('click', function () { dismiss(el); });
    document.getElementById('toast-container').appendChild(el);
    el.getBoundingClientRect();
    el.style.transform = 'translateX(0)';
    el.style.opacity = '1';

    var remaining = 5000;
    var start = Date.now();
    function startTimer() {
      start = Date.now();
      el._t = setTimeout(function () { dismiss(el); }, remaining);
    }
    el.addEventListener('mouseenter', function () {
      clearTimeout(el._t);
      remaining -= Date.now() - start;
    });
    el.addEventListener('mouseleave', function () {
      startTimer();
    });
    startTimer();
  };

  function dismiss(el) {
    if (el._gone) return;
    el._gone = true;
    clearTimeout(el._t);
    el.style.transform = 'translateX(110%)';
    el.style.opacity = '0';
    setTimeout(function () { el.remove(); }, 300);
  }
}());
</script>
