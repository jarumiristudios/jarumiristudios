        <!-- Feature -->
        <div class="p-7 rounded-2xl bg-white/[0.03] border border-white/8 card-hover flex flex-col">
          <p class="text-xs font-semibold tracking-widest text-gray-500 uppercase mb-3">Feature</p>
          <p class="text-4xl font-bold text-white mb-1">$399</p>
          <p class="text-gray-600 text-sm mb-2">per project</p>
          <p class="text-gray-500 text-xs mb-6">Series, long-form, full productions</p>
          <ul class="text-gray-400 text-sm space-y-2.5 mb-8 flex-1">
            <li class="flex gap-2"><span class="text-amber-400">✓</span> Unlimited length / multi-part</li>
