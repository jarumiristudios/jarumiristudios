  <!-- ═══════════════════════════════ REEL ═══════════════════════════════ -->
  <section id="reel" class="py-24 bg-[#0d0d0d]" style="display:none;">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase mb-3">Showreel</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">Selected Recent Works</h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <% const reelItems = [
          { name: 'Client Name', date: 'June 2025' },
          { name: 'Client Name', date: 'May 2025' },
          { name: 'Client Name', date: 'April 2025' }
        ]; %>
        <% reelItems.forEach(function(item) { %>
        <div>
          <div class="rounded-xl bg-white/5 border border-white/8 w-full" style="aspect-ratio: 0.5625;"></div>
          <div class="flex items-center gap-3 mt-3">
            <div class="w-9 h-9 rounded-full bg-white/10 border border-white/10 flex-shrink-0"></div>
            <div>
              <p class="text-sm font-semibold text-white leading-tight"><%= item.name %></p>
              <p class="text-xs text-gray-500"><%= item.date %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ HOW IT WORKS ═══════════════════════════════ -->
  <section id="process" class="py-24 bg-[#080808]">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase mb-3">The Process</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">How It Works</h2>
      <p class="text-gray-500 text-lg mb-16 max-w-xl">Four straightforward steps from raw footage to final delivery.</p>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-0">

        <% const steps = [
          {
            num: '01',
            title: 'Submit a Request',
            desc: 'Fill out the booking form — name, location, contact info, and a quick brief on what you need. Upload your files directly (up to 250 MB). Every project gets attributed a Booking Request (BR) code. For files over 250 MB, send them through Messages once you\'re signed in.',
            note: null
          },
          {
            num: '02',
            title: 'Invoice & Upfront',
            desc: 'The request gets reviewed and an invoice is sent with a timeline estimate and total cost. A Stripe link covers 30% upfront before work begins. Revision rounds are included based on your package — anything beyond that is $30 per round.',
            note: '30% upfront · revisions vary by package'
          },
          {
            num: '03',
            title: 'Production',
            desc: 'Once the deposit lands, a confirmation goes out by email and editing begins. Status can be tracked via the BR code. Any questions that come up during the project will be relayed directly.',
            note: null
          },
          {
            num: '04',
            title: 'Delivery & Final Pay',
            desc: 'When the project is done, you\'ll receive a link to pay the remaining balance. After payment clears, you\'re taken to a private page to download or preview the final video — and request any revisions you still have available.',
            note: null
          }
        ]; %>

        <% steps.forEach(function(step, i) { %>
        <div class="flex flex-col mb-10 md:mb-0">
          <!-- Bubble + connector row — no column padding so line runs flush to grid boundary -->
          <div class="flex items-center mb-6">
            <div class="w-16 h-16 rounded-full border border-white/10 bg-[#080808] flex items-center justify-center flex-shrink-0">
              <span class="text-amber-400 font-bold text-sm font-mono"><%= step.num %></span>
            </div>
            <% if (i < steps.length - 1) { %>
            <div class="hidden md:block flex-1 h-px bg-white/20 ml-4"></div>
            <% } %>
          </div>
          <div class="pr-4">
            <h3 class="font-bold text-white text-lg mb-3"><%= step.title %></h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1"><%= step.desc %></p>
            <% if (step.note) { %>
            <span class="inline-block mt-4 text-[11px] font-semibold tracking-wider uppercase text-amber-400/70 border border-amber-400/20 rounded-full px-3 py-1 w-fit"><%= step.note %></span>
            <% } %>
          </div>
        </div>

        <!-- Arrow between steps (desktop) -->
        <% if (i < steps.length - 1) { %>
        <!-- intentional gap handled by grid -->
        <% } %>
        <% }); %>

      </div>

      <div class="mt-16 pt-10 border-t border-white/5 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <p class="text-gray-500 text-sm">Have a large project or not sure where to start?</p>
        <a href="/hire"
           class="text-sm font-semibold px-6 py-3 rounded-full border border-white/15 text-white hover:border-white/40 transition-colors flex-shrink-0">
          Get in Touch →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ SERVICES ═══════════════════════════════ -->
  <section id="services" class="py-24 bg-[#080808]">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase mb-3">What You Get</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-12">Services</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <% const services = [
          { icon: '🎬', name: 'Video Editing', desc: 'Your raw footage turned into something people actually want to watch. Every cut lands, every second earns its place.' },
          { icon: '🎨', name: 'Color Grading', desc: 'We adjust how the image looks — skin tones, lighting, mood — so the final video feels exactly how you pictured it, or better.' },
          { icon: '🔊', name: 'Sound Design', desc: 'Bad audio kills good video. We clean up the sound, balance the music, and make sure everything sounds as good as it looks.' },
          { icon: '✨', name: 'Motion Graphics', desc: 'Animated text, intros, outros, and on-screen elements that make your content look polished — not like something you edited on your phone.' }
        ]; %>
        <% services.forEach(function(s) { %>
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/8 card-hover">
          <div class="text-3xl mb-4"><%= s.icon %></div>
          <h3 class="font-bold text-white mb-2"><%= s.name %></h3>
          <p class="text-gray-500 text-sm leading-relaxed"><%= s.desc %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ PRICING ═══════════════════════════════ -->
