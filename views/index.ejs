  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }
    .gradient-text {
      background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-bg {
      background: radial-gradient(ellipse at 60% 0%, rgba(245,158,11,0.12) 0%, transparent 60%),
                  radial-gradient(ellipse at 0% 80%, rgba(239,68,68,0.08) 0%, transparent 50%),
                  #080808;
    }
    .card-hover {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(245,158,11,0.12);
    }
    .nav-link {
      position: relative;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: #f59e0b;
      transition: width 0.25s ease;
    }
    .nav-link:hover::after { width: 100%; }
    html { scroll-behavior: smooth; }
  </style>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Jarumiri Studios",
    "description": "Delivering precision video editing and photo retouching for adult content creators on OnlyFans, Fansly, and more.",
    "url": "https://jarumiri.studio",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "url": "https://t.me/jarumiri"
    },
    "serviceType": ["Video Editing", "Photo Retouching", "Color Grading", "Motion Graphics"]
  }
  </script>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <!-- ═══════════════════════════════ NAVBAR ═══════════════════════════════ -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-md bg-[#080808]/80">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="brand text-xl font-bold tracking-tight">
        <span class="text-white">Jarumiri</span> Studios<span class="text-amber-400">.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-gray-400 font-medium">
        <a href="#services" class="nav-link hover:text-white transition-colors">Services</a>
        <a href="#pricing"  class="nav-link hover:text-white transition-colors">Pricing</a>
        <a href="#about"    class="nav-link hover:text-white transition-colors">About</a>
        <a href="#career"   class="nav-link hover:text-white transition-colors">Careers</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="/login"
           class="hidden md:inline-flex text-sm font-semibold px-5 py-3.5 rounded-full border border-white/15 text-white hover:border-white/40 transition-colors">
          Log In
        </a>
        <a href="/hire"
           class="text-sm font-semibold px-7 py-3.5 rounded-full bg-amber-400 text-black hover:bg-amber-300 transition-colors">
          Book A Project
        </a>
        <!-- Hamburger (mobile only) -->
        <button id="menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5" aria-label="Open menu">
          <span class="menu-bar block w-5 h-px bg-white transition-all duration-300"></span>
          <span class="menu-bar block w-5 h-px bg-white transition-all duration-300"></span>
          <span class="menu-bar block w-5 h-px bg-white transition-all duration-300"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile drawer -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-white/5 bg-[#080808]">
      <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5 text-sm text-gray-400 font-medium">
        <a href="#process"  class="hover:text-white transition-colors" onclick="closeMobileMenu()">How It Works</a>
        <a href="#services" class="hover:text-white transition-colors" onclick="closeMobileMenu()">Services</a>
        <a href="#pricing"  class="hover:text-white transition-colors" onclick="closeMobileMenu()">Pricing</a>
        <a href="#about"    class="hover:text-white transition-colors" onclick="closeMobileMenu()">About</a>
        <a href="#career"   class="hover:text-white transition-colors" onclick="closeMobileMenu()">Careers</a>
        <a href="/login"    class="hover:text-white transition-colors">Log In</a>
      </div>
    </div>
  </header>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const bars = menuBtn.querySelectorAll('.menu-bar');

    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      bars[0].style.transform = isOpen ? '' : 'translateY(6px) rotate(45deg)';
      bars[1].style.opacity  = isOpen ? '' : '0';
      bars[2].style.transform = isOpen ? '' : 'translateY(-6px) rotate(-45deg)';
    });

    function closeMobileMenu() {
      mobileMenu.classList.add('hidden');
      bars.forEach(b => { b.style.transform = ''; b.style.opacity = ''; });
    }
  </script>

  <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
