<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof booking !== 'undefined' && booking ? booking.crCode + ' · ' : '' %>Messages | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }
    button, a { cursor: pointer; }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; min-height: 40px; border-radius: 6px;
      font-size: 13.5px; color: #6b7280; font-weight: 500;
      text-decoration: none; transition: all 0.15s;
    }
    .sidebar-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.active { color: #fff; background: rgba(255,255,255,0.07); }
    .sidebar-link.danger:hover { color: #f87171; background: rgba(239,68,68,0.06); }
    .unread-badge {
      display: flex; align-items: center; justify-content: center;
      min-width: 18px; height: 18px; padding: 0 4px; border-radius: 9999px;
      background: #f59e0b; color: #000; font-size: 10px; font-weight: 700;
    }

    .messenger { display: flex; height: calc(100vh - 56px); }
    @media (min-width: 1024px) { .messenger { height: 100vh; } }

    .chat-list-col { width: 300px; flex-shrink: 0; border-right: 1px solid rgba(255,255,255,0.05); overflow-y: auto; }
    .thread-panel-col { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    @media (max-width: 1023px) {
      .messenger.thread-active .chat-list-col { display: none; }
      .messenger:not(.thread-active) .thread-panel-col { display: none; }
    }

    .thread-row {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      transition: background 0.15s;
    }
    .thread-row:hover { background: rgba(255,255,255,0.03); }
    .thread-row.active { background: rgba(245,158,11,0.06); }
    .thread-icon {
      width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
      background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2);
      display: flex; align-items: center; justify-content: center;
    }

    .day-separator { display: flex; justify-content: center; margin: 18px 0 14px; }
    .day-separator:first-child { margin-top: 0; }
    .day-separator span {
      font-size: 11px; font-weight: 600; color: #6b7280;
      background: rgba(255,255,255,0.05); padding: 4px 14px; border-radius: 9999px;
    }
    .bubble-row { display: flex; align-items: center; gap: 4px; margin-bottom: 6px; }
    .bubble-row.mine { justify-content: flex-end; }
    .bubble-col { max-width: 70%; }
    .msg-delete-btn {
      display: flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: none; border: none; color: #6b7280;
      opacity: 0; transition: opacity 0.15s, color 0.15s;
    }
    .bubble-row:hover .msg-delete-btn { opacity: 1; }
    .msg-delete-btn:hover { color: #f87171; }
    .bubble-row.deleted .bubble { font-style: italic; }
    .bubble-deleted-text { color: rgba(0,0,0,0.5); }
    .bubble-row.theirs .bubble-deleted-text { color: #6b7280; }
    .bubble {
      position: relative;
      width: fit-content;
      max-width: 100%;
      min-width: 96px;
      padding: 7px 11px;
      border-radius: 6px;
      font-size: 14.5px;
      line-height: 1.55;
      word-wrap: break-word;
    }
    .bubble-row.theirs .bubble { background: rgba(255,255,255,0.06); color: #e5e7eb; border-bottom-left-radius: 3px; }
    .bubble-row.mine .bubble { background: var(--color-orange-300); color: #000; border-bottom-right-radius: 3px; }
    .time-spacer { display: inline-block; width: 58px; height: 1px; }
    .time-spacer.with-tick { width: 78px; }
    .bubble-time {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; line-height: 1;
    }
    .bubble-time.corner { position: absolute; right: 11px; bottom: 7px; }
    .bubble-time.block { display: flex; justify-content: flex-end; margin-top: 4px; }
    .bubble-time-text { opacity: 0.65; }
    .tick { opacity: 1; color: rgba(0,0,0,0.55); }
    .tick-read { color: #1d4ed8; }

    .attachment-badge {
      display: block;
      width: fit-content;
      text-decoration: none; margin-top: 7px;
    }
    .badge-thumb {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,0.08);
      background-size: cover; background-position: center;
    }
    .badge-thumb img, .badge-thumb video { width: 100%; height: 100%; object-fit: cover; border-radius: inherit; }
    .attachment-badge .badge-thumb img, .attachment-badge .badge-thumb video { object-fit: contain; background: rgba(0,0,0,0.4); }
    .badge-thumb-lg { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.1); }
    .badge-thumb-preview { width: 320px; height: 320px; border-radius: 10px; }
    .badge-thumb-audio { background: rgba(255,255,255,0.3); border-color: rgba(255,255,255,0.22); }
    @keyframes thumb-spin { to { transform: rotate(360deg); } }
    .thumb-loading-overlay {
      position: absolute; inset: 0; z-index: 2; border-radius: inherit;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px;
      background: rgba(0,0,0,0.32);
    }
    .thumb-loading-overlay > svg { width: 40%; height: 40%; max-width: 28px; max-height: 28px; animation: thumb-spin 0.8s linear infinite; filter: drop-shadow(0 1px 3px rgba(0,0,0,0.6)); }
    .thumb-progress-text {
      font-size: 11px; font-weight: 700; line-height: 1; color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.85);
    }
    .thumb-btn-badge {
      position: relative; flex-shrink: 0;
      width: 70%; height: 70%; max-width: 52px; max-height: 52px; min-width: 18px; min-height: 18px;
      border-radius: 50%;
      background: rgba(0,0,0,0.82);
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .thumb-btn-badge svg.thumb-progress-ring { width: 85%; height: 85%; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5)); }
    .thumb-btn-badge iconify-icon { color: #fff; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.7)); }
    .thumb-progress-ring-fill { transition: stroke-dashoffset 0.15s linear; }
    .thumb-cancel-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.7)); }
    .thumb-cancel-btn { appearance: none; border: none; padding: 0; margin: 0; font: inherit; }
    .thumb-cancel-btn:hover .thumb-progress-ring-fill { stroke: #f87171; }
    .thumb-cancel-btn:hover .thumb-btn-badge, .thumb-retry-btn:hover .thumb-btn-badge, .thumb-download-btn:hover .thumb-btn-badge { background: rgba(0,0,0,0.95); }
    .badge-thumb.media-loaded .thumb-loading-overlay, .tagged-inline-thumb.media-loaded .thumb-loading-overlay { display: none; }
    .bubble-row.pending .bubble-time-text { opacity: 1; }
    .bubble-row.pending.cancelled .bubble-time-text { color: #f87171; opacity: 1; }
    .bubble-row.pending.cancelled .bubble { cursor: pointer; }
    .bubble-row.pending.cancelled.retry-cooldown .thumb-retry-btn { pointer-events: none; }
    .bubble-row.pending.cancelled.retry-cooldown .bubble { cursor: default; }
    .retry-cooldown > .thumb-download-btn { pointer-events: none; }
    .thumb-retry-btn { appearance: none; border: none; padding: 0; margin: 0; font: inherit; }
    .thumb-download-btn {
      appearance: none; border: none; padding: 0; margin: 0; font: inherit;
      width: 100%; height: 100%; border-radius: inherit;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,0.32);
    }
    .lazy-attachment { cursor: pointer; }
    .badge-tag-mark {
      position: absolute; bottom: -3px; right: -3px;
      width: 15px; height: 15px; border-radius: 50%;
      background: #0d0d0d;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 0 1.5px rgba(255,255,255,0.15);
    }
    .media-pick-selected { background: rgba(245,158,11,0.12); }
    .media-pick-selected .badge-thumb { box-shadow: 0 0 0 2px #f59e0b; }

    .tagged-inline-badge {
      display: flex; align-items: center; gap: 5px; width: fit-content;
      padding: 2px 10px 2px 2px; border-radius: 6px;
      background: rgba(0,0,0,0.15);
      text-decoration: none; margin-bottom: 5px;
      font-size: 13px; max-width: 100%;
    }
    .bubble-row.theirs .tagged-inline-badge { background: rgba(0,0,0,0.25); color: #e5e7eb; }
    .bubble-row.mine .tagged-inline-badge { background: rgba(0,0,0,0.12); color: #000; }
    .tagged-inline-thumb {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,0.15); overflow: hidden;
      background-size: cover; background-position: center;
    }
    .tagged-inline-thumb img, .tagged-inline-thumb video { width: 100%; height: 100%; object-fit: cover; }

    .viewer-container {
      background: #111; border: 1px solid rgba(255,255,255,0.09); border-radius: 12px;
      width: 100%; max-width: 1100px; height: 100%; max-height: 720px;
      display: flex; flex-direction: column; overflow: hidden;
    }
    .viewer-header { display: flex; align-items: center; gap: 10px; padding: 13px 18px; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
    .viewer-filename { font-size: 14px; font-weight: 600; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .viewer-close-btn { margin-left: auto; background: none; border: none; cursor: pointer; color: #6b7280; display: flex; align-items: center; padding: 4px; border-radius: 6px; transition: color 0.15s; }
    .viewer-close-btn:hover { color: #fff; }
    .viewer-body { display: flex; flex: 1; overflow: hidden; }
    .viewer-player-wrap { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .viewer-player { flex: 1; background: #000; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .viewer-player video { max-width: 100%; max-height: 100%; display: block; }
    .viewer-player img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }
    .viewer-info-bar { flex-shrink: 0; display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-top: 1px solid rgba(255,255,255,0.06); }
    .viewer-file-panel { width: 220px; flex-shrink: 0; border-left: 1px solid rgba(255,255,255,0.07); display: flex; flex-direction: column; overflow: hidden; }
    .viewer-file-panel-header { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 11px; color: #6b7280; font-weight: 500; }
    .viewer-file-grid { flex: 1; overflow-y: auto; padding: 10px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; align-content: start; }
    .viewer-thumb { aspect-ratio: 1 / 1; border-radius: 6px; overflow: hidden; cursor: pointer; border: 2px solid transparent; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; transition: border-color 0.15s; }
    .viewer-thumb:hover { border-color: rgba(255,255,255,0.2); }
    .viewer-thumb.selected { border-color: #f59e0b; }
    .viewer-thumb img, .viewer-thumb video { width: 100%; height: 100%; object-fit: cover; display: block; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[#0d0d0d] border-b border-white/5 flex items-center justify-between px-4">
    <span class="brand text-[15px] font-bold text-white">Jarumiri<span class="text-amber-400">.</span></span>
    <button onclick="toggleSidebar()" class="text-gray-500 hover:text-white transition-colors p-1.5">
      <iconify-icon icon="material-symbols-light:menu" width="22" height="22"></iconify-icon>
    </button>
  </header>

  <div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-30 hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-screen w-55 bg-[#0d0d0d] border-r border-white/5 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="h-16.25 flex items-center px-5 border-b border-white/5 shrink-0">
      <span class="brand text-[15px] font-bold text-white">Jarumiri Studios<span class="text-amber-400">.</span></span>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/dashboard" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:grid-view" width="20" height="20"></iconify-icon>
        Overview
      </a>
      <a href="/dashboard/gallery" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:photo-library" width="20" height="20"></iconify-icon>
        Gallery
      </a>
      <a href="/dashboard/messages" class="sidebar-link active">
        <iconify-icon icon="material-symbols-light:chat" width="20" height="20"></iconify-icon>
        <span class="flex-1">Messages</span>
        <% if (locals.unreadMessageCount > 0) { %>
        <span class="unread-badge"><%= unreadMessageCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/notifications" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:notifications" width="20" height="20"></iconify-icon>
        <span class="flex-1">Notifications</span>
        <% if (locals.unreadCount > 0) { %>
        <span class="unread-badge"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/invoices" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:receipt-long-outline" width="20" height="20"></iconify-icon>
        Invoices
      </a>
      <a href="/dashboard/account" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:person" width="20" height="20"></iconify-icon>
        Account
      </a>
    </nav>

    <div class="px-3 pb-4 border-t border-white/5 shrink-0 space-y-1">
      <a href="/dashboard/new"
        class="flex items-center gap-2.5 w-full px-3 min-h-10 rounded-md bg-amber-400 text-black text-[13.5px] font-bold hover:bg-amber-300 transition-colors">
        <iconify-icon icon="material-symbols-light:add" width="20" height="20"></iconify-icon>
        New project
      </a>
      <a href="https://t.me/jarumiri" target="_blank" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:forum" width="20" height="20"></iconify-icon>
        Support
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="lg:ml-55">
    <div class="lg:hidden h-14"></div>

    <div id="messenger" class="messenger <%= typeof booking !== 'undefined' && booking ? 'thread-active' : '' %>">
      <!-- Chat list column -->
      <div class="chat-list-col">
        <% if (!threads || threads.length === 0) { %>
        <div class="text-center py-16 px-4">
          <div class="w-11 h-11 rounded-md bg-white/3 border border-white/8 flex items-center justify-center mx-auto mb-4">
            <iconify-icon icon="material-symbols-light:chat" width="22" height="22" class="text-gray-700"></iconify-icon>
          </div>
          <p class="text-gray-600 text-sm">No projects yet.</p>
          <a href="/dashboard/new" class="text-amber-400 text-sm hover:text-amber-300 transition-colors font-medium mt-1 inline-block">Start a project →</a>
        </div>
        <% } else { %>
        <% threads.forEach(t => {
          const isActive = typeof booking !== 'undefined' && booking && String(booking._id) === String(t.booking._id);
        %>
        <a href="/dashboard/messages/<%= t.booking._id %>" class="thread-row <%= isActive ? 'active' : '' %>" data-booking-id="<%= t.booking._id %>">
          <div class="thread-icon">
            <iconify-icon icon="material-symbols-light:chat" width="15" height="15" style="color:#f59e0b"></iconify-icon>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-mono text-amber-400 text-xs font-semibold"><%= t.booking.crCode %></span>
            </div>
            <p class="text-sm text-gray-300 mt-0.5 truncate">
              <% if (t.lastMessage) {
                const atts = (t.lastMessage.attachments && t.lastMessage.attachments.length) ? t.lastMessage.attachments : (t.lastMessage.attachment && t.lastMessage.attachment.storedName ? [t.lastMessage.attachment] : []);
                const attsLabel = atts.length ? '📎 ' + (atts.length === 1 ? atts[0].originalName : atts.length + ' files') : '';
              %>
                <%= t.lastMessage.senderRole === 'admin' ? 'Studio: ' : 'You: ' %><%= t.lastMessage.deleted ? 'This message was deleted' : (t.lastMessage.body || attsLabel) %>
              <% } else { %>
                <span class="<%= t.booking.chatUnlocked ? 'text-gray-700' : 'text-gray-500' %>"><%= t.booking.chatUnlocked ? 'Say hello.' : 'Chat opens once accepted.' %></span>
              <% } %>
            </p>
          </div>
          <% if (t.unreadCount > 0) { %>
          <span class="unread-badge"><%= t.unreadCount %></span>
          <% } %>
        </a>
        <% }) %>
        <% } %>
      </div>

      <!-- Thread panel -->
      <div id="thread-panel" class="thread-panel-col">
        <% if (typeof booking !== 'undefined' && booking) { %>
        <%- include('_message-thread-panel', { booking, messages, myRole: 'client', attachmentBasePath: '/dashboard/messages/attachments', postPath: '/dashboard/messages/' + booking._id }) %>
        <% } else { %>
        <div class="flex-1 flex items-center justify-center text-center px-6">
          <div>
            <div class="w-11 h-11 rounded-md bg-white/3 border border-white/8 flex items-center justify-center mx-auto mb-4">
              <iconify-icon icon="material-symbols-light:chat" width="22" height="22" class="text-gray-700"></iconify-icon>
            </div>
            <p class="text-gray-600 text-sm">Select a conversation.</p>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }
  </script>
  <%- include('_message-thread-script', { booking: typeof booking !== 'undefined' ? booking : null }) %>
  <%- include('_toast') %>
  <%- include('_confirm-modal') %>
  <%- include('_notif-poll') %>
</body>
</html>
