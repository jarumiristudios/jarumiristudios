<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= typeof booking !== 'undefined' && booking ? booking.crCode + ' · ' : '' %>Messages | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }
    button, a { cursor: pointer; }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; min-height: 40px; border-radius: 6px;
      font-size: 13.5px; color: #6b7280; font-weight: 500;
      text-decoration: none; transition: all 0.15s;
    }
    .sidebar-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.active { color: #fff; background: rgba(255,255,255,0.07); }
    .sidebar-link.danger:hover { color: #f87171; background: rgba(239,68,68,0.06); }
    .unread-badge {
      display: flex; align-items: center; justify-content: center;
      min-width: 18px; height: 18px; padding: 0 4px; border-radius: 9999px;
      background: #f59e0b; color: #000; font-size: 10px; font-weight: 700;
    }

    .messenger { display: flex; height: calc(100vh - 56px); height: calc(100dvh - 56px); }
    @media (min-width: 1024px) { .messenger { height: 100vh; height: 100dvh; } }

    .chat-list-col { width: 360px; flex-shrink: 0; min-height: 0; border-right: 1px solid rgba(255,255,255,0.05); overflow-y: auto; }
    .thread-panel-col { flex: 1; min-width: 0; min-height: 0; display: flex; flex-direction: column; }
    @media (max-width: 1023px) {
      .chat-list-col { width: 100%; }
      .messenger.thread-active .chat-list-col { display: none; }
      .messenger:not(.thread-active) .thread-panel-col { display: none; }
    }

    .thread-row {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      transition: background 0.15s;
    }
    .thread-row:hover { background: rgba(255,255,255,0.03); }
    .thread-row.active { background: rgba(245,158,11,0.06); }
    .thread-icon {
      width: 48px; height: 48px; border-radius: 50%; flex-shrink: 0;
      background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .thread-icon img, .thread-icon video { width: 100%; height: 100%; object-fit: cover; }

    .day-separator { display: flex; justify-content: center; margin: 18px 0 14px; }
    .day-separator:first-child { margin-top: 0; }
    .day-separator span {
      font-size: 11px; font-weight: 600; color: #6b7280;
      background: rgba(255,255,255,0.05); padding: 4px 14px; border-radius: 9999px;
    }
    .bubble-row { display: flex; align-items: center; gap: 4px; margin-bottom: 6px; position: relative; }
    .bubble-row.mine { justify-content: flex-end; }
    .bubble-row::before {
      content: ''; position: absolute; left: 0; right: 0; top: -4px; bottom: -4px;
      background: rgba(245,158,11,0.18); z-index: -1; pointer-events: none;
      opacity: 0; transition: opacity 0.7s ease;
    }
    .bubble-row.flash-highlight::before { opacity: 1; }
    .bubble-row.theirs + .bubble-row.mine,
    .bubble-row.mine + .bubble-row.theirs { margin-top: 12px; }
    .bubble-col { max-width: 70%; }
    .msg-select-radio {
      display: none; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: rgba(255,255,255,0.08); border: none; color: #d1d5db;
      transition: color 0.15s;
    }
    #message-list.selecting .msg-select-radio { display: flex; }
    #message-list.selecting .bubble-row { -webkit-user-select: none; user-select: none; }
    .bubble-row.selected .msg-select-radio { color: #f59e0b; background: rgba(245,158,11,0.15); }
    .bubble-actions { display: none; align-items: center; gap: 2px; flex-shrink: 0; }
    .bubble-row.selected .bubble-actions { display: flex; }
    .bubble-row.selected .bubble { outline: 2px solid rgba(245,158,11,0.4); outline-offset: 2px; }
    .bubble-action-btn {
      display: flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: rgba(255,255,255,0.08); border: none; color: #e5e7eb;
      transition: color 0.15s, background 0.15s;
    }
    .bubble-action-btn:hover { color: #fff; background: rgba(255,255,255,0.16); }
    #message-list.multi-selecting .reply-action-btn,
    #message-list.multi-selecting .edit-action-btn { display: none; }
    .edited-label { font-size: 10.5px; font-style: italic; opacity: 0.55; margin-right: 3px; }
    .bubble-row.deleted .bubble { font-style: italic; }
    .bubble-deleted-text { color: rgba(0,0,0,0.5); }
    .bubble-row.theirs .bubble-deleted-text { color: #6b7280; }
    .reply-quote {
      display: flex; flex-direction: column; gap: 1px;
      padding: 5px 9px; border-radius: 5px; margin-bottom: 5px;
      border-left: 2.5px solid #f59e0b;
      background: rgba(0,0,0,0.15); cursor: pointer;
    }
    .bubble-row.theirs .reply-quote { background: rgba(0,0,0,0.25); }
    .bubble-row.mine .reply-quote { background: rgba(0,0,0,0.12); border-left-color: rgba(0,0,0,0.4); }
    .reply-quote-sender { display: block; font-size: 11.5px; font-weight: 700; color: #f59e0b; }
    .bubble-row.mine .reply-quote-sender { color: rgba(0,0,0,0.65); }
    .reply-quote-text {
      display: block; font-size: 12.5px; opacity: 0.75;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260px;
    }
    .bubble {
      position: relative;
      z-index: 1;
      width: fit-content;
      max-width: 100%;
      min-width: 96px;
      padding: 7px 11px;
      border-radius: 6px;
      font-size: 14.5px;
      line-height: 1.55;
      word-wrap: break-word;
    }
    .bubble-row.theirs .bubble { background: rgba(255,255,255,0.06); color: #e5e7eb; border-bottom-left-radius: 3px; }
    .bubble-row.mine .bubble { background: var(--color-orange-300); color: #000; border-bottom-right-radius: 3px; }
    /* The theirs bubble's own background is only 6% opaque, so the highlight ribbon behind it
       (see .bubble-row::before above) would otherwise bleed straight through — give it an opaque
       backing under the same tint just while highlighted, so the ribbon is actually hidden behind it. */
    .bubble-row.theirs.flash-highlight .bubble { background: linear-gradient(rgba(255,255,255,0.06), rgba(255,255,255,0.06)), #0d0d0d; }
    .time-spacer { display: inline-block; width: 58px; height: 1px; }
    .time-spacer.with-tick { width: 78px; }
    .bubble-time {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; line-height: 1;
    }
    .bubble-time.corner { position: absolute; right: 11px; bottom: 7px; }
    .bubble-time.block { display: flex; justify-content: flex-end; margin-top: 4px; }
    .bubble-time-text { opacity: 0.65; }
    .tick { opacity: 1; color: rgba(0,0,0,0.55); }
    .tick-read { color: #1d4ed8; }

    .attachment-badge {
      display: block;
      width: fit-content;
      text-decoration: none; margin-top: 7px;
    }
    .badge-thumb {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      width: 34px; height: 34px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,0.08);
      background-size: cover; background-position: center;
    }
    .badge-thumb img, .badge-thumb video { width: 100%; height: 100%; object-fit: cover; border-radius: inherit; }
    .attachment-badge .badge-thumb img, .attachment-badge .badge-thumb video { object-fit: contain; background: rgba(0,0,0,0.4); }
    .badge-thumb-lg { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.1); }
    .badge-thumb-preview { width: 320px; height: 320px; border-radius: 10px; }
    /* A caption below an attached image is a plain inline span, so it was contributing its own
       full (unwrapped) text width to the bubble's fit-content sizing — if the caption is wider
       than the now-correctly-shrunk image, the bubble grows to match the caption, stranding the
       image with a gap. Taking the caption out of that width calculation lets the image drive the
       bubble's width and the caption wrap to match. Scoped to .attachment-badge only — tagged
       files render as a small inline icon+filename chip (.tagged-inline-badge), not a large
       preview, and shouldn't constrain the bubble's width at all. */
    .bubble:has(.attachment-badge) .bubble-body-text {
      display: block; contain: inline-size; width: 100%;
    }
    .badge-thumb-audio { background: rgba(255,255,255,0.3); border-color: rgba(255,255,255,0.22); }
    @keyframes thumb-spin { to { transform: rotate(360deg); } }
    .thumb-loading-overlay {
      position: absolute; inset: 0; z-index: 2; border-radius: inherit;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px;
      background: rgba(0,0,0,0.32);
    }
    .thumb-error-overlay {
      position: absolute; inset: 0; z-index: 2; border-radius: inherit;
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
      background: rgba(255,255,255,0.03); padding: 10px; text-align: center;
    }
    .thumb-error-overlay iconify-icon { color: rgba(255,255,255,0.35); }
    .thumb-error-text { font-size: 11px; font-weight: 500; line-height: 1.35; color: rgba(255,255,255,0.4); }
    .attachment-unavailable { cursor: default; }
    .thumb-progress-text {
      font-size: 11px; font-weight: 700; line-height: 1; color: #fff;
      text-shadow: 0 1px 3px rgba(0,0,0,0.85);
    }
    .thumb-btn-badge {
      position: relative; flex-shrink: 0;
      width: 70%; height: 70%; max-width: 52px; max-height: 52px; min-width: 18px; min-height: 18px;
      border-radius: 50%;
      background: rgba(0,0,0,0.82);
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .thumb-btn-badge svg.thumb-progress-ring { width: 85%; height: 85%; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5)); }
    .thumb-btn-badge svg.thumb-spin-ring { width: 85%; height: 85%; animation: thumb-spin 0.8s linear infinite; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5)); }
    .thumb-btn-badge iconify-icon { color: #fff; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.7)); }
    .thumb-progress-ring-fill { transition: stroke-dashoffset 0.15s linear; }
    .thumb-cancel-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.7)); }
    .thumb-cancel-btn { appearance: none; border: none; padding: 0; margin: 0; font: inherit; }
    .thumb-cancel-btn:hover .thumb-progress-ring-fill { stroke: #f87171; }
    .thumb-cancel-btn:hover .thumb-btn-badge, .thumb-retry-btn:hover .thumb-btn-badge, .thumb-download-btn:hover .thumb-btn-badge { background: rgba(0,0,0,0.95); }
    .badge-thumb.media-loaded .thumb-loading-overlay, .tagged-inline-thumb.media-loaded .thumb-loading-overlay { display: none; }
    .bubble-row.pending .bubble-time-text { opacity: 1; }
    .bubble-row.pending.cancelled .bubble-time-text { color: #f87171; opacity: 1; }
    .bubble-row.pending.cancelled .bubble { cursor: pointer; }
    .bubble-row.pending.cancelled.retry-cooldown .thumb-retry-btn { pointer-events: none; }
    .bubble-row.pending.cancelled.retry-cooldown .bubble { cursor: default; }
    .retry-cooldown > .thumb-download-btn { pointer-events: none; }
    .thumb-retry-btn { appearance: none; border: none; padding: 0; margin: 0; font: inherit; }
    .thumb-download-btn {
      appearance: none; border: none; padding: 0; margin: 0; font: inherit;
      width: 100%; height: 100%; border-radius: inherit;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,0.32);
    }
    .lazy-attachment { cursor: pointer; }
    .badge-tag-mark {
      position: absolute; bottom: -3px; right: -3px;
      width: 15px; height: 15px; border-radius: 50%;
      background: #0d0d0d;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 0 0 1.5px rgba(255,255,255,0.15);
    }
    .media-pick-selected { background: rgba(245,158,11,0.12); }
    .media-pick-selected .badge-thumb { box-shadow: 0 0 0 2px #f59e0b; }

    .tagged-inline-badge {
      display: flex; align-items: center; gap: 5px; width: fit-content;
      padding: 2px 10px 2px 2px; border-radius: 6px;
      background: rgba(0,0,0,0.15);
      text-decoration: none; margin-bottom: 5px;
      font-size: 13px; max-width: 100%;
    }
    .bubble-row.theirs .tagged-inline-badge { background: rgba(0,0,0,0.25); color: #e5e7eb; }
    .bubble-row.mine .tagged-inline-badge { background: rgba(0,0,0,0.12); color: #000; }
    .tagged-inline-thumb {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,0.15); overflow: hidden;
      background-size: cover; background-position: center;
    }
    .tagged-inline-thumb img, .tagged-inline-thumb video { width: 100%; height: 100%; object-fit: cover; }

    .viewer-container {
      background: #111; border: 1px solid rgba(255,255,255,0.09); border-radius: 12px;
      width: 100%; max-width: 1100px; height: 100%; max-height: 720px;
      display: flex; flex-direction: column; overflow: hidden;
    }
    .viewer-header { display: flex; align-items: center; gap: 10px; padding: 13px 18px; border-bottom: 1px solid rgba(255,255,255,0.07); flex-shrink: 0; }
    .viewer-filename { font-size: 14px; font-weight: 600; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .viewer-close-btn { margin-left: auto; background: none; border: none; cursor: pointer; color: #6b7280; display: flex; align-items: center; padding: 4px; border-radius: 6px; transition: color 0.15s; }
    .viewer-close-btn:hover { color: #fff; }
    .viewer-body { display: flex; flex: 1; overflow: hidden; }
    .viewer-player-wrap { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .viewer-player { flex: 1; background: #000; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .viewer-player video { max-width: 100%; max-height: 100%; display: block; }
    .viewer-player img {
      max-width: 100%; max-height: 100%; object-fit: contain; display: block;
      cursor: zoom-in; transition: transform 0.12s ease-out;
      -webkit-user-drag: none; user-select: none;
    }
    .viewer-player.zoomed img { cursor: grab; }
    .viewer-player.dragging img { cursor: grabbing; transition: none; }
    .viewer-info-bar { flex-shrink: 0; display: flex; align-items: center; gap: 12px; padding: 10px 16px; border-top: 1px solid rgba(255,255,255,0.06); }
    .viewer-file-panel { width: 220px; flex-shrink: 0; border-left: 1px solid rgba(255,255,255,0.07); display: flex; flex-direction: column; overflow: hidden; }
    .viewer-file-panel-header { padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 11px; color: #6b7280; font-weight: 500; }
    .viewer-file-grid { flex: 1; overflow-y: auto; padding: 10px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; align-content: start; }
    .viewer-thumb { aspect-ratio: 1 / 1; border-radius: 6px; overflow: hidden; cursor: pointer; border: 2px solid transparent; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; transition: border-color 0.15s; }
    .viewer-thumb:hover { border-color: rgba(255,255,255,0.2); }
    .viewer-thumb.selected { border-color: #f59e0b; }
    .viewer-thumb img, .viewer-thumb video { width: 100%; height: 100%; object-fit: cover; display: block; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[#0d0d0d] border-b border-white/5 flex items-center gap-2 px-4">
    <button onclick="toggleSidebar()" class="h-12 w-12 flex items-center justify-center text-white transition-colors cursor-pointer">
      <iconify-icon icon="material-symbols-light:menu" width="22" height="22"></iconify-icon>
    </button>
    <span class="brand text-[15px] font-bold text-white leading-none">Jarumiri Studios<span class="text-amber-400">.</span></span>
  </header>

  <div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-30 hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-screen w-55 bg-[#0d0d0d] border-r border-white/5 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="h-16.25 flex items-center px-5 border-b border-white/5 shrink-0">
      <span class="brand text-[15px] font-bold text-white">Jarumiri Studios<span class="text-amber-400">.</span></span>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/dashboard" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:grid-view" width="20" height="20"></iconify-icon>
        Overview
      </a>
      <a href="/dashboard/gallery" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:photo-library" width="20" height="20"></iconify-icon>
        Gallery
      </a>
      <a href="/dashboard/messages" class="sidebar-link active">
        <iconify-icon icon="material-symbols-light:chat" width="20" height="20"></iconify-icon>
        <span class="flex-1">Messages</span>
        <% if (locals.unreadMessageCount > 0) { %>
        <span class="unread-badge"><%= unreadMessageCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/notifications" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:notifications" width="20" height="20"></iconify-icon>
        <span class="flex-1">Notifications</span>
        <% if (locals.unreadCount > 0) { %>
        <span class="unread-badge"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/invoices" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:receipt-long-outline" width="20" height="20"></iconify-icon>
        Invoices
      </a>
      <a href="/dashboard/account" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:person" width="20" height="20"></iconify-icon>
        Account
      </a>
    </nav>

    <div class="px-3 pb-4 border-t border-white/5 shrink-0 space-y-1">
      <a href="/dashboard/new"
        class="flex items-center gap-2.5 w-full px-3 min-h-10 rounded-md bg-amber-400 text-black text-[13.5px] font-bold hover:bg-amber-300 transition-colors">
        <iconify-icon icon="material-symbols-light:add" width="20" height="20"></iconify-icon>
        New project
      </a>
      <a href="https://t.me/jarumiri" target="_blank" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:forum" width="20" height="20"></iconify-icon>
        Support
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="lg:ml-55">
    <div class="lg:hidden h-14"></div>

    <div id="messenger" class="messenger <%= typeof booking !== 'undefined' && booking ? 'thread-active' : '' %>">
      <!-- Chat list column -->
      <div class="chat-list-col">
        <!-- Search + filter -->
        <div class="flex items-center gap-2 p-3 border-b border-white/5">
          <div class="relative flex-1 min-w-0">
            <iconify-icon icon="material-symbols-light:search" width="18" height="18" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none"></iconify-icon>
            <input type="text" id="thread-search" placeholder="Search conversations…"
              class="w-full h-9 pl-9 pr-3 rounded-md bg-white/5 border border-white/10 text-sm text-white placeholder-gray-500 outline-none focus:border-amber-400/40 transition-colors" />
          </div>
          <div class="relative shrink-0">
            <button type="button" id="thread-filter-btn" class="h-9 w-9 flex items-center justify-center rounded-md bg-white/5 border border-white/10 text-gray-400 hover:text-white transition-colors cursor-pointer">
              <iconify-icon icon="material-symbols-light:filter-list" width="18" height="18"></iconify-icon>
            </button>
            <div id="thread-filter-menu" class="hidden absolute right-0 top-full mt-1 w-48 rounded-md bg-[#131313] border border-white/10 shadow-xl z-20 py-1">
              <div class="px-3 pt-2 pb-1 text-[10px] font-semibold uppercase tracking-wide text-gray-600">Status</div>
              <button type="button" class="thread-filter-opt active w-full text-left px-3 py-1.5 text-sm text-gray-300 hover:bg-white/5 cursor-pointer" data-filter-type="read" data-filter-value="all">All</button>
              <button type="button" class="thread-filter-opt w-full text-left px-3 py-1.5 text-sm text-gray-300 hover:bg-white/5 cursor-pointer" data-filter-type="read" data-filter-value="unread">Unread only</button>
              <div class="border-t border-white/5 my-1"></div>
              <div class="px-3 pt-1 pb-1 text-[10px] font-semibold uppercase tracking-wide text-gray-600">Project</div>
              <button type="button" class="thread-filter-opt active w-full text-left px-3 py-1.5 text-sm text-gray-300 hover:bg-white/5 cursor-pointer" data-filter-type="status" data-filter-value="all">All</button>
              <button type="button" class="thread-filter-opt w-full text-left px-3 py-1.5 text-sm text-gray-300 hover:bg-white/5 cursor-pointer" data-filter-type="status" data-filter-value="active">Active</button>
              <button type="button" class="thread-filter-opt w-full text-left px-3 py-1.5 text-sm text-gray-300 hover:bg-white/5 cursor-pointer" data-filter-type="status" data-filter-value="completed">Completed</button>
            </div>
          </div>
        </div>

        <div id="thread-list-empty" class="text-center py-16 px-4 <%= (threads && threads.length) ? 'hidden' : '' %>">
          <div class="w-11 h-11 rounded-md bg-white/3 border border-white/8 flex items-center justify-center mx-auto mb-4">
            <iconify-icon icon="material-symbols-light:chat" width="22" height="22" class="text-gray-700"></iconify-icon>
          </div>
          <p class="text-gray-600 text-sm">No conversations yet.</p>
          <a href="/dashboard" class="text-amber-400 text-sm hover:text-amber-300 transition-colors font-medium mt-1 inline-block">Open a project to start one →</a>
        </div>
        <div id="thread-list-no-match" class="hidden text-center py-16 px-4">
          <p class="text-gray-600 text-sm">No conversations match your search.</p>
        </div>
        <% (threads || []).forEach(t => {
          const isActive = typeof booking !== 'undefined' && booking && String(booking._id) === String(t.booking._id);
          const statusBucket = t.booking.status === 'completed' ? 'completed' : 'active';
          const lastAtts = (t.lastMessage.attachments && t.lastMessage.attachments.length) ? t.lastMessage.attachments : (t.lastMessage.attachment && t.lastMessage.attachment.storedName ? [t.lastMessage.attachment] : []);
          // Always the project's own thumbnail — never a chat attachment, even the most recent one.
          const projectThumbFile = (t.booking.uploadedFiles || []).find(f => f.mimetype && /^(video|image)\//i.test(f.mimetype));
          const thumbSrc = projectThumbFile ? '/dashboard/uploads/' + projectThumbFile.storedName : null;
          const thumbIsVideo = /^video\//i.test((projectThumbFile || {}).mimetype || '');
        %>
        <a href="/dashboard/messages/<%= t.booking._id %>" class="thread-row <%= isActive ? 'active' : '' %>" data-booking-id="<%= t.booking._id %>" data-status="<%= statusBucket %>" data-unread="<%= t.unreadCount %>">
          <div class="thread-icon">
            <% if (thumbSrc && thumbIsVideo) { %>
            <video src="<%= thumbSrc %>" muted preload="metadata" class="thread-thumb-video" onerror="handleThreadThumbError(this)"></video>
            <% } else if (thumbSrc) { %>
            <img src="<%= thumbSrc %>" alt="" onerror="handleThreadThumbError(this)" />
            <% } else { %>
            <iconify-icon icon="material-symbols-light:chat" width="15" height="15" style="color:#f59e0b"></iconify-icon>
            <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-mono text-amber-400 text-xs font-semibold"><%= t.booking.crCode %></span>
            </div>
            <p class="text-sm text-gray-300 mt-0.5 truncate">
              <%
                const atts = lastAtts;
                const attTypeLabel = (m) => /^video\//i.test(m) ? 'Video' : /^audio\//i.test(m) ? 'Audio' : /^image\//i.test(m) ? 'Image' : 'File';
                const attsLabel = atts.length ? '📎 ' + (atts.length === 1 ? attTypeLabel(atts[0].mimetype) : atts.length + ' files') : '';
              %>
              <%= t.lastMessage.senderRole === 'admin' ? 'Studio: ' : 'You: ' %><%= t.lastMessage.deleted ? 'This message was deleted' : (t.lastMessage.body || attsLabel) %>
            </p>
          </div>
          <% if (t.unreadCount > 0) { %>
          <span class="unread-badge"><%= t.unreadCount %></span>
          <% } %>
        </a>
        <% }) %>
      </div>

      <!-- Thread panel -->
      <div id="thread-panel" class="thread-panel-col">
        <% if (typeof booking !== 'undefined' && booking) { %>
        <%- include('_message-thread-panel', { booking, messages, myRole: 'client', attachmentBasePath: '/dashboard/messages/attachments', postPath: '/dashboard/messages/' + booking._id }) %>
        <% } else { %>
        <div class="flex-1 flex items-center justify-center text-center px-6">
          <div>
            <div class="w-11 h-11 rounded-md bg-white/3 border border-white/8 flex items-center justify-center mx-auto mb-4">
              <iconify-icon icon="material-symbols-light:chat" width="22" height="22" class="text-gray-700"></iconify-icon>
            </div>
            <p class="text-gray-600 text-sm">Select a conversation.</p>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }

    document.querySelectorAll('video.thread-thumb-video').forEach(v => {
      const seek = () => { if (v.currentTime === 0) v.currentTime = 0.1; };
      if (v.readyState >= 2) seek();
      else v.addEventListener('loadeddata', seek, { once: true });
    });

    function handleThreadThumbError(el) {
      el.outerHTML = '<iconify-icon icon="material-symbols-light:chat" width="15" height="15" style="color:#f59e0b"></iconify-icon>';
    }

    (function () {
      const searchInput = document.getElementById('thread-search');
      const filterBtn = document.getElementById('thread-filter-btn');
      const filterMenu = document.getElementById('thread-filter-menu');
      const noMatchEl = document.getElementById('thread-list-no-match');
      const filters = { read: 'all', status: 'all' };

      // Re-queried on every call (not cached) so rows created later — e.g. a booking's first-ever
      // message inserting a fresh row live, see _message-thread-script.ejs — get filtered too.
      function applyFilters() {
        const rows = Array.from(document.querySelectorAll('.thread-row'));
        const q = (searchInput?.value || '').trim().toLowerCase();
        let visibleCount = 0;
        rows.forEach((row) => {
          const matchesSearch = !q || row.textContent.toLowerCase().includes(q);
          const matchesRead = filters.read === 'all' || (filters.read === 'unread' && Number(row.dataset.unread || 0) > 0);
          const matchesStatus = filters.status === 'all' || row.dataset.status === filters.status;
          const visible = matchesSearch && matchesRead && matchesStatus;
          row.classList.toggle('hidden', !visible);
          if (visible) visibleCount++;
        });
        if (noMatchEl) noMatchEl.classList.toggle('hidden', visibleCount > 0 || rows.length === 0);
      }
      window.applyThreadFilters = applyFilters;

      searchInput?.addEventListener('input', applyFilters);

      filterBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        filterMenu?.classList.toggle('hidden');
      });
      document.addEventListener('click', (e) => {
        if (filterMenu && !filterMenu.classList.contains('hidden') && !filterMenu.contains(e.target) && e.target !== filterBtn) {
          filterMenu.classList.add('hidden');
        }
      });

      document.querySelectorAll('.thread-filter-opt').forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = btn.dataset.filterType;
          filters[type] = btn.dataset.filterValue;
          document.querySelectorAll(`.thread-filter-opt[data-filter-type="${type}"]`).forEach((b) => {
            b.classList.toggle('active', b === btn);
            b.classList.toggle('text-amber-400', b === btn);
            b.classList.toggle('text-gray-300', b !== btn);
          });
          applyFilters();
        });
      });
    })();
  </script>
  <%- include('_message-thread-script', { booking: typeof booking !== 'undefined' ? booking : null }) %>
  <%- include('_toast') %>
  <%- include('_confirm-modal') %>
  <%- include('_notif-poll') %>
</body>
</html>
