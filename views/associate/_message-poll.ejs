<script>
(function () {
  var lastSeen = Date.now();
  var isMessagesPage = /^\/associate\/messages(\/|$)/.test(window.location.pathname);

  function updateMessagesBadge(count) {
    var link = document.querySelector('a[href="/associate/messages"]');
    if (!link) return;
    var badge = link.querySelector('span:not(.flex-1)');
    if (count > 0) {
      if (!badge) {
        badge = document.createElement('span');
        badge.style.cssText = 'display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;';
        link.appendChild(badge);
      }
      badge.textContent = count;
    } else if (badge) {
      badge.remove();
    }
  }

  function handleNewMessages(messageItems) {
    if (!messageItems.length) return;

    var activeBookingMatch = location.pathname.match(/\/messages\/([a-f0-9]+)$/);
    var activeBookingId = activeBookingMatch ? activeBookingMatch[1] : null;

    var elsewhere = messageItems.filter(function (m) { return String(m.bookingId) !== activeBookingId; });

    if (typeof showToast === 'function') {
      elsewhere.forEach(function (m) {
        if (m.unclaimed) {
          showToast('New message (unclaimed)', 'On ' + m.crCode + ': "' + m.preview + '" — claim it to reply.', 'info');
        } else {
          showToast('New message', 'On ' + m.crCode + ': "' + m.preview + '"', 'info');
        }
      });
    }

    // Unclaimed threads don't have a thread panel on this page yet, so only reload
    // for messages on threads this associate is actually assigned to.
    var reloadable = elsewhere.filter(function (m) { return !m.unclaimed; });
    if (isMessagesPage && reloadable.length) location.reload();
  }

  async function poll() {
    try {
      var res = await fetch('/api/associate/messages/poll?since=' + lastSeen);
      if (!res.ok) return;
      var data = await res.json();
      lastSeen = data.now;

      updateMessagesBadge(data.associateUnreadMessageCount);
      handleNewMessages(data.messageItems || []);
    } catch {}
  }

  setInterval(poll, 15000);
}());
</script>
