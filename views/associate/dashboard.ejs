<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Associate Portal | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, .brand { font-family: 'Syne', sans-serif; }
    button, a { cursor: pointer; }
    .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 24px; }
    .status-badge {
      display: inline-flex; align-items: center;
      font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 999px;
    }
    .status-pending    { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }
    .status-in-review  { background: rgba(99,102,241,0.12);  color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
    .status-accepted   { background: rgba(34,197,94,0.12);   color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .status-declined   { background: rgba(239,68,68,0.12);   color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .status-in-progress { background: rgba(59,130,246,0.12); color: #60a5fa; border: 1px solid rgba(59,130,246,0.25); }
    .status-completed  { background: rgba(16,185,129,0.12);  color: #34d399; border: 1px solid rgba(16,185,129,0.25); }
    .status-paused     { background: rgba(167,139,250,0.12); color: #a78bfa; border: 1px solid rgba(167,139,250,0.25); }
    .row {
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
      padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .row:last-child { border-bottom: none; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased min-h-screen">

  <%- include('_sidebar', { active: 'dashboard' }) %>

  <div class="lg:ml-55 min-h-screen">
  <div class="lg:hidden h-14"></div>

  <main class="px-6 lg:px-10 py-10 space-y-8">

    <div>
      <h2 class="text-base font-semibold text-white mb-4">My projects <span class="text-gray-600 font-normal text-sm"><%= myProjects.length %></span></h2>
      <% if (myProjects.length === 0) { %>
      <div class="card text-center py-10">
        <p class="text-gray-500 text-sm">Nothing claimed yet — take a project from the pool below.</p>
      </div>
      <% } else { %>
      <div class="card py-2! divide-y divide-white/5">
        <% myProjects.forEach(b => { %>
        <a href="/associate/booking/<%= b._id %>" class="row hover:opacity-80 transition-opacity">
          <div class="min-w-0">
            <p class="text-white font-medium text-sm truncate"><%= b.name %></p>
            <p class="text-gray-500 text-xs mt-0.5 font-mono"><%= b.crCode %> · <%= b.serviceType.join(', ') %></p>
          </div>
          <span class="status-badge status-<%= b.status %> shrink-0"><%= b.status %></span>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <div>
      <h2 class="text-base font-semibold text-white mb-4">Unclaimed pool <span class="text-gray-600 font-normal text-sm"><%= unclaimed.length %></span></h2>
      <% if (unclaimed.length === 0) { %>
      <div class="card text-center py-10">
        <p class="text-gray-500 text-sm">Nothing waiting to be claimed right now.</p>
      </div>
      <% } else { %>
      <div class="card py-2! divide-y divide-white/5">
        <% unclaimed.forEach(b => { %>
        <div class="row">
          <div class="min-w-0">
            <p class="text-white font-medium text-sm truncate"><%= b.name %></p>
            <p class="text-gray-500 text-xs mt-0.5 font-mono"><%= b.crCode %> · <%= b.serviceType.join(', ') %></p>
          </div>
          <form action="/associate/booking/<%= b._id %>/claim" method="POST" class="shrink-0">
            <button type="submit"
              class="text-xs font-semibold px-4 py-1.5 rounded-full bg-amber-400 hover:bg-amber-300 text-black transition-colors">
              Claim
            </button>
          </form>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

  </main>

  </div>

  <%- include('../_toast') %>
  <%- include('_message-poll') %>
  <%- include('_notif-poll') %>
  <% if (locals.claimError) { %>
  <script>showToast('Already claimed', <%- JSON.stringify(claimError) %>, 'error');</script>
  <% } %>
</body>
</html>
