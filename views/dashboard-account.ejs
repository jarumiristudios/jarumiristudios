<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Account | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; min-height: 40px; border-radius: 6px;
      font-size: 13.5px; color: #6b7280; font-weight: 500;
      text-decoration: none; transition: all 0.15s;
    }
    .sidebar-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.active { color: #fff; background: rgba(255,255,255,0.07); }
    .sidebar-link.new-link { color: #f59e0b; }
    .sidebar-link.new-link:hover { color: #fbbf24; background: rgba(245,158,11,0.08); }
    .sidebar-link.danger:hover { color: #f87171; background: rgba(239,68,68,0.06); }

    /* Collapsible sections */
    .section-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px;
    }
    .section-header {
      width: 100%; display: flex; align-items: center; justify-content: space-between;
      padding: 18px 24px; background: none; border: none; cursor: pointer;
      text-align: left; color: inherit;
    }
    .section-header:hover { background: rgba(255,255,255,0.015); }
    .section-body {
      overflow: hidden;
      max-height: 1000px;
      transition: max-height 0.28s ease, opacity 0.2s ease, padding 0.28s ease;
      opacity: 1;
      padding: 0 24px 24px;
    }
    .section-body.collapsed {
      max-height: 0;
      opacity: 0;
      padding-bottom: 0;
    }
    .collapse-icon {
      flex-shrink: 0; color: #4b5563;
      transition: transform 0.25s ease;
    }
    .collapse-icon.open { transform: rotate(180deg); }

    .form-input {
      width: 100%; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      padding: 12px 16px; color: #fff; font-size: 14px;
      font-family: 'Inter', sans-serif; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-input:focus { border-color: rgba(245,158,11,0.5); box-shadow: 0 0 0 3px rgba(245,158,11,0.07); }
    .form-input::placeholder { color: #4b5563; }
    .form-input.error { border-color: rgba(239,68,68,0.5); }
    .form-label { display: block; font-size: 12px; font-weight: 600; color: #6b7280; margin-bottom: 7px; letter-spacing: 0.05em; text-transform: uppercase; }

    .custom-select { position: relative; }
    .custom-select-trigger {
      width: 100%; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      padding: 12px 16px; color: #9ca3af; font-size: 14px;
      font-family: 'Inter', sans-serif;
      display: flex; align-items: center; justify-content: space-between;
      cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s;
      text-align: left; outline: none;
    }
    .custom-select-trigger.selected { color: #fff; }
    .custom-select-trigger.open,
    .custom-select-trigger:focus { border-color: rgba(245,158,11,0.5); box-shadow: 0 0 0 3px rgba(245,158,11,0.07); }
    .custom-select-chevron { flex-shrink: 0; width: 15px; height: 15px; color: #6b7280; transition: transform 0.2s; }
    .custom-select-trigger.open .custom-select-chevron { transform: rotate(180deg); }
    .custom-select-menu {
      display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0;
      background: #111; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      overflow: hidden; z-index: 100; box-shadow: 0 20px 40px rgba(0,0,0,0.6);
    }
    .custom-select-menu.open { display: block; }
    .custom-select-option {
      padding: 12px 16px; cursor: pointer; transition: background 0.15s;
      border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 14px; color: #fff;
    }
    .custom-select-option:last-child { border-bottom: none; }
    .custom-select-option:hover { background: rgba(245,158,11,0.08); }
    .custom-select-option.active { background: rgba(245,158,11,0.12); color: #f59e0b; }
    .custom-select-option .opt-label { font-size: 14px; color: #fff; font-weight: 500; }
    .custom-select-option .opt-desc  { font-size: 12px; color: #6b7280; margin-top: 2px; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[#0d0d0d] border-b border-white/5 flex items-center justify-between px-4">
    <span class="brand text-[15px] font-bold text-white">Jarumiri<span class="text-amber-400">.</span></span>
    <button onclick="toggleSidebar()" class="text-gray-500 hover:text-white transition-colors p-1.5">
      <iconify-icon icon="material-symbols-light:menu" width="22" height="22"></iconify-icon>
    </button>
  </header>

  <div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-30 hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-screen w-[220px] bg-[#0d0d0d] border-r border-white/5 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="h-[65px] flex items-center px-5 border-b border-white/5 shrink-0">
      <span class="brand text-[15px] font-bold text-white">Jarumiri Studios<span class="text-amber-400">.</span></span>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/dashboard" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:grid-view" width="20" height="20"></iconify-icon>
        Overview
      </a>
      <a href="/dashboard/gallery" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:photo-library" width="20" height="20"></iconify-icon>
        Gallery
      </a>
      <a href="/dashboard/messages" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:chat" width="20" height="20"></iconify-icon>
        <span class="flex-1">Messages</span>
        <% if (locals.unreadMessageCount > 0) { %>
        <span style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;"><%= unreadMessageCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/notifications" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:notifications" width="20" height="20"></iconify-icon>
        <span class="flex-1">Notifications</span>
        <% if (locals.unreadCount > 0) { %>
        <span style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/invoices" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:receipt-long-outline" width="20" height="20"></iconify-icon>
        Invoices
      </a>
      <a href="/dashboard/account" class="sidebar-link active">
        <iconify-icon icon="material-symbols-light:person" width="20" height="20"></iconify-icon>
        Account
      </a>
    </nav>

    <div class="px-3 pb-4 border-t border-white/5 shrink-0 space-y-1">
      <a href="/dashboard/new"
        class="flex items-center gap-2.5 w-full px-3 min-h-10 rounded-md bg-amber-400 text-black text-[13.5px] font-bold hover:bg-amber-300 transition-colors">
        <iconify-icon icon="material-symbols-light:add" width="20" height="20"></iconify-icon>
        New project
      </a>
      <a href="https://t.me/jarumiri" target="_blank" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:forum" width="20" height="20"></iconify-icon>
        Support
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="lg:ml-[220px] min-h-screen">
    <div class="lg:hidden h-14"></div>

    <main class="max-w-[620px] mx-auto px-5 py-10 space-y-3">

      <!-- Success banner -->
      <% if (locals.success) { %>
      <div id="success-banner" class="flex items-center gap-3 p-4 rounded-md bg-green-500/[0.07] border border-green-500/20 mb-2">
        <iconify-icon icon="material-symbols-light:check-circle" width="16" height="16" class="text-green-400 shrink-0"></iconify-icon>
        <p class="text-sm text-green-400 font-medium">Password updated successfully.</p>
      </div>
      <% } %>

      <!-- Error banner -->
      <% if (locals.error) { %>
      <div class="flex items-center gap-3 p-4 rounded-md bg-red-500/[0.07] border border-red-500/20 mb-2">
        <iconify-icon icon="material-symbols-light:error" width="16" height="16" class="text-red-400 shrink-0"></iconify-icon>
        <p class="text-sm text-red-400"><%= error %></p>
      </div>
      <% } %>

      <!-- ── Section: Account info ── -->
      <div class="section-card">
        <button class="section-header" onclick="toggleSection('account-info')">
          <span class="text-sm font-semibold text-white">Account info</span>
          <iconify-icon id="icon-account-info" class="collapse-icon open" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-account-info" class="section-body" style="overflow:visible;">
          <div class="space-y-5">
            <div>
              <p class="form-label">Email address</p>
              <p class="text-sm text-white"><%= user.email %></p>
              <p class="text-xs text-gray-500 mt-1.5">Your email cannot be changed. Contact support if you need help.</p>
            </div>
            <div class="border-t border-white/5 pt-5">
              <p class="form-label">Member since</p>
              <p class="text-sm text-white"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Section: Profile ── -->
      <div class="section-card">
        <button class="section-header" onclick="toggleSection('profile')">
          <span class="text-sm font-semibold text-white">Profile</span>
          <iconify-icon id="icon-profile" class="collapse-icon" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-profile" class="section-body collapsed">
          <form id="profile-form" action="/dashboard/account/profile" method="POST" novalidate>
            <div class="space-y-4">
              <div>
                <label class="form-label" for="profile-name">Full name <span class="text-amber-400">*</span></label>
                <input class="form-input" type="text" id="profile-name" name="name"
                  value="<%= user.name || '' %>" placeholder="Your name" autocomplete="name" required />
              </div>
              <div>
                <label class="form-label" for="profile-location">Location <span class="text-amber-400">*</span></label>
                <input class="form-input" type="text" id="profile-location" name="location"
                  value="<%= user.location || '' %>" placeholder="City, Country" autocomplete="country-name" required />
              </div>
              <div>
                <label class="form-label">You are a(n) <span class="text-amber-400">*</span></label>
                <input type="hidden" id="clientType" name="clientType" value="<%= user.clientType || '' %>" />
                <div class="custom-select" id="cs-clientType">
                  <button type="button" class="custom-select-trigger <%= user.clientType ? 'selected' : '' %>" id="cs-clientType-trigger" onclick="toggleDropdown('cs-clientType')" aria-haspopup="listbox" aria-expanded="false">
                    <span id="cs-clientType-label"><%= user.clientType || 'Select an option' %></span>
                    <iconify-icon class="custom-select-chevron" icon="material-symbols-light:keyboard-arrow-down"></iconify-icon>
                  </button>
                  <div class="custom-select-menu" id="cs-clientType-menu" role="listbox">
                    <div class="custom-select-option <%= user.clientType === 'Independent Creator' ? 'active' : '' %>" onclick="selectClientType('Independent Creator')" role="option" data-value="Independent Creator">
                      <p class="opt-label">Independent Creator</p>
                      <p class="opt-desc">Solo creator or freelancer making your own content</p>
                    </div>
                    <div class="custom-select-option <%= user.clientType === 'Agency' ? 'active' : '' %>" onclick="selectClientType('Agency')" role="option" data-value="Agency">
                      <p class="opt-label">Agency</p>
                      <p class="opt-desc">Managing projects on behalf of a client</p>
                    </div>
                    <div class="custom-select-option <%= user.clientType === 'Studio' ? 'active' : '' %>" onclick="selectClientType('Studio')" role="option" data-value="Studio">
                      <p class="opt-label">Studio</p>
                      <p class="opt-desc">In-house production team or post-production house</p>
                    </div>
                    <div class="custom-select-option <%= user.clientType === 'Brand / Business' ? 'active' : '' %>" onclick="selectClientType('Brand / Business')" role="option" data-value="Brand / Business">
                      <p class="opt-label">Brand / Business</p>
                      <p class="opt-desc">Company producing content for your own brand</p>
                    </div>
                    <div class="custom-select-option <%= user.clientType === 'Other' ? 'active' : '' %>" onclick="selectClientType('Other')" role="option" data-value="Other">
                      <p class="opt-label">Other</p>
                      <p class="opt-desc">Something else — tell us in your project brief</p>
                    </div>
                  </div>
                </div>
                <p class="field-error hidden mt-1" id="err-clientType">Please select an option.</p>
              </div>
              <div>
                <label class="form-label" for="profile-external-link">Website / Portfolio <span class="text-gray-500 font-normal">(optional)</span></label>
                <input class="form-input" type="url" id="profile-external-link" name="externalLink"
                  value="<%= user.externalLink || '' %>" placeholder="https://yoursite.com" />
              </div>
            </div>
            <div class="mt-5 flex items-center justify-end gap-4">
              <button type="submit"
                class="px-5 py-2.5 rounded-full bg-white/6 border border-white/12 text-white text-sm font-semibold hover:bg-white/10 transition-colors shrink-0">
                Save profile
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- ── Section: External links ── -->
      <div class="section-card">
        <button class="section-header" onclick="toggleSection('links')">
          <span class="text-sm font-semibold text-white">External links</span>
          <iconify-icon id="icon-links" class="collapse-icon" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-links" class="section-body collapsed">
          <form action="/dashboard/account/profile" method="POST" novalidate>
            <input type="hidden" name="platformsSubmitted" value="1" />
            <input type="hidden" name="name" value="<%= user.name || '' %>" />
            <input type="hidden" name="location" value="<%= user.location || '' %>" />
            <input type="hidden" name="clientType" value="<%= user.clientType || '' %>" />
            <input type="hidden" name="externalLink" value="<%= user.externalLink || '' %>" />

            <p class="text-xs text-gray-500 mb-4">Saved here once — new project requests will reuse these instead of asking again.</p>

            <div>
              <label class="form-label">Platforms <span class="text-gray-500 font-normal">(up to 3)</span></label>
              <div id="platform-badges" class="flex flex-wrap gap-2 mb-2 hidden"></div>
              <div id="platform-hidden-inputs"></div>
              <div class="flex gap-2">
                <input type="hidden" id="platform-select" value="Instagram" />
                <div class="custom-select w-36 shrink-0" id="cs-platform">
                  <button type="button" class="custom-select-trigger" id="cs-platform-trigger" onclick="toggleDropdown('cs-platform')" aria-haspopup="listbox" aria-expanded="false">
                    <span id="cs-platform-label">Instagram</span>
                    <iconify-icon class="custom-select-chevron" icon="material-symbols-light:keyboard-arrow-down"></iconify-icon>
                  </button>
                  <div class="custom-select-menu" id="cs-platform-menu" role="listbox">
                    <div class="custom-select-option active" onclick="selectPlatformOption('Instagram')" role="option" data-value="Instagram">
                      <p class="opt-label">Instagram</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('Twitter')" role="option" data-value="Twitter">
                      <p class="opt-label">Twitter</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('TikTok')" role="option" data-value="TikTok">
                      <p class="opt-label">TikTok</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('OnlyFans')" role="option" data-value="OnlyFans">
                      <p class="opt-label">OnlyFans</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('Fansly')" role="option" data-value="Fansly">
                      <p class="opt-label">Fansly</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('Fanview')" role="option" data-value="Fanview">
                      <p class="opt-label">Fanview</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('MannyVids')" role="option" data-value="MannyVids">
                      <p class="opt-label">MannyVids</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('Pornhub')" role="option" data-value="Pornhub">
                      <p class="opt-label">Pornhub</p>
                    </div>
                    <div class="custom-select-option" onclick="selectPlatformOption('Other')" role="option" data-value="Other">
                      <p class="opt-label">Other</p>
                    </div>
                  </div>
                </div>
                <input class="form-input" type="text" id="platform-handle-input" placeholder="@handle or profile URL" />
                <button type="button" id="platform-add-btn" onclick="addPlatformEntry()" aria-label="Add link" class="shrink-0 w-11 rounded-md bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-white/25 transition-colors flex items-center justify-center">
                  <iconify-icon icon="material-symbols-light:check" width="18" height="18"></iconify-icon>
                </button>
              </div>
              <p class="field-error hidden mt-1" id="err-platform">Please enter a handle or profile URL.</p>
            </div>

            <div class="mt-5 flex items-center justify-end gap-4">
              <button type="submit"
                class="px-5 py-2.5 rounded-full bg-white/6 border border-white/12 text-white text-sm font-semibold hover:bg-white/10 transition-colors shrink-0">
                Save links
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- ── Section: Change password ── -->
      <div class="section-card">
        <button class="section-header" onclick="toggleSection('password')">
          <span class="text-sm font-semibold text-white">Change password</span>
          <iconify-icon id="icon-password" class="collapse-icon" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-password" class="section-body collapsed">
          <form action="/dashboard/account/password" method="POST" novalidate id="pwd-form">
            <div class="space-y-4">
              <div>
                <label class="form-label" for="currentPassword">Current password</label>
                <div style="position:relative;">
                  <input class="form-input" type="password" id="currentPassword" name="currentPassword" required placeholder="Your current password" />
                  <button type="button" onclick="togglePwd('currentPassword',this)" tabindex="-1"
                    style="position:absolute;right:13px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;color:#6b7280;cursor:pointer;display:flex;align-items:center;">
                    <iconify-icon class="eye-show" icon="material-symbols-light:visibility" width="20" height="20"></iconify-icon>
                    <iconify-icon class="eye-hide" icon="material-symbols-light:visibility-off" width="20" height="20" style="display:none;"></iconify-icon>
                  </button>
                </div>
              </div>
              <div>
                <label class="form-label" for="newPassword">New password</label>
                <div style="position:relative;">
                  <input class="form-input" type="password" id="newPassword" name="newPassword" required minlength="8" placeholder="At least 8 characters" />
                  <button type="button" onclick="togglePwd('newPassword',this)" tabindex="-1"
                    style="position:absolute;right:13px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;color:#6b7280;cursor:pointer;display:flex;align-items:center;">
                    <iconify-icon class="eye-show" icon="material-symbols-light:visibility" width="20" height="20"></iconify-icon>
                    <iconify-icon class="eye-hide" icon="material-symbols-light:visibility-off" width="20" height="20" style="display:none;"></iconify-icon>
                  </button>
                </div>
                <div id="pwd-strength" class="mt-2 hidden">
                  <div class="flex gap-1 mb-1">
                    <div class="h-1 flex-1 rounded-full bg-white/10" id="str-1"></div>
                    <div class="h-1 flex-1 rounded-full bg-white/10" id="str-2"></div>
                    <div class="h-1 flex-1 rounded-full bg-white/10" id="str-3"></div>
                    <div class="h-1 flex-1 rounded-full bg-white/10" id="str-4"></div>
                  </div>
                  <p id="str-label" class="text-xs text-gray-500"></p>
                </div>
              </div>
              <div>
                <label class="form-label" for="confirmPassword">Confirm new password</label>
                <div style="position:relative;">
                  <input class="form-input" type="password" id="confirmPassword" name="confirmPassword" required placeholder="Repeat new password" />
                  <button type="button" onclick="togglePwd('confirmPassword',this)" tabindex="-1"
                    style="position:absolute;right:13px;top:50%;transform:translateY(-50%);background:none;border:none;padding:0;color:#6b7280;cursor:pointer;display:flex;align-items:center;">
                    <iconify-icon class="eye-show" icon="material-symbols-light:visibility" width="20" height="20"></iconify-icon>
                    <iconify-icon class="eye-hide" icon="material-symbols-light:visibility-off" width="20" height="20" style="display:none;"></iconify-icon>
                  </button>
                </div>
                <p id="confirm-mismatch" class="text-[12px] text-red-400 mt-1.5 hidden">Passwords don't match.</p>
              </div>
            </div>

            <div class="mt-6 flex items-center justify-between gap-4">
              <p class="text-xs text-gray-500">You'll stay logged in after changing your password.</p>
              <button type="submit" id="save-btn"
                class="px-6 py-2.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
                Save changes
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- ── Section: Sign out ── -->
      <div class="section-card" style="border-color:rgba(239,68,68,0.1);">
        <button class="section-header" onclick="toggleSection('signout')">
          <span class="text-sm font-semibold text-white">Sign out</span>
          <iconify-icon id="icon-signout" class="collapse-icon" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-signout" class="section-body collapsed">
          <p class="text-xs text-gray-600 mb-4">End your current session on this device.</p>
          <a href="/logout"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-red-500/25 text-red-400 text-sm font-medium hover:bg-red-500/8 hover:border-red-500/40 transition-colors">
            <iconify-icon icon="material-symbols-light:logout" width="15" height="15"></iconify-icon>
            Sign out
          </a>
        </div>
      </div>

      <!-- ── Section: Delete account ── -->
      <div class="section-card" style="border-color:rgba(239,68,68,0.15);">
        <button class="section-header" onclick="toggleSection('delete')">
          <span class="text-sm font-semibold text-red-400">Delete account</span>
          <iconify-icon id="icon-delete" class="collapse-icon" icon="material-symbols-light:expand-more" width="18" height="18"></iconify-icon>
        </button>
        <div id="body-delete" class="section-body collapsed">
          <p class="text-xs text-gray-600 mb-4">Permanently delete your account, along with all of your projects and uploaded files. This cannot be undone.</p>

          <button type="button" onclick="toggleDeleteConfirm()"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-red-500/30 bg-red-500/5 text-red-400 text-sm font-semibold hover:bg-red-500/12 hover:border-red-500/50 transition-colors">
            <iconify-icon icon="material-symbols-light:delete" width="15" height="15"></iconify-icon>
            Delete account
          </button>

          <div id="delete-confirm" class="hidden mt-5 pt-5 border-t border-red-500/15">
            <p class="text-xs text-gray-500 mb-3">Type your email address to confirm: <span class="text-gray-300 font-medium"><%= user.email %></span></p>
            <form action="/dashboard/account/delete" method="POST" novalidate id="delete-form">
              <input type="text" name="confirmEmail" id="confirm-email-input" autocomplete="off"
                placeholder="<%= user.email %>"
                class="form-input mb-3"
                style="border-color:rgba(239,68,68,0.25);" />
              <div class="flex items-center gap-3">
                <button type="submit" id="confirm-delete-btn" disabled
                  class="px-5 py-2.5 rounded-full bg-red-500/15 border border-red-500/30 text-red-400 text-sm font-semibold opacity-40 cursor-not-allowed transition-all">
                  Confirm deletion
                </button>
                <button type="button" onclick="toggleDeleteConfirm()"
                  class="text-xs text-gray-600 hover:text-gray-400 transition-colors">
                  Cancel
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    // ── Account type dropdown ──
    function toggleDropdown(id) {
      const trigger = document.getElementById(`${id}-trigger`);
      const menu    = document.getElementById(`${id}-menu`);
      const isOpen  = menu.classList.contains('open');
      closeAllDropdowns();
      if (!isOpen) {
        menu.classList.add('open');
        trigger.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    }

    function closeAllDropdowns() {
      document.querySelectorAll('.custom-select-menu.open').forEach(m => {
        m.classList.remove('open');
        m.previousElementSibling.classList.remove('open');
        m.previousElementSibling.setAttribute('aria-expanded', 'false');
      });
    }

    function selectClientType(value) {
      document.getElementById('clientType').value = value;
      document.getElementById('cs-clientType-label').textContent = value;
      const trigger = document.getElementById('cs-clientType-trigger');
      trigger.classList.add('selected');
      trigger.classList.remove('error');
      document.getElementById('err-clientType').classList.add('hidden');
      document.querySelectorAll('#cs-clientType-menu .custom-select-option').forEach(o => o.classList.remove('active'));
      event.currentTarget.classList.add('active');
      document.getElementById('cs-clientType-menu').classList.remove('open');
      trigger.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    }

    document.addEventListener('click', e => { if (!e.target.closest('.custom-select')) closeAllDropdowns(); });

    // ── External links: platform dropdown + handle input side by side. Enter or
    // the check button commits the pair as a badge above the field. ──
    let platformEntries = <%- JSON.stringify((user.platforms || []).map(p => ({ platform: p.platform, handle: p.handle }))) %>;
    const MAX_PLATFORM_LINKS = 3;

    function selectPlatformOption(value) {
      document.getElementById('platform-select').value = value;
      document.getElementById('cs-platform-label').textContent = value;
      document.querySelectorAll('#cs-platform-menu .custom-select-option').forEach(o => {
        o.classList.toggle('active', o.dataset.value === value);
      });
      const trigger = document.getElementById('cs-platform-trigger');
      document.getElementById('cs-platform-menu').classList.remove('open');
      trigger.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
      const handleInput = document.getElementById('platform-handle-input');
      handleInput.placeholder = value === 'Other' ? 'Paste your link (https://…)' : '@handle or profile URL';
      handleInput.focus();
    }

    function addPlatformEntry() {
      const platform = document.getElementById('platform-select').value;
      const input    = document.getElementById('platform-handle-input');
      const handle   = input.value.trim();
      const err      = document.getElementById('err-platform');

      if (platformEntries.length >= MAX_PLATFORM_LINKS) return;

      if (!handle) {
        input.classList.add('error');
        err.textContent = 'Please enter a handle or profile URL.';
        err.classList.remove('hidden');
        return;
      }
      input.classList.remove('error');
      err.classList.add('hidden');

      platformEntries.push({ platform, handle });
      input.value = '';
      renderPlatformBadges();
      input.focus();
    }

    function removePlatformEntry(i) {
      platformEntries.splice(i, 1);
      renderPlatformBadges();
    }

    // Known real domains only — never fabricate a TLD for a platform we don't
    // actually know the domain of, and never touch a URL the user already typed.
    const PLATFORM_DOMAINS = {
      Instagram: 'instagram.com',
      Twitter:   'x.com',
      TikTok:    'tiktok.com',
      OnlyFans:  'onlyfans.com',
      Fansly:    'fansly.com',
      Pornhub:   'pornhub.com',
      MannyVids: 'manyvids.com',
    };

    // TikTok profile URLs require the @ in the path (tiktok.com/@user); every
    // other platform here uses a bare username, so strip a leading @ instead.
    function handlePath(platform, value) {
      const bare = value.replace(/^@/, '');
      return platform === 'TikTok' ? `@${bare}` : bare;
    }

    function linkPreview(platform, value) {
      const v = value.trim();
      let text;
      if (/^https?:\/\//i.test(v)) {
        text = v.replace(/^https?:\/\//i, '');
      } else {
        const domain = PLATFORM_DOMAINS[platform];
        text = domain ? `${domain}/${handlePath(platform, v)}` : v;
      }
      return text.length > 32 ? `${text.slice(0, 32)}…` : text;
    }

    // Real, absolute URL to open — null when we don't know the platform's domain
    // and the user didn't paste a full URL, rather than guessing one.
    function linkHref(platform, value) {
      const v = value.trim();
      if (/^https?:\/\//i.test(v)) return v;
      const domain = PLATFORM_DOMAINS[platform];
      return domain ? `https://${domain}/${handlePath(platform, v)}` : null;
    }

    function renderPlatformBadges() {
      const badges    = document.getElementById('platform-badges');
      const container = document.getElementById('platform-hidden-inputs');
      badges.innerHTML = '';
      container.innerHTML = '';

      platformEntries.forEach((entry, i) => {
        const badge = document.createElement('span');
        badge.className = 'inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-md bg-amber-400/10 border border-amber-400/20 text-xs font-semibold text-amber-400';

        const href = linkHref(entry.platform, entry.handle);
        const text = document.createElement(href ? 'a' : 'span');
        if (href) {
          text.href = href;
          text.target = '_blank';
          text.rel = 'noopener';
          text.className = 'no-underline';
        }
        text.textContent = `${entry.platform} | ${linkPreview(entry.platform, entry.handle)}`;
        badge.appendChild(text);

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.setAttribute('aria-label', `Remove ${entry.platform} link`);
        removeBtn.style.cssText = 'cursor:pointer;color:inherit;font-weight:700;';
        removeBtn.textContent = '×';
        removeBtn.onclick = () => removePlatformEntry(i);
        badge.appendChild(removeBtn);

        badges.appendChild(badge);

        const nameInput = document.createElement('input');
        nameInput.type = 'hidden'; nameInput.name = 'platformNames'; nameInput.value = entry.platform;
        container.appendChild(nameInput);

        const handleInput = document.createElement('input');
        handleInput.type = 'hidden'; handleInput.name = 'platformHandles'; handleInput.value = entry.handle;
        container.appendChild(handleInput);
      });

      badges.classList.toggle('hidden', platformEntries.length === 0);

      const atMax  = platformEntries.length >= MAX_PLATFORM_LINKS;
      const input  = document.getElementById('platform-handle-input');
      const addBtn = document.getElementById('platform-add-btn');
      input.disabled  = atMax;
      addBtn.disabled = atMax;
      addBtn.classList.toggle('opacity-40', atMax);
      input.placeholder = atMax ? 'Maximum 3 links added' : '@handle or profile URL';
    }

    document.getElementById('platform-handle-input')?.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); addPlatformEntry(); }
    });

    renderPlatformBadges();

    // "You are a(n)" now feeds bookings directly, so require it here too.
    document.getElementById('profile-form')?.addEventListener('submit', e => {
      const clientType = document.getElementById('clientType');
      if (!clientType.value) {
        e.preventDefault();
        document.getElementById('cs-clientType-trigger').classList.add('error');
        document.getElementById('err-clientType').classList.remove('hidden');
      }
    });

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }

    const SECTIONS = ['account-info', 'profile', 'links', 'password', 'signout', 'delete'];

    function toggleSection(id) {
      const body = document.getElementById('body-' + id);
      const isCurrentlyCollapsed = body.classList.contains('collapsed');

      // Collapse all sections first
      SECTIONS.forEach(s => {
        const b = document.getElementById('body-' + s);
        const i = document.getElementById('icon-' + s);
        if (b && !b.classList.contains('collapsed')) {
          b.style.overflow = 'hidden';
          b.classList.add('collapsed');
          i.classList.remove('open');
        }
      });

      // If the clicked one was open, leave everything collapsed; otherwise open it
      if (isCurrentlyCollapsed) {
        body.classList.remove('collapsed');
        document.getElementById('icon-' + id).classList.add('open');
        body.addEventListener('transitionend', function onEnd() {
          body.style.overflow = 'visible';
          body.removeEventListener('transitionend', onEnd);
        });
      }
    }

    function togglePwd(inputId, btn) {
      const input = document.getElementById(inputId);
      const showing = input.type === 'text';
      input.type = showing ? 'password' : 'text';
      btn.querySelector('.eye-show').style.display = showing ? '' : 'none';
      btn.querySelector('.eye-hide').style.display = showing ? 'none' : '';
      btn.style.color = showing ? '#6b7280' : '#f59e0b';
    }

    // Delete account confirm toggle
    function toggleDeleteConfirm() {
      const section = document.getElementById('delete-confirm');
      const input   = document.getElementById('confirm-email-input');
      section.classList.toggle('hidden');
      if (!section.classList.contains('hidden')) input.focus();
      else input.value = '';
    }

    // Enable confirm button only when email matches
    document.getElementById('confirm-email-input').addEventListener('input', function() {
      const btn = document.getElementById('confirm-delete-btn');
      const matches = this.value.trim().toLowerCase() === '<%= user.email %>';
      btn.disabled = !matches;
      btn.classList.toggle('opacity-40', !matches);
      btn.classList.toggle('cursor-not-allowed', !matches);
      btn.classList.toggle('cursor-pointer', matches);
      btn.classList.toggle('hover:bg-red-500/25', matches);
    });

    // Password strength meter
    const newPwdInput = document.getElementById('newPassword');
    const strBar      = document.getElementById('pwd-strength');
    const strLabel    = document.getElementById('str-label');
    const strSegments = [1,2,3,4].map(i => document.getElementById(`str-${i}`));
    const COLORS = ['#ef4444','#f59e0b','#f59e0b','#22c55e'];
    const LABELS = ['Too short','Weak','Medium','Strong'];

    newPwdInput.addEventListener('input', () => {
      const v = newPwdInput.value;
      if (!v) { strBar.classList.add('hidden'); return; }
      strBar.classList.remove('hidden');
      let score = 0;
      if (v.length >= 8)  score++;
      if (v.length >= 12) score++;
      if (/[^a-zA-Z0-9]/.test(v)) score++;
      if (/[0-9]/.test(v) && /[a-zA-Z]/.test(v)) score++;
      score = Math.min(score, 4);
      strSegments.forEach((seg, i) => {
        seg.style.background = i < score ? COLORS[score - 1] : 'rgba(255,255,255,0.08)';
      });
      strLabel.textContent = LABELS[score - 1] || '';
      strLabel.style.color = COLORS[score - 1] || '#6b7280';
    });

    // Confirm match check
    const confirmInput = document.getElementById('confirmPassword');
    const mismatch     = document.getElementById('confirm-mismatch');
    confirmInput.addEventListener('input', () => {
      if (confirmInput.value && confirmInput.value !== newPwdInput.value) {
        mismatch.classList.remove('hidden');
        confirmInput.style.borderColor = 'rgba(239,68,68,0.5)';
      } else {
        mismatch.classList.add('hidden');
        confirmInput.style.borderColor = '';
      }
    });

    // Client-side submit guard
    document.getElementById('pwd-form').addEventListener('submit', e => {
      const cur = document.getElementById('currentPassword').value;
      const nw  = newPwdInput.value;
      const con = confirmInput.value;
      if (!cur || !nw || !con) { e.preventDefault(); return; }
      if (nw !== con) { e.preventDefault(); mismatch.classList.remove('hidden'); return; }
      if (nw.length < 8) { e.preventDefault(); return; }
    });
  </script>
  <%- include('_toast') %>
  <%- include('_notif-poll') %>
</body>
</html>
