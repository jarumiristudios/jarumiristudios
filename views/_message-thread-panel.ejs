<!-- Thread header -->
<div class="flex items-center gap-3 px-5 py-4 border-b border-white/5 shrink-0">
  <button type="button" onclick="showList()" class="lg:hidden text-gray-500 hover:text-white transition-colors text-sm">← Chats</button>
  <span class="font-mono text-amber-400 text-sm font-semibold"><%= booking.crCode %></span>
  <span class="text-gray-600 text-xs"><%= booking.serviceType.join(', ') %></span>
</div>

<!-- Message list -->
<div id="message-list" class="flex-1 overflow-y-auto px-5 py-5">
  <% messages.forEach(m => { %>
  <div class="bubble-row <%= m.senderRole === myRole ? 'mine' : 'theirs' %>" data-message-id="<%= m._id %>">
    <div class="bubble-col">
      <div class="bubble">
        <% if (m.body) { %><div><%= m.body %></div><% } %>
        <% if (m.attachment && m.attachment.storedName) { %>
        <a class="attachment-chip" href="<%= attachmentBasePath %>/<%= m.attachment.storedName %>" download="<%= m.attachment.originalName %>">
          <iconify-icon icon="material-symbols-light:attach-file" width="18" height="18"></iconify-icon>
          <span style="font-size:13.5px;"><%= m.attachment.originalName %></span>
        </a>
        <% } %>
        <div class="bubble-time">
          <span class="bubble-time-text"><%= new Date(m.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></span>
          <% if (m.senderRole === myRole) { %>
          <iconify-icon icon="<%= m.read ? 'material-symbols:done-all' : 'material-symbols:check' %>" width="15" height="15" class="tick <%= m.read ? 'tick-read' : '' %>"></iconify-icon>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
  <% if (!messages.length) { %>
  <p class="text-xs text-gray-600">No messages yet<%= myRole === 'client' ? ' — say hello.' : '.' %></p>
  <% } %>
</div>

<!-- Composer -->
<form id="composer" class="flex items-end gap-2 px-5 py-4 border-t border-white/5 shrink-0" enctype="multipart/form-data" data-post-path="<%= postPath %>" data-attachment-base="<%= attachmentBasePath %>" data-my-role="<%= myRole %>">
  <label class="text-gray-500 hover:text-white transition-colors cursor-pointer p-2">
    <iconify-icon icon="material-symbols-light:attach-file" width="20" height="20"></iconify-icon>
    <input type="file" id="attachment-input" name="attachment" class="hidden" />
  </label>
  <span id="attachment-preview" class="text-xs text-gray-500"></span>
  <textarea id="body-input" rows="1" placeholder="Write a message..."
    class="flex-1 bg-white/4 border border-white/10 rounded-md px-4 py-2.5 text-sm text-white outline-none resize-none"
    style="max-height:120px;"></textarea>
  <button type="submit" class="bg-amber-400 text-black text-sm font-bold px-4 py-2.5 rounded-md hover:bg-amber-300 transition-colors">
    Send
  </button>
</form>
