<!-- Thread header -->
<div class="flex items-center gap-3 px-5 py-4 border-b border-white/5 shrink-0">
  <button type="button" onclick="showList()" class="lg:hidden text-gray-500 hover:text-white transition-colors text-sm">← Chats</button>
  <span class="font-mono text-amber-400 text-sm font-semibold"><%= booking.crCode %></span>
  <span class="text-gray-600 text-xs"><%= booking.serviceType.join(', ') %></span>
</div>

<!-- Message list -->
<div id="message-list" class="flex-1 overflow-y-auto px-5 py-5">
  <%
    function dayLabel(date) {
      const now = new Date();
      const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const startOfDay = new Date(date.getFullYear(), date.getMonth(), date.getDate());
      const diffDays = Math.round((startOfToday - startOfDay) / 86400000);
      if (diffDays === 0) return 'Today';
      if (diffDays === 1) return 'Yesterday';
      if (diffDays > 1 && diffDays < 7) return date.toLocaleDateString('en-US', { weekday: 'long' });
      const opts = { month: 'long', day: 'numeric' };
      if (date.getFullYear() !== now.getFullYear()) opts.year = 'numeric';
      return date.toLocaleDateString('en-US', opts);
    }
    function attachmentIcon(mimetype) {
      if (/^video\//i.test(mimetype)) return 'material-symbols-light:videocam';
      if (/^audio\//i.test(mimetype)) return 'material-symbols-light:music-note-2';
      return 'material-symbols-light:attach-file';
    }
    function truncateTaggedName(name) {
      const dotIdx = name.lastIndexOf('.');
      const hasExt = dotIdx > 0 && dotIdx < name.length - 1;
      const ext = hasExt ? name.slice(dotIdx) : '';
      const base = hasExt ? name.slice(0, dotIdx) : name;
      if (base.length <= 8) return base + ext;
      return base.slice(0, 4) + '…' + base.slice(-4) + ext;
    }
    const thumbSpinnerSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="rgba(255,255,255,0.25)" stroke-width="3"></circle><path d="M21 12a9 9 0 0 0-9-9" stroke="#fff" stroke-width="3" stroke-linecap="round"></path></svg>';
    let lastDayKey = null;
  %>
  <% messages.forEach(m => {
    const createdAt = new Date(m.createdAt);
    const dayKey = createdAt.toDateString();
    const showDaySeparator = dayKey !== lastDayKey;
    lastDayKey = dayKey;
  %>
  <% if (showDaySeparator) { %>
  <div class="day-separator" data-day-key="<%= dayKey %>"><span><%= dayLabel(createdAt) %></span></div>
  <% } %>
  <div class="bubble-row <%= m.senderRole === myRole ? 'mine' : 'theirs' %> <%= m.deleted ? 'deleted' : '' %>" data-message-id="<%= m._id %>">
    <% if (m.senderRole === myRole && !m.deleted) { %>
    <button type="button" class="msg-delete-btn" onclick="window.deleteMessage('<%= m._id %>')" title="Delete message">
      <iconify-icon icon="material-symbols-light:delete-outline" width="20" height="20"></iconify-icon>
    </button>
    <% } %>
    <div class="bubble-col">
      <div class="bubble">
        <% const showTick = m.senderRole === myRole; %>
        <% if (m.deleted) { %>
        <span class="bubble-deleted-text">This message was deleted</span><span class="time-spacer <%= showTick ? 'with-tick' : '' %>"></span>
        <% } else { %>
        <% const msgAttachments = (m.attachments && m.attachments.length) ? m.attachments : (m.attachment && m.attachment.storedName ? [m.attachment] : []); %>
        <% msgAttachments.forEach(att => {
          const isImage = /^image\//i.test(att.mimetype);
          const isVideo = /^video\//i.test(att.mimetype);
          const isAudio = /^audio\//i.test(att.mimetype);
          const isTagged = att.folder && att.folder !== 'chat';
          const attUrl = attachmentBasePath + '/' + att.storedName;
          const isLazy = !showTick && (isImage || isVideo) && !att.downloaded;
        %>
        <% if (isTagged) { %>
        <a class="tagged-inline-badge" href="<%= attUrl %>" download="<%= att.originalName %>" title="<%= att.originalName %>"
          onclick="return window.openFileViewer(event, this)"
          data-stored-name="<%= att.storedName %>" data-original-name="<%= att.originalName %>"
          data-mimetype="<%= att.mimetype %>" data-size="<%= att.size %>">
          <span class="tagged-inline-thumb<%= isLazy ? ' lazy-attachment' : '' %>" data-download-url="<%= attUrl %>" data-mimetype="<%= att.mimetype %>" data-icon-size="13"<% if (isLazy && att.blurDataUrl) { %> style="background-image:url('<%= att.blurDataUrl %>')"<% } %>>
            <% if (isLazy) { %>
            <button type="button" class="thumb-download-btn" onclick="event.preventDefault(); event.stopPropagation(); window.startAttachmentDownload(this.closest('[data-download-url]'));">
              <span class="thumb-btn-badge"><iconify-icon icon="material-symbols-light:download" width="18" height="18"></iconify-icon></span>
            </button>
            <% } else if (isImage) { %>
            <img src="<%= attUrl %>" alt="" onload="this.closest('.tagged-inline-thumb').classList.add('media-loaded')" />
            <span class="thumb-loading-overlay"><%- thumbSpinnerSvg %></span>
            <% } else if (isVideo) { %>
            <video src="<%= attUrl %>" muted preload="metadata" onloadeddata="this.closest('.tagged-inline-thumb').classList.add('media-loaded')"></video>
            <span class="thumb-loading-overlay"><%- thumbSpinnerSvg %></span>
            <% } else if (isAudio) { %>
            <iconify-icon icon="material-symbols-light:music-note-2" width="13" height="13" style="color:#f59e0b;"></iconify-icon>
            <% } else { %>
            <iconify-icon icon="<%= attachmentIcon(att.mimetype) %>" width="13" height="13"></iconify-icon>
            <% } %>
          </span>
          <span><%= truncateTaggedName(att.originalName) %></span>
        </a>
        <% } else { %>
        <a class="attachment-badge" href="<%= attUrl %>" download="<%= att.originalName %>" title="<%= att.originalName %>"
          onclick="return window.openFileViewer(event, this)"
          data-stored-name="<%= att.storedName %>" data-original-name="<%= att.originalName %>"
          data-mimetype="<%= att.mimetype %>" data-size="<%= att.size %>">
          <span class="badge-thumb badge-thumb-preview <%= isAudio ? 'badge-thumb-audio' : '' %><%= isLazy ? ' lazy-attachment' : '' %>" data-download-url="<%= attUrl %>" data-mimetype="<%= att.mimetype %>" data-icon-size="28"<% if (isLazy && att.blurDataUrl) { %> style="background-image:url('<%= att.blurDataUrl %>')"<% } %>>
            <% if (isLazy) { %>
            <button type="button" class="thumb-download-btn" onclick="event.preventDefault(); event.stopPropagation(); window.startAttachmentDownload(this.closest('[data-download-url]'));">
              <span class="thumb-btn-badge"><iconify-icon icon="material-symbols-light:download" width="32" height="32"></iconify-icon></span>
            </button>
            <% } else if (isImage) { %>
            <img src="<%= attUrl %>" alt="" onload="this.closest('.badge-thumb').classList.add('media-loaded')" />
            <span class="thumb-loading-overlay"><%- thumbSpinnerSvg %></span>
            <% } else if (isVideo) { %>
            <video src="<%= attUrl %>" muted preload="metadata" onloadeddata="this.closest('.badge-thumb').classList.add('media-loaded')"></video>
            <span class="thumb-loading-overlay"><%- thumbSpinnerSvg %></span>
            <% } else if (isAudio) { %>
            <iconify-icon icon="material-symbols-light:music-note-2" width="32" height="32" style="color:#f59e0b;"></iconify-icon>
            <% } else { %>
            <iconify-icon icon="<%= attachmentIcon(att.mimetype) %>" width="32" height="32"></iconify-icon>
            <% } %>
          </span>
        </a>
        <% } %>
        <% }) %>
        <% if (m.body) { %>
        <%= m.body %><span class="time-spacer <%= showTick ? 'with-tick' : '' %>"></span>
        <% } %>
        <% } %>
        <span class="bubble-time <%= (m.body || m.deleted) ? 'corner' : 'block' %>">
          <span class="bubble-time-text"><%= createdAt.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) %></span>
          <% if (showTick) { %>
          <iconify-icon icon="<%= m.read ? 'material-symbols:done-all' : 'material-symbols:check' %>" width="15" height="15" class="tick <%= m.read ? 'tick-read' : '' %>"></iconify-icon>
          <% } %>
        </span>
      </div>
    </div>
  </div>
  <% }) %>
  <% if (!messages.length) { %>
  <p class="text-xs <%= booking.chatUnlocked ? 'text-gray-600' : 'text-gray-400' %>">
    <% if (!booking.chatUnlocked) { %>
    Chat opens once this project is accepted.
    <% } else { %>
    No messages yet<%= myRole === 'client' ? ' — say hello.' : '.' %>
    <% } %>
  </p>
  <% } %>
</div>

<!-- Attach file modal -->
<div id="attach-modal" class="hidden fixed inset-0 z-50 items-center justify-center bg-black/60 px-4">
  <div class="bg-[#111111] border border-white/10 rounded-lg w-full max-w-md max-h-[75vh] flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-white/5 shrink-0">
      <h3 class="text-sm font-semibold text-white">Attach a file</h3>
      <button type="button" id="attach-modal-close" class="text-gray-500 hover:text-white transition-colors">
        <iconify-icon icon="material-symbols-light:close" width="18" height="18"></iconify-icon>
      </button>
    </div>
    <div class="p-4 border-b border-white/5 shrink-0">
      <button type="button" id="browse-files-btn" class="w-full h-11 flex items-center justify-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md text-sm text-gray-300 transition-colors">
        <iconify-icon icon="material-symbols-light:cloud-upload" width="18" height="18"></iconify-icon>
        Browse files
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-4 space-y-5">
      <%
        const mediaGroups = [];
        if (booking.uploadedFiles && booking.uploadedFiles.length) {
          mediaGroups.push({ label: 'Uploaded files', source: 'uploaded', base: '/dashboard/uploads', files: booking.uploadedFiles });
        }
        if (booking.deliverablesUnlocked && booking.deliverableFiles && booking.deliverableFiles.length) {
          mediaGroups.push({ label: 'Final deliverables', source: 'deliverable', base: '/dashboard/deliverables', files: booking.deliverableFiles });
        }
      %>
      <% if (!mediaGroups.length) { %>
      <p class="text-xs text-gray-600">No project files to tag yet.</p>
      <% } %>
      <% mediaGroups.forEach(group => { %>
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-wide text-gray-600 mb-2"><%= group.label %></h4>
        <div class="space-y-1">
          <% group.files.forEach(f => {
            const isImage = /^image\//i.test(f.mimetype);
            const isVideo = /^video\//i.test(f.mimetype);
            const isAudio = /^audio\//i.test(f.mimetype);
            const thumbUrl = group.base + '/' + f.storedName;
            const sizeLabel = f.size < 1024*1024 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1024/1024).toFixed(1)+' MB';
          %>
          <button type="button" class="media-pick-btn w-full flex items-center gap-3 px-2.5 py-2 rounded-md hover:bg-white/5 transition-colors text-left"
            data-file-id="<%= f._id %>" data-source="<%= group.source %>"
            data-original-name="<%= f.originalName %>" data-mimetype="<%= f.mimetype %>" data-thumb="<%= thumbUrl %>">
            <span class="badge-thumb badge-thumb-lg <%= isAudio ? 'badge-thumb-audio' : '' %>">
              <% if (isImage) { %>
              <img src="<%= thumbUrl %>" alt="" />
              <% } else if (isVideo) { %>
              <video src="<%= thumbUrl %>" muted preload="metadata"></video>
              <% } else if (isAudio) { %>
              <iconify-icon icon="material-symbols-light:music-note-2" width="18" height="18" style="color:#f59e0b;"></iconify-icon>
              <% } else { %>
              <iconify-icon icon="<%= attachmentIcon(f.mimetype) %>" width="18" height="18"></iconify-icon>
              <% } %>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block text-sm text-gray-300 truncate"><%= f.originalName %></span>
              <span class="block text-xs text-gray-600"><%= sizeLabel %></span>
            </span>
          </button>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="p-4 border-t border-white/5 shrink-0">
      <button type="button" id="attach-modal-done" class="w-full h-11 flex items-center justify-center bg-amber-400 hover:bg-amber-300 text-black text-sm font-bold rounded-md transition-colors">
        Done
      </button>
    </div>
  </div>
</div>

<!-- File viewer modal -->
<%
  const viewerFiles = (booking.uploadedFiles || []).map(f => ({
    storedName: f.storedName, originalName: f.originalName, mimetype: f.mimetype, size: f.size,
    url: '/dashboard/uploads/' + f.storedName,
  }));
%>
<div id="file-viewer-modal" class="hidden fixed inset-0 z-50 items-center justify-center p-6" style="background:rgba(0,0,0,0.88);backdrop-filter:blur(6px);"
  onclick="if (event.target === this) window.closeFileViewer()"
  data-files="<%- JSON.stringify(viewerFiles).replace(/"/g, '&quot;') %>">
  <div class="viewer-container">
    <div class="viewer-header">
      <span id="viewer-filename" class="viewer-filename"></span>
      <button type="button" onclick="window.closeFileViewer()" class="viewer-close-btn">
        <iconify-icon icon="material-symbols-light:close" width="20" height="20"></iconify-icon>
      </button>
    </div>
    <div class="viewer-body">
      <div class="viewer-player-wrap">
        <div id="viewer-player" class="viewer-player"></div>
        <div id="viewer-info-bar" class="viewer-info-bar"></div>
      </div>
      <div class="viewer-file-panel">
        <div class="viewer-file-panel-header">Project files</div>
        <div id="viewer-file-grid" class="viewer-file-grid"></div>
      </div>
    </div>
  </div>
</div>

<!-- Composer -->
<% const composerLocked = !booking.chatUnlocked; %>
<form id="composer" class="flex flex-col gap-2 px-5 py-4 border-t border-white/5 shrink-0" enctype="multipart/form-data" data-post-path="<%= postPath %>" data-attachment-base="<%= attachmentBasePath %>" data-my-role="<%= myRole %>">
  <div id="attachment-preview-list" class="hidden flex-wrap gap-2"></div>
  <div class="flex items-end gap-2">
    <button type="button" id="attach-btn" <%= composerLocked ? 'disabled' : '' %>
      class="h-12 w-12 flex items-center justify-center text-gray-300 hover:text-white bg-white/4 hover:bg-white/8 border border-white/10 rounded-md transition-colors shrink-0 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white/4 disabled:hover:text-gray-300">
      <iconify-icon icon="material-symbols-light:attach-file" width="20" height="20"></iconify-icon>
    </button>
    <input type="file" id="attachment-input" name="attachments" multiple class="hidden" <%= composerLocked ? 'disabled' : '' %> />
    <textarea id="body-input" rows="1" placeholder="<%= composerLocked ? 'Chat opens once this project is accepted.' : 'Write a message...' %>" <%= composerLocked ? 'disabled' : '' %>
      class="flex-1 h-12 bg-white/4 border border-white/10 rounded-md px-4 py-2.5 text-sm text-white outline-none resize-none disabled:opacity-40 disabled:cursor-not-allowed"
      style="max-height:120px;"></textarea>
    <button type="submit" <%= composerLocked ? 'disabled' : '' %>
      class="h-12 bg-amber-400 text-black text-sm font-bold px-4 py-2.5 rounded-md hover:bg-amber-300 transition-colors disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-amber-400">
      Send
    </button>
  </div>
</form>
