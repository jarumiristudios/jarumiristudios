<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Careers | Jarumiri Studios</title>
  <meta name="description" content="Join Jarumiri Studios — open roles for video editors and videographers, or send your work if you don't see an exact fit." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/iconify-icon@2/dist/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }
    .nav-link { position: relative; }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: #f59e0b;
      transition: width 0.25s ease;
    }
    .nav-link:hover::after { width: 100%; }
    .card-hover {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(245,158,11,0.12);
    }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased min-h-screen">

  <!-- NAVBAR -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-md bg-[#080808]/80">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="brand text-xl font-bold tracking-tight">
        <span class="text-white">Jarumiri</span> Studios<span class="text-amber-400">.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-gray-400 font-medium">
        <a href="/#services" class="nav-link hover:text-white transition-colors">Services</a>
        <a href="/#pricing"  class="nav-link hover:text-white transition-colors">Pricing</a>
        <a href="/#about"    class="nav-link hover:text-white transition-colors">About</a>
        <a href="/career"    class="nav-link hover:text-white transition-colors">Careers</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="/login"
           class="hidden md:inline-flex text-sm font-semibold px-5 py-3.5 rounded-full border border-white/15 text-white hover:border-white/40 transition-colors">
          Log In / Sign Up
        </a>
        <a href="/hire"
           class="text-sm font-semibold px-7 py-3.5 rounded-full bg-amber-400 text-black hover:bg-amber-300 transition-colors">
          Book A Project
        </a>
      </div>
    </nav>
  </header>

  <!-- ═══════════════════════════════ CAREERS ═══════════════════════════════ -->
  <main class="pt-32 pb-24 px-6 bg-[#0d0d0d]">
    <div class="max-w-6xl mx-auto">
      <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase mb-3">Join the Studio</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">We're looking for Talents</h1>
      <p class="text-gray-500 text-lg mb-16 max-w-xl">Having experiences in the adult industry ? Or simply, genuine passion for the craft ? There may be a place here for you.</p>

      <% if (roles.length === 0) { %>
      <p class="text-gray-500 text-sm mb-16">No open roles right now — reach out anyway below.</p>
      <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        <% roles.forEach(role => { %>
        <div class="p-7 rounded-2xl bg-white/[0.03] border border-white/8 card-hover flex flex-col gap-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-[10px] font-bold tracking-widest uppercase text-amber-400/70 border border-amber-400/20 rounded-full px-3 py-1">Open Role</span>
              <h3 class="font-bold text-white text-xl mt-4"><%= role.title %></h3>
            </div>
            <span class="text-3xl"><%= role.emoji %></span>
          </div>
          <p class="text-gray-500 text-sm leading-relaxed"><%= role.description %></p>
          <ul class="text-gray-500 text-sm space-y-2 mt-2">
            <% role.requirements.forEach(req => { %>
            <li class="flex gap-2"><span class="text-amber-400">✓</span> <%= req %></li>
            <% }) %>
          </ul>
          <button type="button" class="apply-btn text-sm font-semibold px-5 py-2.5 rounded-full bg-amber-400 text-black hover:bg-amber-300 transition-colors self-start mt-2"
            data-role-id="<%= role._id %>" data-role-title="<%= role.title %>">
            Apply
          </button>
        </div>
        <% }) %>
      </div>
      <% } %>

      <div class="p-8 rounded-2xl bg-amber-400/[0.05] border border-amber-400/15 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <p class="text-white font-semibold text-lg mb-1">Don't see your exact skill set listed?</p>
          <p class="text-gray-500 text-sm">Reach out anyway. If the work is strong, the conversation is worth having.</p>
        </div>
        <button type="button" class="apply-btn text-sm font-semibold px-6 py-3.5 rounded-full bg-amber-400 text-black hover:bg-amber-300 transition-colors shrink-0 whitespace-nowrap"
          data-role-id="" data-role-title="General Application">
          Send Your Work
        </button>
      </div>

    </div>
  </main>

  <!-- ═══════════════════════════════ FOOTER ═══════════════════════════════ -->
  <footer class="border-t border-white/5 bg-[#0a0a0a] py-12">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      <div>
        <a href="/" class="brand text-lg font-bold">
          <span class="text-white">Jarumiri Studios</span><span class="text-amber-400">.</span>
        </a>
        <p class="text-gray-600 text-sm mt-1">Precision editing for content creators.</p>
      </div>

      <div class="flex flex-wrap gap-6 text-sm text-gray-500">
        <a href="/#services" class="hover:text-white transition-colors">Services</a>
        <a href="/#pricing"  class="hover:text-white transition-colors">Pricing</a>
        <a href="/#about"    class="hover:text-white transition-colors">About</a>
        <a href="/career"    class="hover:text-white transition-colors">Careers</a>
        <a href="/terms"     class="hover:text-white transition-colors">Terms of Service</a>
      </div>

      <div class="text-sm text-gray-600">
        <p class="mt-1">&copy; 2026 Jarumiri Studios</p>
      </div>

    </div>
  </footer>

  <script>
    document.querySelectorAll('.apply-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        window.openApplicationModal(btn.dataset.roleId, btn.dataset.roleTitle);
      });
    });
  </script>

  <%- include('_toast') %>
  <%- include('_application-modal') %>

</body>
</html>
