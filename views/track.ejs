<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Track Your Request | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, .brand { font-family: 'Syne', sans-serif; }
    .nav-link { position: relative; }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: #f59e0b;
      transition: width 0.25s ease;
    }
    .nav-link:hover::after { width: 100%; }
    .form-input {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 14px 18px;
      color: #fff;
      font-size: 15px;
      font-family: 'Inter', sans-serif;
      outline: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .form-input:focus {
      border-color: rgba(245,158,11,0.5);
      box-shadow: 0 0 0 3px rgba(245,158,11,0.08);
    }
    .form-input::placeholder { color: #374151; letter-spacing: 0.1em; text-transform: uppercase; }
    button { cursor: pointer; }

    /* Status styles */
    .status-pill {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 6px 16px; border-radius: 999px;
    }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; }
    .s-pending   { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }
    .s-pending .status-dot   { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; animation: pulse 1.8s infinite; }
    .s-in-review { background: rgba(99,102,241,0.12);  color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }
    .s-in-review .status-dot { background: #818cf8; box-shadow: 0 0 6px #818cf8; animation: pulse 1.8s infinite; }
    .s-accepted  { background: rgba(34,197,94,0.12);   color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
    .s-accepted .status-dot  { background: #4ade80; }
    .s-declined  { background: rgba(239,68,68,0.12);   color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .s-declined .status-dot  { background: #f87171; }
    .s-paused    { background: rgba(167,139,250,0.12); color: #a78bfa; border: 1px solid rgba(167,139,250,0.25); }
    .s-paused .status-dot    { background: #a78bfa; }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }

    /* Timeline */
    .timeline-step { display: flex; gap: 16px; align-items: flex-start; }
    .timeline-icon {
      width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .timeline-icon.done    { background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.3); }
    .timeline-icon.current { background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.3); }
    .timeline-icon.future  { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }
    .timeline-line { width: 1px; height: 28px; margin-left: 15px; }
    .timeline-line.done   { background: rgba(245,158,11,0.3); }
    .timeline-line.future { background: rgba(255,255,255,0.06); }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased min-h-screen">

  <!-- NAVBAR -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-md bg-[#080808]/80">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="brand text-xl font-bold tracking-tight">
        <span class="text-white">Jarumiri</span> Studios<span class="text-amber-400">.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-gray-400 font-medium">
        <a href="/#services" class="nav-link hover:text-white transition-colors">Services</a>
        <a href="/#pricing"  class="nav-link hover:text-white transition-colors">Pricing</a>
        <a href="/#about"    class="nav-link hover:text-white transition-colors">About</a>
      </div>
      <a href="/hire" class="text-sm font-semibold px-7 py-3.5 rounded-full bg-amber-400 text-black hover:bg-amber-300 transition-colors">
        Book A Project
      </a>
    </nav>
  </header>

  <main class="pt-32 pb-20 px-6">
    <div class="max-w-lg mx-auto">

      <!-- Header -->
      <div class="mb-10">
        <p class="text-xs font-semibold tracking-widest text-amber-400 uppercase mb-3">Request tracker</p>
        <h1 class="text-4xl font-bold text-white mb-3">Track your project<span class="text-amber-400">.</span></h1>
        <p class="text-gray-400">Enter the BR code you received after submitting your booking.</p>
      </div>

      <!-- Lookup form -->
      <div id="code-form-wrap">
        <form action="/track" method="GET" class="flex gap-3 mb-3">
          <input
            class="form-input"
            type="text"
            name="code"
            placeholder="XXX-XXX-XXX"
            maxlength="11"
            value="<%= locals.code || '' %>"
            oninput="formatCRCode(this)"
          />
          <button type="submit"
            class="flex-shrink-0 px-6 py-3.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors whitespace-nowrap">
            Look up
          </button>
        </form>
        <p class="text-sm text-gray-600 mb-10">
          I don't remember the booking code.
          <button type="button" onclick="toggleMethod()" class="text-amber-400 hover:underline">Try another method</button>
        </p>
      </div>

      <!-- Alternate: name + email lookup -->
      <div id="identity-form-wrap" class="hidden mb-10">
        <form action="/track" method="GET" class="space-y-3">
          <input
            class="form-input"
            type="text"
            name="name"
            placeholder="Full name"
            value="<%= locals.name || '' %>"
            style="letter-spacing:normal;text-transform:none;"
          />
          <input
            class="form-input"
            type="email"
            name="email"
            placeholder="Email address"
            value="<%= locals.email || '' %>"
            style="letter-spacing:normal;text-transform:none;"
          />
          <button type="submit"
            class="w-full px-6 py-3.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors">
            Look up
          </button>
        </form>
        <p class="text-sm text-gray-600 mt-3">
          I have my BR code.
          <button type="button" onclick="toggleMethod()" class="text-amber-400 hover:underline">Use it instead</button>
        </p>
      </div>

      <% if (locals.searched) { %>

        <% if (!locals.booking) { %>
        <!-- Not found -->
        <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/8 text-center">
          <p class="text-2xl mb-3">🔍</p>
          <p class="text-white font-semibold mb-1">No request found</p>
          <p class="text-gray-500 text-sm">Double-check your BR code and try again.</p>
        </div>

        <% } else { %>
        <!-- Result -->
        <div class="space-y-5">

          <!-- Status card -->
          <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/8">
            <div class="flex items-start justify-between gap-4 mb-5">
              <div>
                <p class="text-xs font-semibold tracking-widest text-gray-500 uppercase mb-1">BR Code</p>
                <p class="font-mono text-amber-400 font-bold text-lg tracking-widest"><%= booking.crCode %></p>
              </div>
              <span class="status-pill s-<%= booking.status %>">
                <span class="status-dot"></span>
                <%= booking.status === 'in-review' ? 'In Review' : booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
              </span>
            </div>

            <!-- Timeline -->
            <%
              const steps = [
                { key: 'pending',   label: 'Request received',   desc: 'Your booking has been submitted successfully.' },
                { key: 'in-review', label: 'Under review',       desc: 'We\'re going through your brief and files.' },
                { key: 'accepted',  label: 'Project accepted',   desc: 'We\'ve accepted your project and will be in touch.' },
              ];
              const statusOrder = ['pending', 'in-review', 'accepted'];
              const currentIdx  = booking.status === 'declined' ? -1 : statusOrder.indexOf(booking.status);
            %>

            <% if (booking.status === 'declined') { %>
            <div class="pt-4 border-t border-white/5">
              <p class="text-red-400 text-sm font-medium mb-1">Request declined</p>
              <p class="text-gray-500 text-sm">Unfortunately we weren't able to take on this project. Feel free to <a href="https://t.me/jarumiri" class="text-amber-400 hover:underline">reach out on Telegram</a> to discuss alternatives.</p>
            </div>
            <% } else { %>
            <div class="pt-4 border-t border-white/5 space-y-0">
              <% steps.forEach((step, i) => {
                const isDone    = i < currentIdx;
                const isCurrent = i === currentIdx;
                const isFuture  = i > currentIdx;
              %>
              <div class="timeline-step">
                <div class="flex flex-col items-center">
                  <div class="timeline-icon <%= isDone ? 'done' : isCurrent ? 'current' : 'future' %>">
                    <% if (isDone) { %>
                      <svg width="14" height="11" viewBox="0 0 14 11" fill="none"><path d="M1 5.5l4 4 8-8" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <% } else if (isCurrent) { %>
                      <div style="width:8px;height:8px;border-radius:50%;background:#f59e0b;animation:pulse 1.8s infinite;"></div>
                    <% } else { %>
                      <div style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.1);"></div>
                    <% } %>
                  </div>
                  <% if (i < steps.length - 1) { %>
                  <div class="timeline-line <%= isDone ? 'done' : 'future' %>"></div>
                  <% } %>
                </div>
                <div class="pb-6 <%= i === steps.length - 1 ? 'pb-0' : '' %>">
                  <p class="text-sm font-semibold <%= isFuture ? 'text-gray-600' : 'text-white' %> leading-none mb-1" style="margin-top:6px;"><%= step.label %></p>
                  <% if (!isFuture) { %>
                  <p class="text-xs text-gray-500"><%= step.desc %></p>
                  <% } %>
                </div>
              </div>
              <% }) %>
            </div>
            <% if (booking.status === 'accepted' && booking.depositStatus === 'pending' && booking.depositDueDate) { %>
            <div class="pt-4 mt-4 border-t border-white/5">
              <p class="text-amber-400 text-sm font-medium mb-1">Deposit due by <%= new Date(booking.depositDueDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
              <p class="text-gray-500 text-sm mb-3">Pay the deposit invoice sent to your email to begin your project.</p>
              <% if (booking.depositInvoiceUrl) { %>
              <a href="<%= booking.depositInvoiceUrl %>" target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors">
                Pay deposit now
              </a>
              <% } %>
            </div>
            <% } %>
            <% if (booking.finalPaymentStatus === 'pending' && booking.finalDueDate) { %>
            <div class="pt-4 mt-4 border-t border-white/5">
              <p class="text-amber-400 text-sm font-medium mb-1">Final payment due by <%= new Date(booking.finalDueDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
              <p class="text-gray-500 text-sm mb-3">Pay the final invoice sent to your email to complete your project. The link is voided if it passes unpaid.</p>
              <% if (booking.finalInvoiceUrl) { %>
              <a href="<%= booking.finalInvoiceUrl %>" target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors">
                Pay final invoice now
              </a>
              <% } %>
            </div>
            <% } %>
            <% } %>
          </div>

          <!-- Final deliverables -->
          <% if (booking.deliverablesUnlocked && booking.deliverableFiles && booking.deliverableFiles.length > 0) { %>
          <div class="p-6 rounded-2xl bg-white/[0.03] border border-amber-400/20">
            <h2 class="text-sm font-semibold text-white mb-1">Final deliverables</h2>
            <p class="text-gray-500 text-xs mb-4">Your finished files are ready to download.</p>
            <div class="space-y-2">
              <% booking.deliverableFiles.forEach(f => {
                const url = '/track/' + booking.crCode + '/deliverables/' + f.storedName;
                const sizeLabel = f.size < 1024*1024 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1024/1024).toFixed(1)+' MB';
              %>
              <div class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl bg-white/[0.03] border border-white/8">
                <span class="text-gray-300 text-sm truncate"><%= f.originalName %></span>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-gray-600 text-xs"><%= sizeLabel %></span>
                  <a href="<%= url %>" download="<%= f.originalName %>"
                    class="text-xs font-semibold text-amber-400 hover:text-amber-300 transition-colors px-3 py-1.5 rounded-full border border-amber-400/30 hover:border-amber-400/60 whitespace-nowrap">
                    Download
                  </a>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Project summary -->
          <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/8">
            <h2 class="text-sm font-semibold text-white mb-4">Your request</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Services</p>
                <p class="text-gray-300"><%= booking.serviceType.join(', ') %></p>
              </div>
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Package</p>
                <p class="text-gray-300">
                  <%= booking.pricingTier %>
                  <% if (booking.pricingTier === 'Custom' && booking.budget) { %>
                  <span class="text-amber-400">(<%= booking.budget %>)</span>
                  <% } %>
                </p>
              </div>
              <% if (booking.addOns && booking.addOns.length > 0) { %>
              <div class="col-span-2">
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Add-ons</p>
                <p class="text-gray-300"><%= booking.addOns.join(' · ') %></p>
              </div>
              <% } %>
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Submitted</p>
                <p class="text-gray-300"><%= new Date(booking.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></p>
              </div>
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Name</p>
                <p class="text-gray-300"><%= booking.name %></p>
              </div>
              <% if (booking.deliveryDate) { %>
              <div class="col-span-2">
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Estimated delivery</p>
                <p class="text-amber-400 font-medium"><%= new Date(booking.deliveryDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></p>
              </div>
              <% } %>
            </div>
          </div>

          <!-- Contact nudge -->
          <p class="text-center text-sm text-gray-600">
            Questions? <a href="https://t.me/jarumiri" target="_blank" class="text-amber-400 hover:underline">Reach us on Telegram</a>
          </p>

        </div>
        <% } %>

      <% } %>

    </div>
  </main>

  <script>
    function formatCRCode(input) {
      let v = input.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
      if (v.length > 3)  v = v.slice(0,3) + '-' + v.slice(3);
      if (v.length > 7)  v = v.slice(0,7) + '-' + v.slice(7);
      if (v.length > 11) v = v.slice(0,11);
      input.value = v;
    }

    function toggleMethod() {
      document.getElementById('code-form-wrap').classList.toggle('hidden');
      document.getElementById('identity-form-wrap').classList.toggle('hidden');
    }

    <% if (locals.method === 'identity') { %>
    toggleMethod();
    <% } %>
  </script>

</body>
</html>
