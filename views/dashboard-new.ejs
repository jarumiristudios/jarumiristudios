<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Project | Jarumiri Studios</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎬</text></svg>" />
  <link rel="stylesheet" href="/output.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, .brand { font-family: 'Syne', sans-serif; }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; min-height: 40px; border-radius: 6px;
      font-size: 13.5px; color: #6b7280; font-weight: 500;
      text-decoration: none; transition: all 0.15s;
    }
    .sidebar-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.active { color: #f59e0b; background: rgba(245,158,11,0.08); }
    .sidebar-link.back-link:hover { color: #e5e7eb; background: rgba(255,255,255,0.045); }
    .sidebar-link.danger:hover { color: #f87171; background: rgba(239,68,68,0.06); }

    .step-dot {
      width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 600; transition: all 0.25s;
    }
    .step-dot.active   { background: #f59e0b; color: #000; }
    .step-dot.done     { background: #f59e0b; color: #000; }
    .step-dot.inactive { background: rgba(255,255,255,0.06); color: #6b7280; border: 1px solid rgba(255,255,255,0.08); }
    .step-line { flex: 1; height: 1px; background: rgba(255,255,255,0.08); margin-top: 13px; }
    .step-line.done { background: #f59e0b; }

    .form-input {
      width: 100%; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      padding: 13px 16px; color: #fff; font-size: 14px;
      font-family: 'Inter', sans-serif; outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .form-input:focus { border-color: rgba(245,158,11,0.5); box-shadow: 0 0 0 3px rgba(245,158,11,0.07); }
    .form-input::placeholder { color: #4b5563; }
    textarea.form-input { resize: none; min-height: 120px; }
    .form-label { display: block; font-size: 13px; font-weight: 500; color: #9ca3af; margin-bottom: 8px; }
    .form-input.error { border-color: rgba(239,68,68,0.5); }
    .field-error { font-size: 12px; color: #ef4444; margin-top: 5px; }

    .drop-zone {
      border: 2px dashed rgba(255,255,255,0.1); border-radius: 6px;
      padding: 36px 24px; text-align: center; cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: rgba(245,158,11,0.5); background: rgba(245,158,11,0.03);
    }
    .drop-zone input[type="file"] { display: none; }

    .file-item {
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px; padding: 11px 14px; font-size: 13px;
    }

    .step-panel { display: none; }
    .step-panel.active { display: block; }

    .custom-select { position: relative; }
    .custom-select-trigger {
      width: 100%; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      padding: 13px 16px; color: #9ca3af; font-size: 14px;
      font-family: 'Inter', sans-serif;
      display: flex; align-items: center; justify-content: space-between;
      cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s;
      text-align: left; outline: none;
    }
    .custom-select-trigger.selected { color: #fff; }
    .custom-select-trigger.open,
    .custom-select-trigger:focus { border-color: rgba(245,158,11,0.5); box-shadow: 0 0 0 3px rgba(245,158,11,0.07); }
    .custom-select-trigger.error { border-color: rgba(239,68,68,0.5); }
    .custom-select-chevron { flex-shrink: 0; width: 15px; height: 15px; color: #6b7280; transition: transform 0.2s; }
    .custom-select-trigger.open .custom-select-chevron { transform: rotate(180deg); }
    .custom-select-menu {
      display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0;
      background: #111; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px;
      overflow: hidden; z-index: 100; box-shadow: 0 20px 40px rgba(0,0,0,0.6);
    }
    .custom-select-menu.open { display: block; }
    .custom-select-option {
      padding: 12px 16px; cursor: pointer; transition: background 0.15s;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .custom-select-option:last-child { border-bottom: none; }
    .custom-select-option:hover { background: rgba(245,158,11,0.08); }
    .custom-select-option.active { background: rgba(245,158,11,0.12); }
    .custom-select-option .opt-label { font-size: 14px; color: #fff; font-weight: 500; }
    .custom-select-option .opt-desc  { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .custom-select-option .opt-check {
      width: 17px; height: 17px; flex-shrink: 0; border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, border-color 0.15s;
    }
    .custom-select-option.active .opt-check { background: #f59e0b; border-color: #f59e0b; }

    .price-estimate { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; padding: 18px 20px; }
  </style>
</head>
<body class="bg-[#080808] text-gray-100 antialiased">

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 bg-[#0d0d0d] border-b border-white/5 flex items-center justify-between px-4">
    <span class="brand text-[15px] font-bold text-white">Jarumiri<span class="text-amber-400">.</span></span>
    <button onclick="toggleSidebar()" class="text-gray-500 hover:text-white transition-colors p-1.5">
      <iconify-icon icon="material-symbols-light:menu" width="22" height="22"></iconify-icon>
    </button>
  </header>

  <div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-30 hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-screen w-[220px] bg-[#0d0d0d] border-r border-white/5 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="h-[65px] flex items-center px-5 border-b border-white/5 shrink-0">
      <span class="brand text-[15px] font-bold text-white">Jarumiri Studios<span class="text-amber-400">.</span></span>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/dashboard" class="sidebar-link back-link">
        <iconify-icon icon="material-symbols-light:grid-view" width="20" height="20"></iconify-icon>
        Overview
      </a>
      <a href="/dashboard/gallery" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:photo-library" width="20" height="20"></iconify-icon>
        Gallery
      </a>
      <a href="/dashboard/notifications" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:notifications" width="20" height="20"></iconify-icon>
        <span class="flex-1">Notifications</span>
        <% if (locals.unreadCount > 0) { %>
        <span style="display:flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 4px;border-radius:9999px;background:#f59e0b;color:#000;font-size:10px;font-weight:700;"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/dashboard/invoices" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:receipt-long-outline" width="20" height="20"></iconify-icon>
        Invoices
      </a>
      <a href="/dashboard/account" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:person" width="20" height="20"></iconify-icon>
        Account
      </a>
    </nav>

    <div class="px-3 pb-4 border-t border-white/5 shrink-0 space-y-1">
      <a href="/dashboard/new"
        class="flex items-center gap-2.5 w-full px-3 min-h-10 rounded-md bg-amber-400 text-black text-[13.5px] font-bold hover:bg-amber-300 transition-colors">
        <iconify-icon icon="material-symbols-light:add" width="20" height="20"></iconify-icon>
        New project
      </a>
      <a href="https://t.me/jarumiri" target="_blank" class="sidebar-link">
        <iconify-icon icon="material-symbols-light:forum" width="20" height="20"></iconify-icon>
        Support
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="lg:ml-[220px] min-h-screen">
    <div class="lg:hidden h-14"></div>

    <main class="max-w-[680px] mx-auto px-5 py-10">

      <!-- Page header -->
      <div class="mb-8">
        <h1 class="text-xl font-bold text-white">New project</h1>
        <p class="text-gray-600 text-sm mt-0.5">Tell us what you need — we'll handle the rest.</p>
      </div>

      <% if (!profileComplete) { %>
      <!-- ── Profile gate ── -->
      <div class="rounded-md border border-white/10 bg-white/[0.02] p-6">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-9 h-9 rounded-md bg-amber-400/10 border border-amber-400/20 flex items-center justify-center shrink-0">
            <iconify-icon icon="material-symbols-light:person" width="18" height="18" class="text-amber-400"></iconify-icon>
          </div>
          <div>
            <h2 class="text-sm font-semibold text-white mb-1">We need a few details first</h2>
            <p class="text-sm text-gray-500">We require basic information about you before you can book a project. This is stored on your account and won't be asked again.</p>
          </div>
        </div>

        <form action="/dashboard/account/profile?next=/dashboard/new" method="POST" novalidate class="space-y-4">
          <div>
            <label class="form-label" for="profile-name">Full name <span class="text-amber-400">*</span></label>
            <input class="form-input" type="text" id="profile-name" name="name" placeholder="Your name" autocomplete="name" required />
          </div>
          <div>
            <label class="form-label" for="profile-location">Location <span class="text-amber-400">*</span></label>
            <input class="form-input" type="text" id="profile-location" name="location" placeholder="City, Country" autocomplete="country-name" required />
          </div>
          <div>
            <label class="form-label" for="profile-telegram">Telegram <span class="text-gray-600 font-normal">(optional — for large file transfers)</span></label>
            <input class="form-input" type="text" id="profile-telegram" name="telegramHandle" placeholder="@username" />
          </div>
          <div class="pt-2">
            <button type="submit"
              class="px-6 py-2.5 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors">
              Save & continue →
            </button>
          </div>
        </form>
      </div>

      <% } else { %>
      <!-- ── Identity strip + Step indicator + Form ── -->

      <!-- Identity strip -->
      <div class="flex items-center gap-2.5 mb-7 px-4 py-3 rounded-md bg-white/[0.025] border border-white/8">
        <iconify-icon icon="material-symbols-light:person" width="16" height="16" class="text-amber-400 shrink-0"></iconify-icon>
        <p class="text-sm text-gray-400">Submitting as <span class="text-white font-medium"><%= user.email %></span></p>
        <a href="/dashboard/account" class="ml-auto text-xs text-gray-600 hover:text-gray-400 transition-colors">Edit profile</a>
      </div>

      <!-- Step indicator -->
      <div class="flex items-start gap-2 mb-8">
        <div class="flex flex-col items-center gap-1.5">
          <div class="step-dot active" id="dot-1">1</div>
          <span class="text-[10px] text-gray-500 font-medium uppercase tracking-wide">Project</span>
        </div>
        <div class="step-line" id="line-1"></div>
        <div class="flex flex-col items-center gap-1.5">
          <div class="step-dot inactive" id="dot-2">2</div>
          <span class="text-[10px] text-gray-500 font-medium uppercase tracking-wide">Files</span>
        </div>
      </div>

      <!-- FORM — contact info from user profile, no re-asking -->
      <form id="booking-form" action="/hire" method="POST" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="name"           value="<%= user.name %>" />
        <input type="hidden" name="email"          value="<%= user.email %>" />
        <input type="hidden" name="location"       value="<%= user.location %>" />
        <input type="hidden" name="telegramHandle" value="<%= user.telegramHandle || '' %>" />

        <!-- ── Step 1: Project Details ── -->
        <div class="step-panel active" id="step-1">
          <div class="space-y-5">

            <!-- Package -->
            <div>
              <label class="form-label">Package <span class="text-amber-400">*</span></label>
              <input type="hidden" id="pricingTier" name="pricingTier" value="" />
              <div class="custom-select" id="cs-tier">
                <button type="button" class="custom-select-trigger" id="cs-tier-trigger" onclick="toggleDropdown('cs-tier')" aria-haspopup="listbox" aria-expanded="false">
                  <span id="cs-tier-label">Select a package</span>
                  <iconify-icon class="custom-select-chevron" icon="material-symbols-light:keyboard-arrow-down"></iconify-icon>
                </button>
                <div class="custom-select-menu" id="cs-tier-menu" role="listbox">
                  <div class="custom-select-option" onclick="selectOption('cs-tier','Clip','Clip — $79')" role="option" data-value="Clip">
                    <p class="opt-label">Clip <span class="text-amber-400 font-bold">$79</span></p>
                    <p class="opt-desc">Up to 4 min · Color correction · Music sync · 2 revisions · 3-day delivery</p>
                  </div>
                  <div class="custom-select-option" onclick="selectOption('cs-tier','Scene','Scene — $189')" role="option" data-value="Scene">
                    <p class="opt-label">Scene <span class="text-amber-400 font-bold">$189</span> <span class="text-[10px] font-bold tracking-widest uppercase bg-amber-400 text-black px-2 py-0.5 rounded-full ml-1">Popular</span></p>
                    <p class="opt-desc">Up to 20 min · Full color grade · Sound mix · Basic titles · 3 revisions · 6 days</p>
                  </div>
                  <div class="custom-select-option" onclick="selectOption('cs-tier','Feature','Feature — $399')" role="option" data-value="Feature">
                    <p class="opt-label">Feature <span class="text-amber-400 font-bold">$399</span></p>
                    <p class="opt-desc">Unlimited / multi-part · Custom LUT · Sound design · Motion graphics · 4 revisions · 10 days</p>
                  </div>
                  <div class="custom-select-option" onclick="selectOption('cs-tier','Custom','Custom budget')" role="option" data-value="Custom">
                    <p class="opt-label">Custom <span class="text-gray-400 font-normal text-sm">— name your budget</span></p>
                    <p class="opt-desc">Tell us what you have in mind and we'll work something out</p>
                  </div>
                  <div style="padding:12px 16px;border-top:1px solid rgba(255,255,255,0.06);">
                    <p style="font-size:11px;color:#6b7280;line-height:1.5;">Prices may vary based on project complexity and queue.</p>
                  </div>
                  <div style="padding:8px 12px;border-top:1px solid rgba(255,255,255,0.06);">
                    <button type="button" onclick="closeAllDropdowns()" style="width:100%;padding:7px;border-radius:6px;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25);color:#f59e0b;font-size:12px;font-weight:600;cursor:pointer;">Done</button>
                  </div>
                </div>
              </div>
              <p class="field-error hidden" id="err-tier">Please select a package.</p>
            </div>

            <!-- Budget (Custom only) -->
            <div id="budget-field" class="hidden">
              <label class="form-label" for="budget">Your budget <span class="text-amber-400">*</span></label>
              <input class="form-input" type="text" id="budget" name="budget" placeholder="e.g. $80, $200, open to suggestions…" />
              <p class="field-error hidden" id="err-budget">Please enter your budget.</p>
            </div>

            <!-- Service type -->
            <div>
              <label class="form-label">Service <span class="text-amber-400">*</span> <span class="text-gray-500 font-normal">(select all that apply)</span></label>
              <div id="service-hidden-inputs"></div>
              <div class="custom-select" id="cs-service">
                <button type="button" class="custom-select-trigger" id="cs-service-trigger" onclick="toggleDropdown('cs-service')" aria-haspopup="listbox" aria-expanded="false">
                  <span id="cs-service-label">Select services</span>
                  <iconify-icon class="custom-select-chevron" icon="material-symbols-light:keyboard-arrow-down"></iconify-icon>
                </button>
                <div class="custom-select-menu" id="cs-service-menu" role="listbox" aria-multiselectable="true">
                  <div class="custom-select-option" onclick="toggleService('Video Editing')" role="option" data-value="Video Editing">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Video Editing</p><p class="opt-desc">Cuts, transitions, pacing, and timeline assembly</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleService('Color Grading')" role="option" data-value="Color Grading">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Color Grading</p><p class="opt-desc">LUT creation, skin tone correction, cinematic look</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleService('Sound Design')" role="option" data-value="Sound Design">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Sound Design</p><p class="opt-desc">Audio mix, music sync, SFX, noise removal</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleService('Motion Graphics')" role="option" data-value="Motion Graphics">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Motion Graphics</p><p class="opt-desc">Animated titles, overlays, lower thirds, intros</p></div>
                    </div>
                  </div>
                  <div style="padding:8px 12px;border-top:1px solid rgba(255,255,255,0.06);">
                    <button type="button" onclick="closeAllDropdowns()" style="width:100%;padding:7px;border-radius:6px;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25);color:#f59e0b;font-size:12px;font-weight:600;cursor:pointer;">Done</button>
                  </div>
                </div>
              </div>
              <p class="field-error hidden" id="err-service">Please select at least one service.</p>
            </div>

            <!-- Add-ons -->
            <div>
              <label class="form-label">Add-ons <span class="text-gray-500 font-normal">(optional)</span></label>
              <div id="addon-hidden-inputs"></div>
              <div class="custom-select" id="cs-addon">
                <button type="button" class="custom-select-trigger" id="cs-addon-trigger" onclick="toggleDropdown('cs-addon')" aria-haspopup="listbox" aria-expanded="false">
                  <span id="cs-addon-label">Select add-ons</span>
                  <iconify-icon class="custom-select-chevron" icon="material-symbols-light:keyboard-arrow-down"></iconify-icon>
                </button>
                <div class="custom-select-menu" id="cs-addon-menu" role="listbox" aria-multiselectable="true">
                  <div class="custom-select-option" onclick="toggleAddon('Rush delivery')" role="option" data-value="Rush delivery">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Rush delivery <span class="text-amber-400 font-bold text-xs ml-1">+$50</span></p><p class="opt-desc">Shave 2 days off your turnaround</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleAddon('Platform cut')" role="option" data-value="Platform cut">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Platform cut <span class="text-amber-400 font-bold text-xs ml-1">+$30</span></p><p class="opt-desc">Portrait or square crop per variant</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleAddon('Captions')" role="option" data-value="Captions">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Captions / subtitles <span class="text-amber-400 font-bold text-xs ml-1">+$35</span></p><p class="opt-desc">Burned-in or separate file</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleAddon('Censored preview')" role="option" data-value="Censored preview">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Censored preview <span class="text-amber-400 font-bold text-xs ml-1">+$45</span></p><p class="opt-desc">Blurred version for social promos</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleAddon('Intro/outro bumper')" role="option" data-value="Intro/outro bumper">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Intro / outro bumper <span class="text-amber-400 font-bold text-xs ml-1">+$75</span></p><p class="opt-desc">Custom animated brand bumper</p></div>
                    </div>
                  </div>
                  <div class="custom-select-option" onclick="toggleAddon('Extra revision')" role="option" data-value="Extra revision">
                    <div style="display:flex;align-items:flex-start;gap:12px;">
                      <div class="opt-check" style="margin-top:2px;"><iconify-icon icon="material-symbols-light:check" style="color:#000;font-size:10px;"></iconify-icon></div>
                      <div><p class="opt-label">Extra revision round <span class="text-amber-400 font-bold text-xs ml-1">+$30</span></p><p class="opt-desc">One additional consolidated batch of notes</p></div>
                    </div>
                  </div>
                  <div style="padding:8px 12px;border-top:1px solid rgba(255,255,255,0.06);">
                    <button type="button" onclick="closeAllDropdowns()" style="width:100%;padding:7px;border-radius:6px;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.25);color:#f59e0b;font-size:12px;font-weight:600;cursor:pointer;">Done</button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Coupon -->
            <div>
              <label class="form-label">Coupon code <span class="text-gray-500 font-normal">(optional)</span></label>
              <input type="hidden" id="couponCode" name="couponCode" value="" />
              <div class="flex gap-2">
                <input class="form-input" type="text" id="coupon-input" placeholder="e.g. LAUNCH20" autocomplete="off" style="text-transform:uppercase;" />
                <button type="button" onclick="applyCoupon()"
                  class="shrink-0 px-5 py-3 rounded-md bg-white/5 border border-white/10 text-sm font-semibold text-gray-300 hover:text-white hover:border-white/25 transition-colors">
                  Apply
                </button>
              </div>
              <p id="coupon-msg" class="text-xs mt-2 hidden"></p>
            </div>

            <!-- Project brief -->
            <div>
              <label class="form-label" for="projectBrief">Project brief <span class="text-amber-400">*</span></label>
              <textarea class="form-input" id="projectBrief" name="projectBrief" rows="5"
                placeholder="Describe what you need — style, mood, reference clips, delivery format, deadlines, anything relevant…"></textarea>
              <p class="field-error hidden" id="err-brief">Please describe your project.</p>
            </div>

          </div>

          <!-- Price estimate -->
          <div id="price-estimate" class="hidden mt-5 price-estimate">
            <p class="text-xs font-semibold tracking-widest text-gray-600 uppercase mb-3">Estimated total</p>
            <div id="estimate-lines" class="space-y-1.5 mb-3"></div>
            <div class="border-t border-white/8 pt-3 flex items-baseline justify-between">
              <span class="text-sm text-gray-400">Total</span>
              <span id="estimate-total" class="text-xl font-bold text-white"></span>
            </div>
            <p class="text-xs text-gray-500 mt-2">Final price may vary based on project scope and complexity.</p>
          </div>

          <div class="mt-7 flex justify-end">
            <button type="button" onclick="goToStep(2)"
              class="px-7 py-3 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors">
              Continue →
            </button>
          </div>
        </div>

        <!-- ── Step 2: Files & Links ── -->
        <div class="step-panel" id="step-2">
          <div class="space-y-6">

            <div>
              <label class="form-label">Upload files <span class="text-gray-500 font-normal">(video, audio, photo — max 250 MB each)</span></label>
              <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
                <input type="file" id="file-input" name="files" multiple accept="video/*,audio/*,image/*,.zip,.rar" />
                <div id="drop-placeholder">
                  <iconify-icon icon="material-symbols-light:cloud-upload" width="36" height="36" class="text-gray-600 mx-auto mb-3" style="display:block;"></iconify-icon>
                  <p class="text-sm text-gray-500 mb-1">Drag & drop or <span class="text-amber-400">click to browse</span></p>
                  <p class="text-xs text-gray-600">Video, audio, image, ZIP / RAR — 250 MB per file</p>
                </div>
              </div>
              <div id="file-list" class="mt-3 space-y-2"></div>
              <p class="field-error hidden" id="err-files"></p>
            </div>

            <div>
              <label class="form-label">Media links <span class="text-gray-500 font-normal">(YouTube, Drive, Dropbox — optional)</span></label>
              <div class="flex gap-2">
                <input class="form-input" type="url" id="link-input" placeholder="https://drive.google.com/…" />
                <button type="button" onclick="addLink()"
                  class="shrink-0 w-11 h-11 rounded-md bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-white/25 transition-colors flex items-center justify-center text-lg font-light" style="margin-top:1px;">+</button>
              </div>
              <p class="field-error hidden mt-1" id="err-link">Please enter a valid URL.</p>
              <div id="link-tags" class="mt-3 flex flex-wrap gap-2"></div>
              <div id="link-hidden-inputs"></div>
            </div>

          </div>

          <div class="mt-7 flex justify-between">
            <button type="button" onclick="goToStep(1)"
              class="px-6 py-3 rounded-full border border-white/15 text-white text-sm font-semibold hover:border-white/35 transition-colors">
              ← Back
            </button>
            <button type="submit" id="submit-btn"
              class="px-7 py-3 rounded-full bg-amber-400 text-black text-sm font-semibold hover:bg-amber-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
              <span id="submit-label">Submit project</span>
              <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>
          </div>
        </div>

      </form>
      <% } %>

    </main>
  </div>

  <script>
    // Only run form logic when the booking form is present (profile complete)
    if (document.getElementById('booking-form')) {
    let currentStep = 1;

    function goToStep(next) {
      if (next > currentStep && !validateStep(currentStep)) return;

      document.getElementById(`step-${currentStep}`).classList.remove('active');
      document.getElementById(`dot-${currentStep}`).className = next > currentStep ? 'step-dot done' : 'step-dot inactive';

      currentStep = next;

      document.getElementById(`step-${currentStep}`).classList.add('active');
      document.getElementById(`dot-${currentStep}`).className = 'step-dot active';

      const line = document.getElementById('line-1');
      if (line) line.className = currentStep > 1 ? 'step-line done' : 'step-line';

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function validateStep(step) {
      let ok = true;
      if (step === 1) {
        const tier  = document.getElementById('pricingTier').value;
        const brief = document.getElementById('projectBrief');

        const svcTrigger  = document.getElementById('cs-service-trigger');
        const tierTrigger = document.getElementById('cs-tier-trigger');

        if (!selectedServices.length) {
          svcTrigger.classList.add('error');
          document.getElementById('err-service').classList.remove('hidden');
          ok = false;
        } else {
          svcTrigger.classList.remove('error');
          document.getElementById('err-service').classList.add('hidden');
        }

        if (!tier) {
          tierTrigger.classList.add('error');
          document.getElementById('err-tier').classList.remove('hidden');
          ok = false;
        } else {
          tierTrigger.classList.remove('error');
          document.getElementById('err-tier').classList.add('hidden');
        }

        if (tier === 'Custom') {
          const budget = document.getElementById('budget');
          if (!budget.value.trim()) {
            budget.classList.add('error');
            document.getElementById('err-budget').classList.remove('hidden');
            ok = false;
          } else {
            budget.classList.remove('error');
            document.getElementById('err-budget').classList.add('hidden');
          }
        }

        if (!brief.value.trim()) {
          brief.classList.add('error');
          document.getElementById('err-brief').classList.remove('hidden');
          ok = false;
        } else {
          brief.classList.remove('error');
          document.getElementById('err-brief').classList.add('hidden');
        }

        const couponInput  = document.getElementById('coupon-input');
        const couponHidden = document.getElementById('couponCode');
        const couponMsg    = document.getElementById('coupon-msg');
        if (couponInput?.value.trim() && !couponHidden?.value) {
          couponMsg.className = 'text-xs mt-2 text-amber-400';
          couponMsg.textContent = 'Click Apply to validate your coupon before continuing.';
          ok = false;
        }
      }
      return ok;
    }

    // ── File upload ──
    const dropZone  = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');
    const fileList  = document.getElementById('file-list');
    const MAX_SIZE  = 250 * 1024 * 1024;
    let selectedFiles = [];

    dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault(); dropZone.classList.remove('drag-over'); addFiles(e.dataTransfer.files);
    });
    fileInput.addEventListener('change', () => addFiles(fileInput.files));

    function addFiles(incoming) {
      const errEl = document.getElementById('err-files');
      errEl.classList.add('hidden');
      let tooLarge = [];
      Array.from(incoming).forEach(f => {
        if (f.size > MAX_SIZE) { tooLarge.push(f.name); return; }
        if (!selectedFiles.find(x => x.name === f.name && x.size === f.size)) selectedFiles.push(f);
      });
      if (tooLarge.length) {
        errEl.textContent = `File(s) exceed 250 MB: ${tooLarge.join(', ')}`;
        errEl.classList.remove('hidden');
      }
      rebuildFileInput(); renderFileList();
    }

    function removeFile(idx) { selectedFiles.splice(idx, 1); rebuildFileInput(); renderFileList(); }

    function rebuildFileInput() {
      const dt = new DataTransfer();
      selectedFiles.forEach(f => dt.items.add(f));
      fileInput.files = dt.files;
    }

    function renderFileList() {
      fileList.innerHTML = '';
      selectedFiles.forEach((f, i) => {
        const size = f.size < 1048576 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1048576).toFixed(1)+' MB';
        fileList.innerHTML += `
          <div class="file-item">
            <div class="flex items-center gap-3 min-w-0">
              <iconify-icon icon="material-symbols-light:attach-file" width="16" height="16" style="color:#f59e0b;flex-shrink:0;"></iconify-icon>
              <span class="text-gray-300 truncate">${f.name}</span>
            </div>
            <div class="flex items-center gap-4 flex-shrink-0 ml-4">
              <span class="text-gray-500 text-xs">${size}</span>
              <button type="button" onclick="removeFile(${i})" class="text-gray-500 hover:text-red-400 transition-colors text-lg leading-none">×</button>
            </div>
          </div>`;
      });
    }

    // ── Media links ──
    let mediaLinks = [];

    function addLink() {
      const input = document.getElementById('link-input');
      const errEl = document.getElementById('err-link');
      const url   = input.value.trim();
      try { new URL(url); } catch { errEl.classList.remove('hidden'); return; }
      errEl.classList.add('hidden');
      if (mediaLinks.includes(url)) { input.value = ''; return; }
      mediaLinks.push(url); input.value = ''; renderLinkTags();
    }

    function removeLink(idx) { mediaLinks.splice(idx, 1); renderLinkTags(); }

    function renderLinkTags() {
      const tags   = document.getElementById('link-tags');
      const hidden = document.getElementById('link-hidden-inputs');
      tags.innerHTML = ''; hidden.innerHTML = '';
      mediaLinks.forEach((url, i) => {
        const label = url.replace(/^https?:\/\//, '');
        tags.innerHTML += `
          <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;padding:6px 12px;max-width:100%;">
            <a href="${url}" target="_blank" rel="noopener" style="font-size:13px;color:#f59e0b;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:260px;" title="${url}">${label}</a>
            <button type="button" onclick="removeLink(${i})" style="color:#6b7280;font-size:16px;line-height:1;background:none;border:none;cursor:pointer;flex-shrink:0;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#6b7280'">×</button>
          </div>`;
        const inp = document.createElement('input');
        inp.type = 'hidden'; inp.name = 'mediaLinks'; inp.value = url;
        hidden.appendChild(inp);
      });
    }

    document.getElementById('link-input')?.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); addLink(); }
    });

    // ── Custom dropdowns ──
    let selectedServices = [];
    let selectedAddons   = [];

    function toggleDropdown(id) {
      const trigger = document.getElementById(`${id}-trigger`);
      const menu    = document.getElementById(`${id}-menu`);
      const isOpen  = menu.classList.contains('open');
      closeAllDropdowns();
      if (!isOpen) {
        menu.classList.add('open');
        trigger.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    }

    function closeAllDropdowns() {
      document.querySelectorAll('.custom-select-menu.open').forEach(m => {
        m.classList.remove('open');
        m.previousElementSibling.classList.remove('open');
        m.previousElementSibling.setAttribute('aria-expanded', 'false');
      });
    }

    function toggleService(value) {
      const idx = selectedServices.indexOf(value);
      if (idx === -1) selectedServices.push(value); else selectedServices.splice(idx, 1);
      document.querySelectorAll('#cs-service-menu .custom-select-option').forEach(opt => {
        opt.classList.toggle('active', selectedServices.includes(opt.dataset.value));
      });
      const label   = document.getElementById('cs-service-label');
      const trigger = document.getElementById('cs-service-trigger');
      if (selectedServices.length === 0) { label.textContent = 'Select services'; trigger.classList.remove('selected'); }
      else { label.textContent = selectedServices.join(', '); trigger.classList.add('selected'); trigger.classList.remove('error'); document.getElementById('err-service').classList.add('hidden'); }
      const container = document.getElementById('service-hidden-inputs');
      container.innerHTML = '';
      selectedServices.forEach(s => { const inp = document.createElement('input'); inp.type='hidden'; inp.name='serviceType'; inp.value=s; container.appendChild(inp); });
    }

    function toggleAddon(value) {
      const idx = selectedAddons.indexOf(value);
      if (idx === -1) selectedAddons.push(value); else selectedAddons.splice(idx, 1);
      document.querySelectorAll('#cs-addon-menu .custom-select-option').forEach(opt => {
        opt.classList.toggle('active', selectedAddons.includes(opt.dataset.value));
      });
      const label   = document.getElementById('cs-addon-label');
      const trigger = document.getElementById('cs-addon-trigger');
      if (selectedAddons.length === 0) { label.textContent = 'Select add-ons'; trigger.classList.remove('selected'); }
      else { label.textContent = selectedAddons.join(', '); trigger.classList.add('selected'); }
      const container = document.getElementById('addon-hidden-inputs');
      container.innerHTML = '';
      selectedAddons.forEach(a => { const inp = document.createElement('input'); inp.type='hidden'; inp.name='addOns'; inp.value=a; container.appendChild(inp); });
      updateEstimate();
    }

    // ── Price estimate ──
    const TIER_PRICES  = { Clip: 79, Scene: 189, Feature: 399 };
    const ADDON_PRICES = { 'Rush delivery': 50, 'Platform cut': 30, 'Captions': 35, 'Censored preview': 45, 'Intro/outro bumper': 75, 'Extra revision': 30 };
    let appliedCoupon = null;

    function updateEstimate() {
      const tier  = document.getElementById('pricingTier').value;
      const box   = document.getElementById('price-estimate');
      const lines = document.getElementById('estimate-lines');
      const total = document.getElementById('estimate-total');
      if (!tier || tier === 'Custom') { box.classList.add('hidden'); return; }
      const base     = TIER_PRICES[tier] ?? 0;
      const addons   = selectedAddons.filter(a => ADDON_PRICES[a] !== undefined);
      const addonSum = addons.reduce((s, a) => s + ADDON_PRICES[a], 0);
      const subtotal = base + addonSum;
      let discount   = 0;
      if (appliedCoupon) {
        discount = appliedCoupon.discountType === 'percent'
          ? Math.round(subtotal * appliedCoupon.discountValue) / 100
          : Math.min(appliedCoupon.discountValue, subtotal);
      }
      lines.innerHTML = `<div class="flex justify-between text-sm"><span class="text-gray-300">${tier} package</span><span class="text-white">$${base}</span></div>`;
      addons.forEach(a => { lines.innerHTML += `<div class="flex justify-between text-sm"><span class="text-gray-400">${a}</span><span class="text-amber-400">+$${ADDON_PRICES[a]}</span></div>`; });
      if (discount > 0) { lines.innerHTML += `<div class="flex justify-between text-sm"><span class="text-green-400">Coupon</span><span class="text-green-400">−$${discount.toFixed(2)}</span></div>`; }
      total.textContent = `$${Math.max(0, subtotal - discount).toFixed(2)}`;
      box.classList.remove('hidden');
    }

    window.applyCoupon = async function applyCoupon() {
      const input  = document.getElementById('coupon-input');
      const msg    = document.getElementById('coupon-msg');
      const hidden = document.getElementById('couponCode');
      const code   = input.value.trim().toUpperCase();
      if (!code) return;
      msg.className = 'text-xs mt-2 text-gray-400'; msg.textContent = 'Checking…'; msg.classList.remove('hidden');
      try {
        const res  = await fetch('/hire/coupon/validate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
        const data = await res.json();
        if (data.valid) {
          appliedCoupon = { discountType: data.discountType, discountValue: data.discountValue };
          hidden.value = code; msg.className = 'text-xs mt-2 text-green-400'; msg.textContent = '✓ ' + data.message; input.disabled = true; updateEstimate();
        } else {
          appliedCoupon = null; hidden.value = ''; msg.className = 'text-xs mt-2 text-red-400'; msg.textContent = data.message; updateEstimate();
        }
      } catch { msg.className = 'text-xs mt-2 text-red-400'; msg.textContent = 'Could not validate. Try again.'; }
    }

    document.getElementById('coupon-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); applyCoupon(); } });

    function selectOption(id, value, label) {
      document.getElementById('pricingTier').value = value;
      document.getElementById(`${id}-label`).textContent = label;
      const trigger = document.getElementById(`${id}-trigger`);
      trigger.classList.add('selected'); trigger.classList.remove('error');
      document.querySelectorAll(`#${id}-menu .custom-select-option`).forEach(o => o.classList.remove('active'));
      event.currentTarget.classList.add('active');
      document.getElementById(`${id}-menu`).classList.remove('open');
      trigger.classList.remove('open'); trigger.setAttribute('aria-expanded', 'false');
      document.getElementById('err-tier').classList.add('hidden');
      document.getElementById('budget-field').classList.toggle('hidden', value !== 'Custom');
      updateEstimate();
    }

    document.addEventListener('click', e => { if (!e.target.closest('.custom-select')) closeAllDropdowns(); });

    // ── Tier prefill from ?tier= ──
    (function() {
      const TIER_LABELS = { Clip: 'Clip — $79', Scene: 'Scene — $189', Feature: 'Feature — $399', Custom: 'Custom budget' };
      const param = new URLSearchParams(window.location.search).get('tier');
      if (!param || !TIER_LABELS[param]) return;
      document.getElementById('pricingTier').value = param;
      document.getElementById('cs-tier-label').textContent = TIER_LABELS[param];
      document.getElementById('cs-tier-trigger').classList.add('selected');
      const match = document.querySelector(`#cs-tier-menu [data-value="${param}"]`);
      if (match) match.classList.add('active');
      if (param === 'Custom') document.getElementById('budget-field').classList.remove('hidden');
      updateEstimate();
    })();

    // ── Submit loading state ──
    document.getElementById('booking-form').addEventListener('submit', e => {
      const errEl    = document.getElementById('err-files');
      const hasVideo = selectedFiles.some(f => f.type.startsWith('video/'));
      if (!hasVideo) {
        e.preventDefault();
        errEl.textContent = 'Please upload at least one video file.';
        errEl.classList.remove('hidden');
        return;
      }
      errEl.classList.add('hidden');
      const btn     = document.getElementById('submit-btn');
      const label   = document.getElementById('submit-label');
      const spinner = document.getElementById('submit-spinner');
      btn.disabled = true; label.textContent = 'Submitting…'; spinner.classList.remove('hidden');
    });

    } // end if booking-form

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.toggle('hidden');
    }
  </script>
  <%- include('_toast') %>
  <%- include('_notif-poll') %>
</body>
</html>
