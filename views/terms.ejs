  <script>
    (function () {
      var links = Array.prototype.slice.call(document.querySelectorAll('.toc-link'));
      if (!links.length) return;
      var sections = links
        .map(function (link) { return document.querySelector(link.getAttribute('href')); })
        .filter(Boolean);

      var READ_LINE = 120; // px from top of viewport that counts as "current"

      var setActive = function (id) {
        links.forEach(function (link) {
          link.classList.toggle('active', link.getAttribute('href') === '#' + id);
        });
      };

      var ticking = false;
      var updateActiveSection = function () {
        ticking = false;
        // Near the bottom of the page there isn't enough room left to scroll the last
        // section(s) up to READ_LINE, so fall back to "last section" once the page
        // itself is scrolled (near) all the way down.
        var atBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
        var current = sections[0];
        if (atBottom) {
          current = sections[sections.length - 1];
        } else {
          for (var i = 0; i < sections.length; i++) {
            if (sections[i].getBoundingClientRect().top <= READ_LINE) {
              current = sections[i];
            } else {
              break;
            }
          }
        }
        setActive(current.id);
      };

      window.addEventListener('scroll', function () {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(updateActiveSection);
        }
      }, { passive: true });

      updateActiveSection();

      // Search box: filter the table of contents by matching against each
      // section's full text, not just its title, so a search for a word like
      // "Stripe" or "archive" can surface the right topic even if that word
      // isn't in the heading itself.
      var searchInput = document.getElementById('toc-search');
      var noResults = document.getElementById('toc-no-results');
      if (searchInput) {
        var searchIndex = links.map(function (link, i) {
          return { link: link, text: (link.textContent + ' ' + (sections[i] ? sections[i].textContent : '')).toLowerCase() };
        });

        var filterToc = function () {
          var query = searchInput.value.trim().toLowerCase();
          var visibleCount = 0;
          searchIndex.forEach(function (entry) {
            var matches = !query || entry.text.indexOf(query) !== -1;
            entry.link.classList.toggle('hidden', !matches);
            if (matches) visibleCount++;
          });
          noResults.classList.toggle('hidden', visibleCount !== 0);
        };

        searchInput.addEventListener('input', filterToc);

        searchInput.addEventListener('keydown', function (e) {
          if (e.key !== 'Enter') return;
          var firstVisible = searchIndex.find(function (entry) { return !entry.link.classList.contains('hidden'); });
          if (firstVisible) {
            firstVisible.link.click();
            searchInput.blur();
          }
        });
      }
    })();
  </script>

