<div id="application-modal-overlay" class="fixed inset-0 z-9998 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4">
  <div id="application-modal" class="w-120 max-w-full rounded-xl border border-white/10 bg-[#1a1a1a] shadow-2xl p-6" role="dialog" aria-modal="true" aria-labelledby="application-modal-title">
    <div class="flex items-start justify-between gap-3.5 mb-5">
      <div>
        <h3 id="application-modal-title" class="text-[15px] font-semibold text-white">Apply</h3>
        <p id="application-modal-role" class="text-sm text-amber-400 mt-1"></p>
      </div>
      <button type="button" id="application-modal-close" class="text-gray-500 hover:text-gray-300 transition-colors cursor-pointer shrink-0">
        <iconify-icon icon="material-symbols-light:close" width="20" height="20"></iconify-icon>
      </button>
    </div>

    <form id="application-modal-form">
      <input type="hidden" name="roleId" id="application-modal-role-id" value="" />

      <div class="space-y-3.5">
        <div>
          <label class="block text-xs font-semibold text-gray-400 mb-1.5">Name</label>
          <input type="text" name="name" required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-3.5 py-2.5 text-sm text-white placeholder:text-gray-600 outline-none focus:border-amber-400/50 transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 mb-1.5">Email</label>
          <input type="email" name="email" required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-3.5 py-2.5 text-sm text-white placeholder:text-gray-600 outline-none focus:border-amber-400/50 transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 mb-1.5">Message</label>
          <textarea name="message" required rows="4" maxlength="2000" placeholder="Tell us about yourself and link to your work, if you have somewhere to point us."
            class="w-full bg-white/5 border border-white/10 rounded-lg px-3.5 py-2.5 text-sm text-white placeholder:text-gray-600 outline-none focus:border-amber-400/50 transition-colors resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-400 mb-1.5">Work sample <span class="text-gray-600 font-normal">(optional)</span></label>
          <input type="file" name="file" accept="video/*,audio/*,image/*,.pdf,.zip,.rar"
            class="w-full text-sm text-gray-400 file:mr-3 file:py-2 file:px-3.5 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-white/10 file:text-white hover:file:bg-white/15 file:cursor-pointer cursor-pointer" />
        </div>
      </div>

      <p id="application-modal-error" class="hidden text-red-400 text-xs mt-4"></p>

      <div class="flex justify-end gap-2 mt-6">
        <button type="button" id="application-modal-cancel" class="text-sm font-semibold px-4 py-2 rounded-lg text-gray-300 hover:bg-white/6 transition-colors cursor-pointer">Cancel</button>
        <button type="submit" id="application-modal-submit" class="text-sm font-semibold px-5 py-2 rounded-lg bg-amber-400 text-black hover:bg-amber-300 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">Send application</button>
      </div>
    </form>
  </div>
</div>

<script>
(function () {
  const overlay    = document.getElementById('application-modal-overlay');
  const roleLabel  = document.getElementById('application-modal-role');
  const roleIdInput = document.getElementById('application-modal-role-id');
  const form       = document.getElementById('application-modal-form');
  const errorEl    = document.getElementById('application-modal-error');
  const submitBtn  = document.getElementById('application-modal-submit');
  const closeBtn   = document.getElementById('application-modal-close');
  const cancelBtn  = document.getElementById('application-modal-cancel');
  const nameInput  = form.querySelector('input[name="name"]');

  let lastFocused = null;

  function open(roleId, roleTitle) {
    roleIdInput.value = roleId || '';
    roleLabel.textContent = 'Applying for: ' + (roleTitle || 'General Application');
    errorEl.classList.add('hidden');
    form.reset();
    lastFocused = document.activeElement;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.addEventListener('keydown', onKeydown);
    nameInput.focus();
  }

  function close() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.removeEventListener('keydown', onKeydown);
    if (lastFocused && lastFocused.focus) lastFocused.focus();
  }

  function onKeydown(e) {
    if (e.key === 'Escape') close();
  }

  closeBtn.addEventListener('click', close);
  cancelBtn.addEventListener('click', close);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    try {
      const res = await fetch('/career/apply', { method: 'POST', body: new FormData(form) });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || 'Something went wrong. Please try again.');
      close();
      window.showToast('Application received', "We'll be in touch if it's a fit.", 'success');
    } catch (err) {
      errorEl.textContent = err.message;
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send application';
    }
  });

  window.openApplicationModal = open;
}());
</script>
